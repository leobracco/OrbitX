# ══════════════════════════════════════════════════════
#  OrbitX — Agro Parallel · .gitignore
# ══════════════════════════════════════════════════════

# ── Entorno ────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Node ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ── Datos locales (PouchDB / SQLite) ──────────────────
data/
*.db
*.db-journal
*.db-shm
*.db-wal

# ── Logs ───────────────────────────────────────────────
logs/
*.log
pids/
*.pid

# ── Build / dist ───────────────────────────────────────
dist/
build/
.cache/
.parcel-cache/

# ── OS ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── Editor ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── PM2 ────────────────────────────────────────────────
.pm2/
ecosystem.config.js.bak

# ── Certificados SSL ───────────────────────────────────
*.pem
*.key
*.crt
*.csr

# ── Backups AOG locales ────────────────────────────────
# (se guardan en CouchDB, no en el repo)
aog_backups/

# ── Coverage / test ────────────────────────────────────
coverage/
.nyc_output/
