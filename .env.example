# ══════════════════════════════════════════════════════
#  OrbitX Cloud Server — Variables de entorno
#  Agro Parallel · Renombrá este archivo a .env
# ══════════════════════════════════════════════════════

# ── Servidor ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*
BASE_URL=http://localhost:4000

# ── CouchDB ────────────────────────────────────────────
# Formato: http://usuario:contraseña@host:puerto
COUCHDB_URL=http://admin:password@localhost:5984

# ── JWT (usuarios web/app) ────────────────────────────
# Cambiá esto por una cadena larga y aleatoria en producción
# Generá una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=orbitx-dev-secret-cambiar-en-produccion

# ── Auth de dispositivos (tractores) ─────────────────
# Token maestro de fallback (legacy / bootstrap del primer device).
# Cada dispositivo tiene además su propio token único en CouchDB.
DEVICE_MASTER_TOKEN=vx-device-token-cambiar

# ── agrarIA (Anthropic) ───────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ══════════════════════════════════════════════════════
#  Notificaciones de admin global (Agro Parallel)
#  Bot único para avisarte de eventos críticos en tu Telegram personal:
#  nuevo registro, nueva org aprobada, firmware subido, OTA fallida, login sospechoso, etc.
# ══════════════════════════════════════════════════════
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ══════════════════════════════════════════════════════
#  SMTP global del server (verificación de email + reset password)
#  Las orgs configuran su propio SMTP en /integraciones (independiente).
# ══════════════════════════════════════════════════════
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Agro Parallel <no-reply@agroparallel.com>"

# ══════════════════════════════════════════════════════
#  WhatsApp Cloud API oficial Meta — credenciales por defecto
#  Cada org puede sobrescribir con sus propias credenciales en /integraciones.
#  Si la org no tiene credenciales propias, NO se manda WhatsApp (no usar este como fallback global).
# ══════════════════════════════════════════════════════
WHATSAPP_API_VERSION=v20.0
# Verify token usado por el webhook de Meta para validar callbacks.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ══════════════════════════════════════════════════════
#  OTA — almacenamiento de firmwares
# ══════════════════════════════════════════════════════
# Carpeta absoluta donde se guardan los .bin. Default: <root>/firmwares
FIRMWARE_DIR=

# ══════════════════════════════════════════════════════
#  Deploy
# ══════════════════════════════════════════════════════
# Fecha de deploy — la PWA la usa para detectar actualizaciones
DEPLOY_DATE=2026-05-04T00:00:00Z
