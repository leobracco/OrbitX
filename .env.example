# ══════════════════════════════════════════════════════
#  OrbitX Cloud Server — Variables de entorno
#  Agro Parallel · Renombrá este archivo a .env
# ══════════════════════════════════════════════════════

# ── Servidor ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# ── CouchDB ────────────────────────────────────────────
# Formato: http://usuario:contraseña@host:puerto
COUCHDB_URL=http://admin:password@localhost:5984

# ── JWT (usuarios web/app) ────────────────────────────
# Cambiá esto por una cadena larga y aleatoria en producción
# Generá una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=orbitx-dev-secret-cambiar-en-produccion

# ── Auth de dispositivos (tractores) ─────────────────
# Token fijo que usan los ESP32/PouchDB para autenticarse
# No es JWT — es un token compartido entre todos los tractores
DEVICE_MASTER_TOKEN=vx-device-token-cambiar

# ── agrarIA (Anthropic) ───────────────────────────────
# Se inyecta automáticamente en entorno Anthropic
# En producción agregá tu API key acá:
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Deploy ─────────────────────────────────────────────
# Fecha de deploy — la PWA la usa para detectar actualizaciones
DEPLOY_DATE=2025-03-21T00:00:00Z