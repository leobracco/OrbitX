<%# pages/config.ejs — Configuración del sistema (solo superadmin) %>

<div class="page-header">
  <div>
    <h2>Configuración del sistema</h2>
    <p>Telegram, SMTP, WhatsApp, agrarIA y servidor — todo se guarda en CouchDB y se lee sin reiniciar</p>
  </div>
</div>

<div id="cfg-alert" class="alert" style="margin-bottom:14px"></div>

<!-- Servidor -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head"><span class="card-title">Servidor</span></div>
  <div class="card-body">
    <div class="form-grid">
      <div class="field"><label>Puerto</label><input value="<%= config.port %>" readonly/></div>
      <div class="field"><label>Entorno</label><input value="<%= config.nodeEnv %>" readonly/></div>
      <div class="field field-full"><label>CORS Origin</label><input value="<%= config.corsOrigin %>" readonly/></div>
      <div class="field field-full"><label>Base URL pública</label>
        <input data-key="BASE_URL" placeholder="https://orbitx.agroparallel.com" />
      </div>
    </div>
  </div>
</div>

<!-- CouchDB -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head"><span class="card-title">CouchDB</span></div>
  <div class="card-body">
    <div class="form-grid">
      <div class="field field-full"><label>URL</label><input value="<%= config.couchUrl %>" readonly/></div>
      <div class="field"><label>Prefijo</label><input value="orbitx_" readonly/></div>
      <div class="field"><label>DB Global</label><input value="orbitx_global" readonly/></div>
    </div>
  </div>
</div>

<!-- Telegram admin -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head">
    <span class="card-title">Telegram — Admin global Agro Parallel</span>
    <span class="badge badge-lime" data-status="telegram">Estado…</span>
  </div>
  <div class="card-body">
    <p style="font-size:12px;color:var(--ap-muted);margin-bottom:12px;line-height:1.6">
      Bot que te avisa por Telegram cuando se registra un usuario, se aprueba una org, se sube un firmware, falla un OTA, etc.
      Crealo con <span class="td-mono">@BotFather</span> y obtené tu chat\_id desde <span class="td-mono">getUpdates</span>.
    </p>
    <div class="form-grid">
      <div class="field field-full"><label>Bot token</label>
        <input type="password" data-key="TELEGRAM_ADMIN_BOT_TOKEN" placeholder="7234567890:AAFh..."/>
      </div>
      <div class="field field-full"><label>Chat ID</label>
        <input data-key="TELEGRAM_ADMIN_CHAT_ID" placeholder="1234567890"/>
      </div>
    </div>
    <div style="margin-top:14px;display:flex;gap:8px">
      <button class="btn btn-primary" onclick="cfgGuardar(['TELEGRAM_ADMIN_BOT_TOKEN','TELEGRAM_ADMIN_CHAT_ID'])">Guardar</button>
      <button class="btn" onclick="cfgProbar('telegram')">Probar envío</button>
    </div>
  </div>
</div>

<!-- SMTP global -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head">
    <span class="card-title">SMTP global — Verificación de email + reset password</span>
    <span class="badge badge-lime" data-status="smtp">Estado…</span>
  </div>
  <div class="card-body">
    <p style="font-size:12px;color:var(--ap-muted);margin-bottom:12px;line-height:1.6">
      Casilla desde la que sale los mails de verificación y recupero de contraseña.
      Si tu cliente quiere mandar alertas con SMTP propio, lo configura desde <span class="td-mono">/integraciones</span> (independiente).
    </p>
    <div class="form-grid">
      <div class="field"><label>Host</label><input data-key="SMTP_HOST" placeholder="smtp.gmail.com"/></div>
      <div class="field"><label>Puerto</label><input data-key="SMTP_PORT" placeholder="587"/></div>
      <div class="field"><label>Secure (TLS)</label>
        <select data-key="SMTP_SECURE">
          <option value="false">No (STARTTLS, 587)</option>
          <option value="true">Sí (465)</option>
        </select>
      </div>
      <div class="field"><label>From</label><input data-key="SMTP_FROM" placeholder="Agro Parallel <no-reply@agroparallel.com>"/></div>
      <div class="field"><label>Usuario</label><input data-key="SMTP_USER" placeholder="usuario@dominio.com"/></div>
      <div class="field"><label>Contraseña</label><input type="password" data-key="SMTP_PASS" placeholder="••••••••"/></div>
    </div>
    <div style="margin-top:14px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
      <button class="btn btn-primary" onclick="cfgGuardar(['SMTP_HOST','SMTP_PORT','SMTP_SECURE','SMTP_USER','SMTP_PASS','SMTP_FROM'])">Guardar</button>
      <input id="smtp-test-to" placeholder="email destino para test" style="background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px 12px;border-radius:8px;font-size:12px;min-width:240px"/>
      <button class="btn" onclick="cfgProbar('smtp')">Probar envío</button>
    </div>
    <div style="margin-top:10px;font-size:11px;color:var(--ap-muted)">
      ⚠️ Para que el test funcione hace falta <span class="td-mono">npm install nodemailer</span>.
    </div>
  </div>
</div>

<!-- WhatsApp Cloud API -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head">
    <span class="card-title">WhatsApp Cloud API — Defaults globales</span>
    <span class="badge badge-lime" data-status="whatsapp">Estado…</span>
  </div>
  <div class="card-body">
    <p style="font-size:12px;color:var(--ap-muted);margin-bottom:12px;line-height:1.6">
      Credenciales globales de Meta (API oficial). Cada org puede sobrescribir con las suyas en <span class="td-mono">/integraciones</span>.
      Para enviar fuera de la ventana de 24hs hace falta una <b>plantilla pre-aprobada</b>.
    </p>
    <div class="form-grid">
      <div class="field"><label>API version</label><input data-key="WHATSAPP_API_VERSION" placeholder="v20.0"/></div>
      <div class="field"><label>Phone Number ID</label><input data-key="WHATSAPP_PHONE_NUMBER_ID" placeholder="1234567890"/></div>
      <div class="field field-full"><label>Access Token</label>
        <input type="password" data-key="WHATSAPP_ACCESS_TOKEN" placeholder="EAAG..."/>
      </div>
      <div class="field field-full"><label>Webhook Verify Token</label>
        <input data-key="WHATSAPP_WEBHOOK_VERIFY_TOKEN" placeholder="cadena random que pegás en Meta Developers"/>
      </div>
    </div>
    <div style="margin-top:14px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
      <button class="btn btn-primary" onclick="cfgGuardar(['WHATSAPP_API_VERSION','WHATSAPP_PHONE_NUMBER_ID','WHATSAPP_ACCESS_TOKEN','WHATSAPP_WEBHOOK_VERIFY_TOKEN'])">Guardar</button>
      <input id="wa-test-to" placeholder="número destino (ej: 5493510000000)" style="background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px 12px;border-radius:8px;font-size:12px;min-width:240px"/>
      <button class="btn" onclick="cfgProbar('whatsapp')">Probar envío</button>
    </div>
  </div>
</div>

<!-- Copernicus / Sentinel Hub -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head">
    <span class="card-title">Copernicus Data Space — NDVI / Sentinel-2</span>
    <span class="badge badge-lime" data-status="copernicus">Estado…</span>
  </div>
  <div class="card-body">
    <p style="font-size:12px;color:var(--ap-muted);margin-bottom:12px;line-height:1.6">
      Una sola cuenta global de Agro Parallel para todas las orgs. Registrate en
      <a href="https://dataspace.copernicus.eu" target="_blank" style="color:var(--ap-green)">dataspace.copernicus.eu</a>,
      creá una OAuth client (Account → OAuth clients) y una WMS configuration (Sentinel Hub Dashboard → Configuration Utility).
      Hasta 10.000 PU/mes gratis.
    </p>
    <div class="form-grid">
      <div class="field field-full"><label>Client ID</label>
        <input data-key="COPERNICUS_CLIENT_ID" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
      </div>
      <div class="field field-full"><label>Client Secret</label>
        <input type="password" data-key="COPERNICUS_CLIENT_SECRET" placeholder="••••••••••••"/>
      </div>
      <div class="field field-full"><label>Instance ID (WMS config)</label>
        <input data-key="COPERNICUS_INSTANCE_ID" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
      </div>
    </div>
    <div style="margin-top:14px;display:flex;gap:8px">
      <button class="btn btn-primary" onclick="cfgGuardar(['COPERNICUS_CLIENT_ID','COPERNICUS_CLIENT_SECRET','COPERNICUS_INSTANCE_ID'])">Guardar</button>
      <button class="btn" onclick="cfgProbar('copernicus')">Probar conexión</button>
    </div>
  </div>
</div>

<!-- agrarIA Anthropic -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head">
    <span class="card-title">agrarIA — Anthropic API</span>
    <span class="badge badge-lime" data-status="anthropic">Estado…</span>
  </div>
  <div class="card-body">
    <div class="form-grid">
      <div class="field field-full"><label>API Key</label>
        <input type="password" data-key="ANTHROPIC_API_KEY" placeholder="sk-ant-api03-..."/>
      </div>
      <div class="field"><label>Modelo</label><input value="claude-sonnet-4-6" readonly/></div>
      <div class="field"><label>Resumen diario</label><input value="19:00 (America/Argentina/Cordoba)" readonly/></div>
    </div>
    <div style="margin-top:14px">
      <button class="btn btn-primary" onclick="cfgGuardar(['ANTHROPIC_API_KEY'])">Guardar</button>
    </div>
  </div>
</div>

<!-- Auth de dispositivos -->
<div class="card" style="margin-bottom:14px">
  <div class="card-head"><span class="card-title">Autenticación de dispositivos</span></div>
  <div class="card-body">
    <div class="form-grid">
      <div class="field field-full"><label>Device Master Token (legacy/bootstrap)</label>
        <input type="password" data-key="DEVICE_MASTER_TOKEN" placeholder="vx-device-token-..."/>
      </div>
    </div>
    <div style="margin-top:10px;font-size:11px;color:var(--ap-muted);line-height:1.7">
      ⚠️ Cada dispositivo nuevo se crea desde <span class="td-mono">/dispositivos</span> con su propio token único.
      Este master token es solo para el bootstrap del primer device de un cliente.
    </div>
    <div style="margin-top:14px">
      <button class="btn btn-primary" onclick="cfgGuardar(['DEVICE_MASTER_TOKEN'])">Guardar</button>
    </div>
  </div>
</div>

<script src="/js/config-admin.js"></script>
