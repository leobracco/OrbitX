<%# pages/camaras.ejs — Visualización remota de cámaras por tractor (HLS) %>

<div class="page-header">
  <div>
    <h2>Cámaras</h2>
    <p>Streaming en vivo de cada tractor · HLS Low-Latency · Acceso multi-dispositivo</p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <select id="sel-device" class="input" style="min-width:240px">
      <option value="">— Elegí un tractor —</option>
      <% (dispositivos || []).forEach(d => { %>
        <option value="<%= d.device_id %>" <%= d.online ? '' : 'data-offline="1"' %>>
          <%= d.online ? '🟢' : '⚪' %> <%= d.nombre || d.device_id %>
        </option>
      <% }); %>
    </select>
    <select id="sel-vista" class="input" title="Cuántas cámaras reproducir simultáneamente — para no saturar la subida del tractor">
      <option value="manual">👁 Vista: manual (ninguna)</option>
      <option value="1">👁 Vista: 1 cámara</option>
      <option value="2">👁 Vista: 2 cámaras</option>
      <option value="all">👁 Vista: todas</option>
    </select>
    <button class="btn" onclick="detenerTodos()" title="Cortar todos los streams activos">⏹ Detener todo</button>
    <button class="btn" onclick="recargarCamaras()">↻ Refrescar</button>
  </div>
</div>

<% if ((typeof user !== 'undefined') && user && user.rol_global === 'superadmin') { %>
<div class="card" style="padding:10px 14px;margin-bottom:14px;background:rgba(255,200,40,0.05);border:1px solid rgba(255,200,40,0.2)">
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <span style="font-family:var(--font-h);font-size:12px">🧪 Modo test (solo SA):</span>
    <button class="btn" onclick="iniciarTest()">▶ Iniciar test stream</button>
    <button class="btn" onclick="detenerTest()">⏹ Detener</button>
    <span id="test-status" style="font-size:11px;color:var(--muted);font-family:var(--font-m)"></span>
  </div>
</div>
<% } %>

<div id="info-box" class="card" style="display:none;padding:14px;margin-bottom:14px;background:rgba(60,158,255,0.05);border:1px solid rgba(60,158,255,0.2)">
  <div id="info-text" style="font-family:var(--font-m);font-size:12px"></div>
</div>

<div id="grid-camaras" class="kpi-grid" style="grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:14px"></div>

<div id="empty-state" style="text-align:center;padding:80px 20px;color:var(--muted);display:none">
  <div style="font-size:40px;margin-bottom:10px">📹</div>
  <div style="font-family:var(--font-h)">Este tractor no tiene cámaras registradas todavía</div>
  <div style="font-size:12px;margin-top:8px">El tractor las publica automáticamente cuando PilotX arranca el módulo de Cámaras y tildás "Streaming remoto".</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.13/dist/hls.min.js"></script>
<script>
const $sel = document.getElementById("sel-device");
const $selVista = document.getElementById("sel-vista");
const $grid = document.getElementById("grid-camaras");
const $empty = document.getElementById("empty-state");
const $info = document.getElementById("info-box");
const $infoText = document.getElementById("info-text");

const players = new Map(); // key=`${devId}_${camIdx}` -> { hls, video }

// Recordamos la última vista elegida (global, por simplicidad).
$selVista.value = localStorage.getItem("camaras_vista") || "manual";
$selVista.addEventListener("change", () => {
  localStorage.setItem("camaras_vista", $selVista.value);
  aplicarVista();
});

$sel.addEventListener("change", () => recargarCamaras());

async function recargarCamaras() {
  destruirPlayers();
  $grid.innerHTML = "";
  $empty.style.display = "none";
  $info.style.display = "none";

  const devId = $sel.value;
  if (!devId) return;

  try {
    const r = await fetch(`/api/camaras/list/${encodeURIComponent(devId)}`, { credentials: "include" });
    const j = await r.json();
    if (!r.ok) throw new Error(j.error || "error");

    if (!j.device.online) {
      mostrarInfo(`⚠ Tractor offline. El stream solo está disponible cuando el tractor está conectado y publicando.`);
    }

    const cams = (j.camaras || []).filter(c => c.activa);
    if (cams.length === 0) {
      $empty.style.display = "block";
      return;
    }

    // Renderizamos las cards SIN arrancar streams — el usuario decide cuáles
    // reproducir (con el selector de vista) para no saturar la subida del tractor.
    for (const c of cams) {
      const card = crearCard(devId, j.device.nombre, c);
      $grid.appendChild(card);
    }
    aplicarVista();
  } catch (e) {
    mostrarInfo(`✗ ${e.message}`);
  }
}

// Aplica el modo de vista actual: arranca/para streams según la elección
// (manual / 1 / 2 / todas) sin recargar el listado.
function aplicarVista() {
  const modo = $selVista.value;
  const cards = Array.from($grid.querySelectorAll(".cam-card"));
  let limit;
  if (modo === "manual") limit = 0;
  else if (modo === "all") limit = cards.length;
  else limit = parseInt(modo, 10) || 0;

  cards.forEach((card, i) => {
    const devId = card.dataset.devId;
    const camIdx = parseInt(card.dataset.camIdx, 10);
    const key = `${devId}_${camIdx}`;
    const yaCorriendo = players.has(key);
    if (i < limit && !yaCorriendo) {
      cargarStream(devId, camIdx, card);
    } else if (i >= limit && yaCorriendo) {
      detenerStream(devId, camIdx);
    }
  });
}

function crearCard(devId, devNombre, cam) {
  const card = document.createElement("div");
  card.className = "card cam-card";
  card.dataset.devId = devId;
  card.dataset.camIdx = cam.idx;
  card.style.padding = "10px";
  card.style.background = "rgba(0,0,0,0.4)";
  card.style.border = "1px solid rgba(255,255,255,0.08)";
  card.innerHTML = `
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <div style="font-family:var(--font-h);font-size:13px">📹 ${escape(cam.nombre)}</div>
      <div style="display:flex;gap:6px;align-items:center">
        <span class="badge-online ${cam.online ? 'on' : 'off'}" style="font-size:10px;padding:2px 8px;border-radius:4px;background:${cam.online ? 'rgba(113,181,40,0.2)' : 'rgba(255,68,68,0.15)'};color:${cam.online ? '#71B528' : '#ff4444'}">${cam.online ? '🔴 LIVE' : '⏸ sin stream'}</span>
        <button class="btn cam-toggle" style="font-size:10px;padding:3px 8px" onclick="toggleStream('${devId}', ${cam.idx}, this)">▶ Ver</button>
        <button class="btn" style="font-size:10px;padding:3px 8px" onclick="copiarRtsp('${devId}', ${cam.idx}, this)" title="Copiar URL RTSP para VLC/apps">RTSP</button>
      </div>
    </div>
    <div class="video-wrap" style="position:relative;background:#000;border-radius:6px;overflow:hidden;aspect-ratio:16/9">
      <video class="cam-video" controls muted playsinline style="width:100%;height:100%;object-fit:contain"></video>
      <div class="cam-status" style="position:absolute;left:8px;bottom:8px;font-size:10px;color:#aaa;background:rgba(0,0,0,0.5);padding:2px 6px;border-radius:3px">en pausa — apretá ▶ Ver</div>
    </div>
    <div style="font-size:10px;color:var(--muted);margin-top:6px;font-family:var(--font-m)">${escape(devNombre)} · cam ${cam.idx}</div>
  `;
  return card;
}

function toggleStream(devId, camIdx, btn) {
  const key = `${devId}_${camIdx}`;
  if (players.has(key)) {
    detenerStream(devId, camIdx);
  } else {
    const card = btn.closest(".cam-card");
    cargarStream(devId, camIdx, card);
  }
}

function detenerStream(devId, camIdx) {
  const key = `${devId}_${camIdx}`;
  const p = players.get(key);
  if (!p) return;
  try { p.hls && p.hls.destroy(); } catch {}
  try { p.video.src = ""; } catch {}
  players.delete(key);
  const card = $grid.querySelector(`.cam-card[data-dev-id="${devId}"][data-cam-idx="${camIdx}"]`);
  if (card) {
    const status = card.querySelector(".cam-status");
    const btn = card.querySelector(".cam-toggle");
    if (status) { status.textContent = "en pausa"; status.style.color = "#aaa"; }
    if (btn) btn.textContent = "▶ Ver";
  }
}

function detenerTodos() {
  for (const key of Array.from(players.keys())) {
    const [devId, camIdx] = key.split("_cam");
    // key format: <devId>_<camIdx> (cam idx = solo número). Mejor: re-derivar.
  }
  // Camino seguro: iterar las cards.
  $grid.querySelectorAll(".cam-card").forEach(card => {
    detenerStream(card.dataset.devId, parseInt(card.dataset.camIdx, 10));
  });
}

async function cargarStream(devId, camIdx, card) {
  const video = card.querySelector(".cam-video");
  const status = card.querySelector(".cam-status");
  const btn = card.querySelector(".cam-toggle");
  status.textContent = "conectando…";
  status.style.color = "#aaa";
  if (btn) btn.textContent = "⏹ Detener";
  try {
    const r = await fetch(`/api/camaras/playback/${encodeURIComponent(devId)}/${camIdx}`, { credentials: "include" });
    const j = await r.json();
    if (!r.ok) throw new Error(j.error || "error playback");

    const url = j.hls;
    card.dataset.rtsp = j.rtsp;

    if (Hls.isSupported()) {
      const hls = new Hls({
        lowLatencyMode: true,
        liveSyncDurationCount: 2,
        liveMaxLatencyDurationCount: 4,
        manifestLoadingTimeOut: 10000,
        manifestLoadingMaxRetry: 4,
      });
      hls.loadSource(url);
      hls.attachMedia(video);
      hls.on(Hls.Events.MANIFEST_PARSED, () => {
        status.textContent = "▶ live";
        status.style.color = "#71B528";
        video.play().catch(() => {});
      });
      hls.on(Hls.Events.ERROR, (_, data) => {
        if (!data.fatal) return;
        // manifestLoadError / manifestLoadTimeOut suelen significar que el
        // tractor no está publicando ese path — mostramos algo accionable.
        let msg = data.details || "error";
        if (msg === "manifestLoadError" || msg === "manifestLoadTimeOut") {
          msg = "El tractor no está publicando este stream (¿Streaming remoto tildado? ¿cámara online?)";
        } else if (msg === "manifestParsingError") {
          msg = "MediaMTX devolvió un manifest inválido";
        } else if (msg === "manifestIncompatibleCodecsError") {
          msg = "Codec no soportado por el browser";
        }
        status.textContent = "✗ " + msg;
        status.style.color = "#ff7676";
        // Liberamos el player para que el toggle vuelva a "▶ Ver".
        try { hls.destroy(); } catch {}
        players.delete(`${devId}_${camIdx}`);
        if (btn) btn.textContent = "▶ Ver";
      });
      players.set(`${devId}_${camIdx}`, { hls, video });
    } else if (video.canPlayType("application/vnd.apple.mpegurl")) {
      // iOS / Safari nativo
      video.src = url;
      video.addEventListener("loadedmetadata", () => video.play().catch(() => {}));
      status.textContent = "▶ live";
      status.style.color = "#71B528";
      players.set(`${devId}_${camIdx}`, { hls: null, video });
    } else {
      status.textContent = "✗ HLS no soportado en este browser";
      status.style.color = "#ff7676";
      if (btn) btn.textContent = "▶ Ver";
    }
  } catch (e) {
    status.textContent = "✗ " + e.message;
    status.style.color = "#ff7676";
    if (btn) btn.textContent = "▶ Ver";
  }
}

function destruirPlayers() {
  for (const { hls, video } of players.values()) {
    try { hls.destroy(); } catch {}
    try { video.src = ""; } catch {}
  }
  players.clear();
}

async function copiarRtsp(devId, camIdx, btn) {
  const card = btn.closest(".card");
  let url = card.dataset.rtsp;
  if (!url) {
    // pedir URL fresca por si expiró
    const r = await fetch(`/api/camaras/playback/${encodeURIComponent(devId)}/${camIdx}`, { credentials: "include" });
    const j = await r.json();
    url = j.rtsp;
  }
  try {
    await navigator.clipboard.writeText(url);
    btn.textContent = "✓ copiado";
    setTimeout(() => { btn.textContent = "RTSP"; }, 2000);
  } catch {
    prompt("Copialo manualmente:", url);
  }
}

function mostrarInfo(msg) {
  $info.style.display = "block";
  $infoText.textContent = msg;
}

function escape(s) {
  return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}

// ─── Test stream (solo superadmin) ─────────────────────────
async function iniciarTest() {
  const $st = document.getElementById("test-status");
  $st.textContent = "lanzando…";
  try {
    const r = await fetch("/api/camaras/test/start", { method: "POST", credentials: "include" });
    const j = await r.json();
    if (!r.ok) throw new Error(j.error || "error");
    $st.textContent = j.msg + " (recargando en 5s…)";
    setTimeout(() => location.reload(), 5000);
  } catch (e) {
    $st.textContent = "✗ " + e.message;
    $st.style.color = "#ff7676";
  }
}

async function detenerTest() {
  const $st = document.getElementById("test-status");
  try {
    await fetch("/api/camaras/test/stop", { method: "POST", credentials: "include" });
    $st.textContent = "test detenido";
    $st.style.color = "";
  } catch (e) {
    $st.textContent = "✗ " + e.message;
  }
}

// Liberar players al salir de la página
window.addEventListener("beforeunload", destruirPlayers);
</script>
