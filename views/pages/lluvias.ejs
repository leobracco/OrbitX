<%# pages/lluvias.ejs — Registro manual de lluvias + análisis agrarIA %>

<div class="page-header">
  <div>
    <h2>Lluvias</h2>
    <p>Registro de precipitaciones del establecimiento</p>
  </div>
  <div style="display:flex;gap:8px">
    <button class="btn btn-ghost" id="llu-btn-ina" onclick="lluAbrirINA()">🛰 Importar de INA</button>
    <button class="btn" onclick="lluAnalizar()">✦ Analizar con agrarIA</button>
    <button class="btn btn-ghost" onclick="lluCargar()">↻</button>
  </div>
</div>

<!-- Métricas -->
<div id="llu-metrics" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:16px"></div>

<div style="display:grid;grid-template-columns:340px 1fr;gap:16px;align-items:start">

  <!-- Form carga -->
  <div class="card" id="llu-form-card" style="padding:16px">
    <div style="font-size:14px;font-weight:600;margin-bottom:12px">Cargar lluvia</div>
    <div style="display:flex;flex-direction:column;gap:10px">
      <label style="font-size:11px;color:var(--ap-muted)">Fecha
        <input type="date" id="llu-fecha" style="width:100%;margin-top:4px;background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px;border-radius:8px;font-size:13px;outline:none"/>
      </label>
      <label style="font-size:11px;color:var(--ap-muted)">Milímetros
        <input type="number" id="llu-mm" min="0" max="1000" step="0.5" placeholder="Ej: 25"
          style="width:100%;margin-top:4px;background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px;border-radius:8px;font-size:13px;outline:none"/>
      </label>
      <label style="font-size:11px;color:var(--ap-muted)">Lote (opcional)
        <input type="text" id="llu-lote" placeholder="Ej: Lote 5"
          style="width:100%;margin-top:4px;background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px;border-radius:8px;font-size:13px;outline:none"/>
      </label>
      <label style="font-size:11px;color:var(--ap-muted)">Nota (opcional)
        <input type="text" id="llu-nota" placeholder="Observación"
          style="width:100%;margin-top:4px;background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px;border-radius:8px;font-size:13px;outline:none"/>
      </label>
      <button class="btn" style="width:100%" onclick="lluGuardar()">Guardar</button>
      <div id="llu-form-msg" style="font-size:11px;color:var(--ap-muted)"></div>
    </div>
  </div>

  <!-- Gráfico + tabla -->
  <div style="display:flex;flex-direction:column;gap:16px;min-width:0">
    <div class="card" style="padding:16px">
      <div style="font-size:14px;font-weight:600;margin-bottom:12px">Acumulado mensual (mm)</div>
      <div id="llu-chart" style="display:flex;align-items:flex-end;gap:6px;height:140px;overflow-x:auto;padding-bottom:4px"></div>
    </div>

    <div class="card" style="padding:0;overflow:hidden">
      <div id="llu-tabla"></div>
    </div>
  </div>
</div>

<!-- Modal importar de INA -->
<div class="modal-backdrop" id="modal-llu-ina">
  <div class="modal" style="width:640px;max-height:85vh;display:flex;flex-direction:column">
    <div class="modal-title">🛰 Importar histórico del INA</div>
    <div class="modal-sub">Red Hidrológica Nacional · alerta.ina.gob.ar</div>

    <div style="margin-top:14px;display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
      <label style="font-size:11px;color:var(--ap-muted);flex:1;min-width:160px">Buscar estación (nombre o distrito)
        <input type="text" id="ina-q" placeholder="Ej: Pergamino"
          onkeydown="if(event.key==='Enter'){event.preventDefault();lluBuscarINA()}"
          style="width:100%;margin-top:4px;background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px;border-radius:8px;font-size:13px;outline:none"/>
      </label>
      <button class="btn btn-ghost" style="flex-shrink:0" onclick="lluBuscarINA()">Buscar</button>
      <button class="btn btn-ghost" style="flex-shrink:0" onclick="lluEstacionesCercanas()">📍 Cercanas al campo</button>
    </div>
    <div id="ina-ubic-msg" style="font-size:11px;color:var(--ap-muted);margin-top:6px"></div>

    <div id="ina-lista" style="margin-top:12px;overflow:auto;flex:1;min-height:80px"></div>

    <div id="ina-import-box" style="display:none;margin-top:12px;padding-top:12px;border-top:1px solid var(--ap-border)">
      <div style="font-size:12px;margin-bottom:8px">Importar de <strong id="ina-sel-nombre"></strong></div>
      <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
        <label style="font-size:11px;color:var(--ap-muted)">Desde
          <input type="date" id="ina-desde" style="margin-top:4px;background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px;border-radius:8px;font-size:13px;outline:none"/>
        </label>
        <label style="font-size:11px;color:var(--ap-muted)">Hasta
          <input type="date" id="ina-hasta" style="margin-top:4px;background:var(--ap-bg);border:1px solid var(--ap-border);color:var(--ap-text);padding:8px;border-radius:8px;font-size:13px;outline:none"/>
        </label>
        <button class="btn" style="flex-shrink:0" id="ina-btn-importar" onclick="lluImportarINA()">Importar</button>
      </div>
      <div id="ina-import-msg" style="font-size:12px;color:var(--ap-muted);margin-top:8px"></div>
    </div>

    <button class="btn btn-ghost" style="width:100%;margin-top:14px;flex-shrink:0" onclick="closeModal('modal-llu-ina')">Cerrar</button>
  </div>
</div>

<!-- Modal análisis agrarIA -->
<div class="modal-backdrop" id="modal-llu-ia">
  <div class="modal" style="width:560px;max-height:80vh;display:flex;flex-direction:column">
    <div class="modal-title">✦ agrarIA · Análisis de lluvias</div>
    <div class="modal-sub">Interpretación de lo cargado (no es pronóstico)</div>
    <div id="llu-ia-body" style="margin-top:14px;font-size:14px;line-height:1.6;color:var(--ap-text);overflow:auto;flex:1;white-space:pre-wrap"></div>
    <button class="btn btn-ghost" style="width:100%;margin-top:14px;flex-shrink:0" onclick="closeModal('modal-llu-ia')">Cerrar</button>
  </div>
</div>

<script>
let _lluItems = [];
let _lluPuedeEditar = true;

const MESES_ABR = ["ene","feb","mar","abr","may","jun","jul","ago","sep","oct","nov","dic"];

function lluEscape(s) {
  return String(s ?? "").replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}
function lluFmtFecha(f) {
  if (!f) return "–";
  const [y, m, d] = f.split("-");
  return `${d}/${m}/${y.slice(2)}`;
}

async function lluCargar() {
  document.getElementById("llu-tabla").innerHTML = '<div class="loading" style="padding:20px"><span class="spinner"></span> Cargando…</div>';
  try {
    const r = await Auth.get("/api/lluvias");
    _lluItems = r.registros || [];
    _lluPuedeEditar = r.puede_editar !== false;
    if (!_lluPuedeEditar) {
      document.getElementById("llu-form-card").style.display = "none";
      const bi = document.getElementById("llu-btn-ina");
      if (bi) bi.style.display = "none";
    }
    lluRender();
  } catch (e) {
    document.getElementById("llu-tabla").innerHTML = `<div class="alert error show" style="margin:16px">${lluEscape(e.message)}</div>`;
  }
}

function lluRender() {
  lluRenderMetrics();
  lluRenderChart();
  lluRenderTabla();
}

function lluRenderMetrics() {
  const total = _lluItems.reduce((a, r) => a + (Number(r.mm) || 0), 0);
  const mesActual = new Date().toISOString().slice(0, 7);
  const mesMM = _lluItems.filter(r => (r.fecha || "").startsWith(mesActual)).reduce((a, r) => a + (Number(r.mm) || 0), 0);
  const ordenados = [..._lluItems].sort((a, b) => (b.fecha || "").localeCompare(a.fecha || ""));
  const ultima = ordenados[0];
  const dias = ultima ? Math.max(0, Math.round((Date.now() - new Date(ultima.fecha)) / 86400000)) : null;

  const card = (label, valor, sub) => `
    <div class="card" style="padding:14px 16px">
      <div style="font-size:11px;color:var(--ap-muted);text-transform:uppercase;letter-spacing:1px">${label}</div>
      <div style="font-size:24px;font-weight:700;color:var(--ap-green);margin-top:4px">${valor}</div>
      <div style="font-size:11px;color:var(--ap-muted);margin-top:2px">${sub || ""}</div>
    </div>`;

  document.getElementById("llu-metrics").innerHTML =
    card("Total cargado", `${Math.round(total * 10) / 10} <span style='font-size:13px;color:var(--ap-muted)'>mm</span>`, `${_lluItems.length} registros`) +
    card("Este mes", `${Math.round(mesMM * 10) / 10} <span style='font-size:13px;color:var(--ap-muted)'>mm</span>`, mesActual) +
    card("Última lluvia", ultima ? `${ultima.mm} <span style='font-size:13px;color:var(--ap-muted)'>mm</span>` : "–", ultima ? lluFmtFecha(ultima.fecha) : "sin datos") +
    card("Días sin llover", dias != null ? dias : "–", "desde la última");
}

function lluRenderChart() {
  const porMes = {};
  _lluItems.forEach(r => {
    const mes = (r.fecha || "").slice(0, 7);
    if (mes) porMes[mes] = (porMes[mes] || 0) + (Number(r.mm) || 0);
  });
  const meses = Object.keys(porMes).sort().slice(-12);
  const chart = document.getElementById("llu-chart");
  if (!meses.length) {
    chart.innerHTML = `<div style="color:var(--ap-muted);font-size:12px;align-self:center">Sin datos todavía</div>`;
    return;
  }
  const max = Math.max(...meses.map(m => porMes[m]), 1);
  chart.innerHTML = meses.map(m => {
    const mm = Math.round(porMes[m] * 10) / 10;
    const h = Math.max(4, Math.round((porMes[m] / max) * 110));
    const [y, mo] = m.split("-");
    return `
      <div style="display:flex;flex-direction:column;align-items:center;gap:4px;min-width:36px;flex-shrink:0">
        <div style="font-size:10px;color:var(--ap-green);font-weight:600">${mm}</div>
        <div title="${m}: ${mm} mm" style="width:26px;height:${h}px;background:var(--ap-green-dim);border:1px solid rgba(164,186,62,0.35);border-radius:4px 4px 0 0"></div>
        <div style="font-size:10px;color:var(--ap-muted)">${MESES_ABR[parseInt(mo,10)-1]}<br>${y.slice(2)}</div>
      </div>`;
  }).join("");
}

function lluRenderTabla() {
  const t = document.getElementById("llu-tabla");
  if (!_lluItems.length) {
    t.innerHTML = `<div class="empty-state" style="padding:32px"><span class="icon">🌧</span><p>No hay lluvias cargadas todavía.</p></div>`;
    return;
  }
  const ordenados = [..._lluItems].sort((a, b) => (b.fecha || "").localeCompare(a.fecha || ""));
  t.innerHTML = `
    <table style="width:100%;border-collapse:collapse;font-size:13px">
      <thead>
        <tr style="text-align:left;color:var(--ap-muted);font-size:11px;text-transform:uppercase;letter-spacing:1px">
          <th style="padding:10px 16px">Fecha</th>
          <th style="padding:10px 16px">mm</th>
          <th style="padding:10px 16px">Lote</th>
          <th style="padding:10px 16px">Nota</th>
          <th style="padding:10px 16px"></th>
        </tr>
      </thead>
      <tbody>
        ${ordenados.map(r => `
          <tr style="border-top:1px solid var(--ap-border)">
            <td style="padding:10px 16px">${lluFmtFecha(r.fecha)}${r.fuente === "ina" ? ` <span title="Importado del INA" style="font-size:9px;color:var(--ap-muted);border:1px solid var(--ap-border);border-radius:4px;padding:1px 4px;vertical-align:middle">INA</span>` : ""}</td>
            <td style="padding:10px 16px;color:var(--ap-green);font-weight:600">${r.mm}</td>
            <td style="padding:10px 16px;color:var(--ap-muted)">${lluEscape(r.lote || "–")}</td>
            <td style="padding:10px 16px;color:var(--ap-muted)">${lluEscape(r.nota || "")}</td>
            <td style="padding:10px 16px;text-align:right">
              ${_lluPuedeEditar ? `<button class="btn btn-ghost" style="padding:4px 10px;font-size:11px" onclick="lluBorrar('${lluEscape(r._id)}')">✕</button>` : ""}
            </td>
          </tr>`).join("")}
      </tbody>
    </table>`;
}

async function lluGuardar() {
  const fecha = document.getElementById("llu-fecha").value;
  const mm    = document.getElementById("llu-mm").value;
  const lote  = document.getElementById("llu-lote").value;
  const nota  = document.getElementById("llu-nota").value;
  const msg   = document.getElementById("llu-form-msg");

  if (!fecha) { msg.textContent = "Poné una fecha."; return; }
  if (mm === "" || Number(mm) < 0) { msg.textContent = "Poné los milímetros."; return; }

  msg.style.color = "var(--ap-muted)";
  msg.textContent = "Guardando…";
  try {
    await Auth.post("/api/lluvias", { fecha, mm: Number(mm), lote, nota });
    document.getElementById("llu-mm").value = "";
    document.getElementById("llu-lote").value = "";
    document.getElementById("llu-nota").value = "";
    msg.style.color = "var(--ap-green)";
    msg.textContent = "Guardado ✓";
    await lluCargar();
    setTimeout(() => { msg.textContent = ""; }, 2000);
  } catch (e) {
    msg.style.color = "var(--ap-red, #e5484d)";
    msg.textContent = e.message;
  }
}

async function lluBorrar(id) {
  if (!confirm("¿Borrar este registro de lluvia?")) return;
  try {
    await Auth.del("/api/lluvias/" + encodeURIComponent(id));
    await lluCargar();
  } catch (e) { alert(e.message); }
}

async function lluAnalizar() {
  const body = document.getElementById("llu-ia-body");
  body.innerHTML = '<div class="loading"><span class="spinner"></span> agrarIA está analizando…</div>';
  openModal("modal-llu-ia");
  try {
    const r = await Auth.post("/api/lluvias/analizar", {});
    body.textContent = r.analisis || "Sin respuesta.";
  } catch (e) {
    body.innerHTML = `<div class="alert error show">${lluEscape(e.message)}</div>`;
  }
}

// ── Importar de INA ──────────────────────────────────────
let _inaUbic = null;   // { lat, lon, lotes } o null
let _inaSel  = null;   // estación seleccionada

function lluAbrirINA() {
  openModal("modal-llu-ina");
  document.getElementById("ina-import-box").style.display = "none";
  _inaSel = null;
  // Rango por defecto: últimos 2 años.
  const hoy = new Date();
  const hace2 = new Date(hoy); hace2.setFullYear(hoy.getFullYear() - 2);
  document.getElementById("ina-hasta").value = hoy.toISOString().slice(0, 10);
  document.getElementById("ina-desde").value = hace2.toISOString().slice(0, 10);
  // Auto: buscar estaciones cercanas al campo.
  lluEstacionesCercanas();
}

async function lluEstacionesCercanas() {
  const lista = document.getElementById("ina-lista");
  const umsg  = document.getElementById("ina-ubic-msg");
  lista.innerHTML = '<div class="loading"><span class="spinner"></span> Ubicando el campo…</div>';
  try {
    if (!_inaUbic) {
      const r = await Auth.get("/api/lluvias/ina/ubicacion");
      _inaUbic = r.ubicacion || null;
    }
    if (!_inaUbic || !Number.isFinite(_inaUbic.lat) || !Number.isFinite(_inaUbic.lon)) {
      umsg.textContent = "No se pudo ubicar el campo (no hay lotes con coordenadas). Buscá una estación por nombre.";
      lista.innerHTML = "";
      return;
    }
    umsg.textContent = `Campo ≈ ${_inaUbic.lat.toFixed(4)}, ${_inaUbic.lon.toFixed(4)} (${_inaUbic.lotes || 0} lote${_inaUbic.lotes === 1 ? "" : "s"})`;
    lista.innerHTML = '<div class="loading"><span class="spinner"></span> Buscando estaciones cercanas…</div>';
    const r = await Auth.get(`/api/lluvias/ina/estaciones?lat=${_inaUbic.lat}&lon=${_inaUbic.lon}`);
    lluRenderEstaciones(r.estaciones || []);
  } catch (e) {
    lista.innerHTML = `<div class="alert error show">${lluEscape(e.message)}</div>`;
  }
}

async function lluBuscarINA() {
  const q = document.getElementById("ina-q").value.trim();
  const lista = document.getElementById("ina-lista");
  if (!q) { lluEstacionesCercanas(); return; }
  lista.innerHTML = '<div class="loading"><span class="spinner"></span> Buscando…</div>';
  try {
    const r = await Auth.get(`/api/lluvias/ina/estaciones?q=${encodeURIComponent(q)}`);
    lluRenderEstaciones(r.estaciones || []);
  } catch (e) {
    lista.innerHTML = `<div class="alert error show">${lluEscape(e.message)}</div>`;
  }
}

function lluRenderEstaciones(ests) {
  const lista = document.getElementById("ina-lista");
  if (!ests.length) {
    lista.innerHTML = `<div class="empty-state" style="padding:24px"><span class="icon">🛰</span><p>No se encontraron estaciones.</p></div>`;
    return;
  }
  lista.innerHTML = ests.map(e => {
    const cov = [e.from_date, e.to_date].filter(Boolean).map(d => String(d).slice(0, 10)).join(" → ") || "—";
    const dist = Number.isFinite(e.dist_km) ? `${e.dist_km} km` : "";
    return `
      <div onclick='lluSeleccionarEstacion(${JSON.stringify(e).replace(/'/g, "&#39;")})'
        style="padding:10px 12px;border:1px solid var(--ap-border);border-radius:8px;margin-bottom:8px;cursor:pointer;display:flex;justify-content:space-between;gap:10px;align-items:center"
        onmouseover="this.style.borderColor='var(--ap-green)'" onmouseout="this.style.borderColor='var(--ap-border)'">
        <div style="min-width:0">
          <div style="font-size:13px;font-weight:600">${lluEscape(e.nombre || ("#" + e.sitecode))}</div>
          <div style="font-size:11px;color:var(--ap-muted)">${lluEscape(e.distrito || e.red || "")} · datos ${cov} · ${e.obs_count || 0} obs</div>
        </div>
        <div style="flex-shrink:0;text-align:right">
          ${dist ? `<div style="font-size:12px;color:var(--ap-green);font-weight:600">${dist}</div>` : ""}
          <div style="font-size:11px;color:var(--ap-muted)">Elegir ›</div>
        </div>
      </div>`;
  }).join("");
}

function lluSeleccionarEstacion(e) {
  _inaSel = e;
  document.getElementById("ina-sel-nombre").textContent = e.nombre || ("#" + e.sitecode);
  document.getElementById("ina-import-box").style.display = "block";
  // Ajustar rango a la cobertura de la estación si está disponible.
  if (e.to_date) {
    const to = String(e.to_date).slice(0, 10);
    if (document.getElementById("ina-hasta").value > to) document.getElementById("ina-hasta").value = to;
  }
  document.getElementById("ina-import-msg").textContent = "";
}

async function lluImportarINA() {
  if (!_inaSel) return;
  const desde = document.getElementById("ina-desde").value;
  const hasta = document.getElementById("ina-hasta").value;
  const msg   = document.getElementById("ina-import-msg");
  const btn   = document.getElementById("ina-btn-importar");
  if (!desde || !hasta) { msg.style.color = "var(--ap-red, #e5484d)"; msg.textContent = "Elegí el rango de fechas."; return; }

  btn.disabled = true;
  msg.style.color = "var(--ap-muted)";
  msg.innerHTML = '<span class="spinner"></span> Importando del INA…';
  try {
    const r = await Auth.post("/api/lluvias/ina/importar", { sitecode: _inaSel.sitecode, desde, hasta });
    msg.style.color = "var(--ap-green)";
    msg.textContent = r.importados
      ? `Importados ${r.importados} días con lluvia de ${r.estacion} ✓`
      : `Sin lluvias registradas en el rango para ${r.estacion}.`;
    await lluCargar();
  } catch (e) {
    msg.style.color = "var(--ap-red, #e5484d)";
    msg.textContent = e.message;
  } finally {
    btn.disabled = false;
  }
}

document.addEventListener("DOMContentLoaded", () => {
  document.getElementById("llu-fecha").value = new Date().toISOString().slice(0, 10);
  lluCargar();
});
</script>
