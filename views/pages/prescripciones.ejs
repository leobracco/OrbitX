// ── Panel flotante draggable ─────────────────────────────
function abrirPanelZona() {
  const panel = document.getElementById('panel-zona');
  panel.style.display = 'block';
  // Posicionar sobre el mapa
  const mapa = document.getElementById('mapa-presc');
  const rect = mapa.getBoundingClientRect();
  panel.style.top  = (rect.top + 20) + 'px';
  panel.style.left = (rect.left + rect.width/2 - 190) + 'px';
}

function cerrarPanelZona() {
  document.getElementById('panel-zona').style.display = 'none';
}

// Drag logic
(function() {
  let drag = false, ox = 0, oy = 0;
  document.addEventListener('DOMContentLoaded', () => {
    const handle = document.getElementById('panel-zona-handle');
    const panel  = document.getElementById('panel-zona');
    if (!handle || !panel) return;

    handle.addEventListener('mousedown', e => {
      if (e.target.tagName === 'BUTTON') return;
      drag = true;
      ox = e.clientX - panel.offsetLeft;
      oy = e.clientY - panel.offsetTop;
      handle.style.cursor = 'grabbing';
      e.preventDefault();
    });
    document.addEventListener('mousemove', e => {
      if (!drag) return;
      panel.style.left = Math.max(0, e.clientX - ox) + 'px';
      panel.style.top  = Math.max(0, e.clientY - oy) + 'px';
    });
    document.addEventListener('mouseup', () => {
      drag = false;
      if (handle) handle.style.cursor = 'grab';
    });
  });
})();

// ── Nueva prescripción (limpia todo, mantiene posición del mapa) ──
function nuevaPrescripcion() {
  if (zonas.length && !confirm('¿Comenzar una prescripción nueva?\nLos cambios sin guardar se perderán.')) return;
  // Guardar centro y zoom del mapa actual
  const centro = mapaL ? mapaL.getCenter() : null;
  const zoom   = mapaL ? mapaL.getZoom()   : null;
  // Limpiar estado
  drawnItems.clearLayers();
  zonas = [];
  undoStack = [];
  _prescId = null;
  zonaSeleccionada = null;
  renderListaZonas();
  document.getElementById('btn-guardar').disabled  = true;
  document.getElementById('btn-exportar').disabled = true;
  actualizarBadge();
  // Restaurar posición del mapa
  if (centro && zoom) setTimeout(() => mapaL.setView(centro, zoom), 50);
  toast('✓ Nueva prescripción', 'El mapa quedó en la misma posición', 'lime');
}

function actualizarBadge() {
  const badge  = document.getElementById('badge-presc');
  const btnNueva = document.getElementById('btn-nueva');
  if (_prescId !== null) {
    const lista  = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
    const actual = lista.find(p => p.id === _prescId);
    if (actual) {
      badge.textContent = actual.nombre;
      badge.style.display = 'inline-flex';
      btnNueva.style.display = 'inline-flex';
      return;
    }
  }
  badge.style.display  = 'none';
  btnNueva.style.display = 'none';
}

// ── Vista general: todas las prescripciones superpuestas ──
let _vistaLayers = [];

function cambiarFiltroVista(filtro) {
  ['semilla','ferti_linea','ferti_costado'].forEach(f => {
    document.getElementById(`vbtn-${f}`)?.classList.toggle('active', f===filtro);
  });
  const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
  renderVistaGeneral(lista, filtro);
}

function abrirVistaGeneral() {
  const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
  if (!lista.length) return toast('Sin prescripciones', 'Guardá al menos una primero', 'amber');
  renderVistaGeneral(lista);
  openModal('modal-vista');
}

function renderVistaGeneral(lista, filtro = 'semilla') {
  const mapEl = document.getElementById('mapa-vista');
  if (!mapEl) return;

  // Init mapa vista si no existe
  if (!window._mapaVista) {
    window._mapaVista = L.map('mapa-vista').setView([-34.6,-60.0],13);
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
      {attribution:'Esri',maxZoom:21}).addTo(window._mapaVista);
    L.tileLayer('https://services.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}',
      {maxZoom:21,opacity:0.5}).addTo(window._mapaVista);
  }

  // Limpiar capas anteriores
  _vistaLayers.forEach(l => window._mapaVista.removeLayer(l));
  _vistaLayers = [];

  const bounds = [];
  const resumen = document.getElementById('vista-resumen');
  let html = '';

  lista.forEach((presc, pi) => {
    const color = PALETA[pi % PALETA.length];
    const vals  = presc.data.map(z => parseFloat(z[filtro])||0);
    const minV  = Math.min(...vals);
    const maxV  = Math.max(...vals);

    presc.data.forEach((zona, zi) => {
      try {
        const geom  = zona.geojson?.geometry || zona.geojson;
        const valor = parseFloat(zona[filtro]) || 0;
        const t     = maxV > minV ? (valor-minV)/(maxV-minV) : 0.5;
        const fill  = lerpColor('#3B82F6','#EF4444', t);

        const layer = L.geoJSON(geom, {
          style:{ color, weight:2, opacity:0.9, fillColor:fill, fillOpacity:0.55 }
        });

        const unit = UNIT_LBL[presc.units?.[filtro] || (filtro==='semilla'?'sem_m':'kg_ha')];
        layer.bindTooltip(`
          <div style="font-size:11px">
            <b style="color:${color}">${presc.nombre}</b><br>
            Zona: <b>${zona.nombre}</b><br>
            🌱 ${zona.semilla||0} ${UNIT_LBL[presc.units?.semilla||'sem_m']}<br>
            🧪 ${zona.ferti_linea||0} ${UNIT_LBL[presc.units?.ferti_linea||'kg_ha']}<br>
            🌿 ${zona.ferti_costado||0} ${UNIT_LBL[presc.units?.ferti_costado||'kg_ha']}
          </div>
        `, {sticky:true});

        layer.on('click', () => {
          // Cargar esa prescripción para editar
          if (confirm(`¿Cargar "${presc.nombre}" para editar?`)) {
            const idx = lista.findIndex(p=>p.id===presc.id);
            cargarGuardada(idx);
            closeModal('modal-vista');
          }
        });

        layer.addTo(window._mapaVista);
        _vistaLayers.push(layer);

        layer.getLayers?.()?.forEach(l => {
          if (l.getBounds) l.getBounds().getNorthEast && bounds.push(...Object.values(l.getBounds()));
        });
        // collect bounds manually
        if (geom?.coordinates) {
          const flat = geom.coordinates.flat(3);
          for(let i=0;i<flat.length;i+=2) bounds.push([flat[i+1],flat[i]]);
        }
      } catch {}
    });

    const avg = v => presc.data.length
      ? (presc.data.reduce((s,z)=>s+(parseFloat(z[v])||0),0)/presc.data.length).toFixed(1)
      : '–';

    html += `
      <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border);cursor:pointer"
           onclick="cargarGuardada(${lista.indexOf(presc)});closeModal('modal-vista')">
        <span style="width:10px;height:10px;border-radius:3px;background:${color};flex-shrink:0"></span>
        <div style="flex:1;min-width:0">
          <div style="font-size:12px;font-weight:500;color:#fff">${presc.nombre}</div>
          <div style="font-size:10px;color:var(--muted2)">
            ${presc.fecha} · ${presc.zonas} zona${presc.zonas!==1?'s':''} ·
            🌱 ${avg('semilla')} · 🧪 ${avg('ferti_linea')} · 🌿 ${avg('ferti_costado')}
          </div>
        </div>
        <span style="font-size:10px;color:var(--lime)">Editar →</span>
      </div>`;
  });

  resumen.innerHTML = html || '<div style="padding:16px;color:var(--muted2);font-size:12px">Sin prescripciones</div>';

  if (bounds.length) {
    try { window._mapaVista.fitBounds(bounds, {padding:[20,20]}); } catch {}
  }

  setTimeout(() => window._mapaVista.invalidateSize(), 200);
}

// ── Init ──────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => { initMapa(); });
</script>
