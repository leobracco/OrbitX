<%# pages/prescripciones.ejs — Editor de prescripciones con dibujo de zonas %>

<div class="page-header" style="flex-wrap:wrap;gap:10px">
  <div>
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
      <h2 style="margin:0">Prescripciones</h2>
      <span id="badge-presc" style="display:none;font-size:11px;padding:2px 10px;background:var(--lime-dim);color:var(--lime);border:1px solid rgba(184,255,60,0.25);border-radius:20px;font-family:var(--font-m)"></span>
    </div>
    <p style="margin:0">Dibujá zonas · Asigná dosis · Exportá</p>
  </div>
  <div style="display:flex;gap:6px;flex-wrap:wrap">
    <button class="btn btn-ghost" id="btn-nueva" onclick="nuevaPrescripcion()" style="display:none">+ Nueva</button>
    <button class="btn btn-ghost" onclick="abrirGuardar()" id="btn-guardar" disabled>💾 Guardar</button>
    <button class="btn btn-ghost" onclick="abrirExportar()" id="btn-exportar" disabled>↓ Exportar</button>
    <button class="btn btn-ghost" onclick="abrirGuardadas()">📋 Guardadas</button>
    <button class="btn btn-ghost" onclick="abrirVistaGeneral()" title="Ver todas las prescripciones en el mapa">🗺 Ver todas</button>
  </div>
</div>

<!-- Layout principal: mapa + panel -->
<div class="presc-layout">

  <!-- ══ MAPA ══ -->
  <div class="presc-mapa-wrap" style="position:relative;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border)">
    <div id="mapa-presc" style="height:100%;width:100%;background:var(--surface2)"></div>

    <!-- Toolbar de herramientas (flotante sobre el mapa) -->
    <div style="position:absolute;top:12px;left:50%;transform:translateX(-50%);z-index:1000;display:flex;gap:4px;background:rgba(0,0,0,0.8);border-radius:10px;padding:5px">
      <button id="tool-pan"      class="tool-btn active" onclick="setTool('pan')"      title="Mover mapa">✋</button>
      <div style="width:1px;background:rgba(255,255,255,0.15);margin:4px 2px"></div>
      <button id="tool-polygon"  class="tool-btn"        onclick="setTool('polygon')" title="Dibujar polígono">⬡</button>
      <button id="tool-rect"     class="tool-btn"        onclick="setTool('rect')"    title="Dibujar rectángulo">⬜</button>
      <div style="width:1px;background:rgba(255,255,255,0.15);margin:4px 2px"></div>
      <button id="tool-edit"     class="tool-btn"        onclick="setTool('edit')"    title="Editar zona">✏</button>
      <button id="tool-delete"   class="tool-btn"        onclick="setTool('delete')"  title="Borrar zona">🗑</button>
      <div style="width:1px;background:rgba(255,255,255,0.15);margin:4px 2px"></div>
      <button id="tool-undo"     class="tool-btn"        onclick="deshacer()"         title="Deshacer">↩</button>
    </div>

    <!-- Instrucción contextual -->
    <div id="tool-hint" style="position:absolute;bottom:12px;left:50%;transform:translateX(-50%);z-index:1000;background:rgba(0,0,0,0.75);color:#fff;font-size:11px;padding:5px 12px;border-radius:6px;pointer-events:none;white-space:nowrap">
      Herramienta: Mover mapa
    </div>

    <!-- Leyenda -->
    <div id="leyenda" style="display:none;position:absolute;bottom:44px;left:12px;background:rgba(0,0,0,0.8);border-radius:8px;padding:10px 14px;z-index:1000;font-size:11px;min-width:130px"></div>
  </div>

  <!-- ══ PANEL DERECHO ══ -->
  <div class="presc-panel">

    <!-- Unidades -->
    <div class="card">
      <div class="card-head"><span class="card-title">Unidades</span></div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:8px">
        <div class="field">
          <label>🌱 Semilla</label>
          <select id="unit-semilla" onchange="repintarMapa()">
            <option value="sem_m">sem / metro</option>
            <option value="sem_ha">sem / hectárea</option>
            <option value="sem_10m">sem / 10 metros</option>
            <option value="kg_ha">kg / hectárea</option>
          </select>
        </div>
        <div class="field">
          <label>🧪 Ferti en línea</label>
          <select id="unit-ferti_linea" onchange="repintarMapa()">
            <option value="kg_ha">kg / hectárea</option>
            <option value="l_ha">litros / hectárea</option>
            <option value="g_m">g / metro</option>
          </select>
        </div>
        <div class="field">
          <label>🌿 Ferti costado</label>
          <select id="unit-ferti_costado" onchange="repintarMapa()">
            <option value="kg_ha">kg / hectárea</option>
            <option value="l_ha">litros / hectárea</option>
            <option value="g_m">g / metro</option>
          </select>
        </div>
        <div class="field">
          <label>Color del mapa</label>
          <select id="sel-vista" onchange="repintarMapa()">
            <option value="semilla">Semilla</option>
            <option value="ferti_linea">Ferti en línea</option>
            <option value="ferti_costado">Ferti costado</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Lista de zonas -->
    <div class="card" style="flex:1;min-height:0;display:flex;flex-direction:column">
      <div class="card-head">
        <span class="card-title">Zonas</span>
        <span id="zonas-count" style="font-size:11px;color:var(--muted2)">0 zonas</span>
      </div>
      <div id="lista-zonas" style="overflow-y:auto;flex:1">
        <div style="padding:20px;text-align:center;color:var(--muted2);font-size:12px">
          Dibujá zonas en el mapa con ⬡ o ⬜
        </div>
      </div>
      <div style="padding:8px;border-top:1px solid var(--border)">
        <button class="btn btn-ghost" style="width:100%;font-size:11px" onclick="aplicarDosisGlobal()">Dosis uniforme a todas</button>
      </div>
    </div>

  </div>
</div>

<!-- ══ PANEL FLOTANTE ZONA (draggable, sobre el mapa) ══ -->
<div id="panel-zona" style="
  display:none;
  position:fixed;
  top:200px;left:calc(50% - 200px);
  width:380px;
  background:#0f1729;
  border:1px solid var(--border2);
  border-radius:12px;
  box-shadow:0 8px 40px rgba(0,0,0,0.8);
  z-index:20000;
  user-select:none;
">
  <!-- Handle de arrastre -->
  <div id="panel-zona-handle" style="
    display:flex;align-items:center;justify-content:space-between;
    padding:10px 14px;
    background:var(--surface2);
    border-bottom:1px solid var(--border);
    border-radius:12px 12px 0 0;
    cursor:grab;
  ">
    <div style="display:flex;align-items:center;gap:8px">
      <span style="font-size:13px;color:var(--muted2)">⋮⋮</span>
      <span style="font-family:var(--font-h);font-size:13px;color:#fff" id="panel-zona-title">Zona 1</span>
    </div>
    <button onclick="cerrarPanelZona()" style="background:none;border:none;color:var(--muted2);cursor:pointer;font-size:16px;line-height:1;padding:2px 4px">✕</button>
  </div>
  <input type="hidden" id="zona-idx"/>
  <div style="padding:14px;display:flex;flex-direction:column;gap:10px">
    <div class="field">
      <label>Nombre</label>
      <input type="text" id="zona-nombre" placeholder="Ej: Zona alta, Zona baja..."
        style="background:var(--surface2);border:1px solid var(--border2);color:var(--text);padding:8px 12px;border-radius:8px;width:100%;font-family:var(--font-b);font-size:13px;outline:none"/>
    </div>
    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px;display:flex;flex-direction:column;gap:10px">
      <div style="font-size:10px;color:var(--muted2);text-transform:uppercase;letter-spacing:1px">Dosis</div>
      <div style="display:grid;grid-template-columns:24px 1fr 70px;gap:8px;align-items:center">
        <span style="font-size:15px;text-align:center">🌱</span>
        <input type="number" step="0.1" min="0" id="zona-semilla" placeholder="0"
          style="background:#0a1020;border:1px solid var(--border2);color:var(--text);padding:7px 10px;border-radius:7px;font-family:var(--font-m);font-size:13px;outline:none;width:100%"/>
        <span id="lbl-unit-sem" style="font-size:11px;color:var(--lime);font-family:var(--font-m)">sem/m</span>
      </div>
      <div style="display:grid;grid-template-columns:24px 1fr 70px;gap:8px;align-items:center">
        <span style="font-size:15px;text-align:center">🧪</span>
        <input type="number" step="0.5" min="0" id="zona-ferti_linea" placeholder="0"
          style="background:#0a1020;border:1px solid var(--border2);color:var(--text);padding:7px 10px;border-radius:7px;font-family:var(--font-m);font-size:13px;outline:none;width:100%"/>
        <span id="lbl-unit-fl" style="font-size:11px;color:var(--lime);font-family:var(--font-m)">kg/ha</span>
      </div>
      <div style="display:grid;grid-template-columns:24px 1fr 70px;gap:8px;align-items:center">
        <span style="font-size:15px;text-align:center">🌿</span>
        <input type="number" step="0.5" min="0" id="zona-ferti_costado" placeholder="0"
          style="background:#0a1020;border:1px solid var(--border2);color:var(--text);padding:7px 10px;border-radius:7px;font-family:var(--font-m);font-size:13px;outline:none;width:100%"/>
        <span id="lbl-unit-fc" style="font-size:11px;color:var(--lime);font-family:var(--font-m)">kg/ha</span>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:2px">
      <button class="btn btn-ghost" style="flex:1" onclick="cerrarPanelZona()">Cancelar</button>
      <button class="btn btn-primary" style="flex:1" onclick="guardarZona()">✓ Guardar</button>
    </div>
  </div>
</div>

<!-- ══ MODAL GUARDAR ══ -->
<div class="modal-backdrop" id="modal-guardar" style="z-index:25000">
  <div class="modal" style="background:var(--surface);border:1px solid var(--border2)">
    <div class="modal-title">Guardar prescripción</div>
    <div class="field" style="margin:16px 0">
      <label>Nombre</label>
      <input type="text" id="presc-nombre" placeholder="Ej: Lote Norte — Soja 25/26"
        onkeydown="if(event.key==='Enter') confirmarGuardar()"/>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-ghost" style="flex:1" onclick="closeModal('modal-guardar')">Cancelar</button>
      <button class="btn btn-primary" style="flex:1" onclick="confirmarGuardar()">Guardar</button>
    </div>
  </div>
</div>

<!-- ══ MODAL EXPORTAR ══ -->
<div class="modal-backdrop" id="modal-exportar" style="z-index:25000">
  <div class="modal" style="background:var(--surface);border:1px solid var(--border2)">
    <div class="modal-title">Exportar prescripción</div>
    <div style="display:flex;flex-direction:column;gap:8px;margin:16px 0">
      <button class="btn btn-ghost" style="text-align:left;padding:12px 14px" onclick="exportarJSON()">
        <div style="font-weight:500;color:#fff">📄 JSON — QuantiX</div>
        <div style="font-size:11px;color:var(--muted2);margin-top:2px">Formato nativo para QuantiX</div>
      </button>
      <button class="btn btn-ghost" style="text-align:left;padding:12px 14px" onclick="exportarCSV()">
        <div style="font-weight:500;color:#fff">📊 CSV — Planilla / ISOBUS</div>
        <div style="font-size:11px;color:var(--muted2);margin-top:2px">Compatible con Excel y terminales ISOBUS</div>
      </button>
      <button class="btn btn-ghost" style="text-align:left;padding:12px 14px" onclick="exportarSHP()">
        <div style="font-weight:500;color:#fff">📦 Shapefile — QuantiX (.shp + .dbf + .shx)</div>
        <div style="font-size:11px;color:var(--muted2);margin-top:2px">Formato exacto compatible con QuantiX</div>
      </button>
      <button class="btn btn-ghost" style="text-align:left;padding:12px 14px" onclick="exportarGeoJSON()">
        <div style="font-weight:500;color:#fff">🗺 GeoJSON — QGIS</div>
        <div style="font-size:11px;color:var(--muted2);margin-top:2px">Para editar en QGIS o convertir a otro formato</div>
      </button>
    </div>
    <button class="btn btn-ghost" style="width:100%" onclick="closeModal('modal-exportar')">Cerrar</button>
  </div>
</div>

<!-- ══ MODAL VISTA GENERAL ══ -->
<div class="modal-backdrop" id="modal-vista" style="z-index:25000">
  <div class="modal" style="width:min(900px,96vw);max-height:90vh;display:flex;flex-direction:column;padding:0;background:#0f1729;border:1px solid var(--border2)">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border);flex-shrink:0">
      <div>
        <div style="font-family:var(--font-h);font-size:16px;color:#fff">Vista general</div>
        <div style="font-size:11px;color:var(--muted2);margin-top:2px">Todas las prescripciones guardadas en el mapa</div>
      </div>
      <div style="display:flex;align-items:center;gap:10px">
        <div style="display:flex;gap:4px;background:var(--surface2);border-radius:8px;padding:3px">
          <button class="tool-btn active" id="vbtn-semilla"      onclick="cambiarFiltroVista('semilla')"      style="font-size:12px;padding:4px 10px">🌱 Semilla</button>
          <button class="tool-btn"        id="vbtn-ferti_linea"  onclick="cambiarFiltroVista('ferti_linea')"  style="font-size:12px;padding:4px 10px">🧪 Ferti L</button>
          <button class="tool-btn"        id="vbtn-ferti_costado" onclick="cambiarFiltroVista('ferti_costado')" style="font-size:12px;padding:4px 10px">🌿 Ferti C</button>
        </div>
        <button onclick="closeModal('modal-vista')" style="background:none;border:none;color:var(--muted2);cursor:pointer;font-size:18px">✕</button>
      </div>
    </div>

    <!-- Contenido: mapa + lista -->
    <div style="display:grid;grid-template-columns:1fr 280px;flex:1;min-height:0;overflow:hidden">

      <!-- Mapa -->
      <div id="mapa-vista" style="height:500px;width:100%"></div>

      <!-- Lista prescripciones -->
      <div style="display:flex;flex-direction:column;border-left:1px solid var(--border);overflow:hidden">
        <div style="padding:10px 14px;font-size:10px;color:var(--muted2);text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(--border);flex-shrink:0">
          Clic en una para editar
        </div>
        <div id="vista-resumen" style="overflow-y:auto;flex:1"></div>
      </div>
    </div>

    <!-- Leyenda gradiente -->
    <div style="padding:10px 20px;border-top:1px solid var(--border);display:flex;align-items:center;gap:16px;flex-shrink:0;flex-wrap:wrap">
      <span style="font-size:11px;color:var(--muted2)">Dosis:</span>
      <div style="display:flex;align-items:center;gap:6px">
        <span style="font-size:11px;color:var(--muted2)">Baja</span>
        <div style="width:120px;height:10px;border-radius:4px;background:linear-gradient(to right,#3B82F6,#10B981,#EAB308,#EF4444)"></div>
        <span style="font-size:11px;color:var(--muted2)">Alta</span>
      </div>
      <span style="font-size:11px;color:var(--muted2)">· Borde = prescripción distinta</span>
    </div>
  </div>
</div>

<!-- ══ MODAL GUARDADAS ══ -->
<div class="modal-backdrop" id="modal-guardadas" style="z-index:25000">
  <div class="modal" style="width:540px;max-height:80vh;display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--border2)">
    <div class="modal-title">Prescripciones guardadas</div>
    <div id="lista-guardadas" style="overflow-y:auto;flex:1;margin-top:14px"></div>
    <button class="btn btn-ghost" style="width:100%;margin-top:12px;flex-shrink:0" onclick="closeModal('modal-guardadas')">Cerrar</button>
  </div>
</div>

<!-- Leaflet + Leaflet.draw -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>

<style>
.tool-btn{background:none;border:none;color:#ccc;font-size:16px;cursor:pointer;padding:4px 8px;border-radius:6px;transition:all 0.15s;line-height:1}
.tool-btn:hover{background:rgba(255,255,255,0.1);color:#fff}
.tool-btn.active{background:rgba(184,255,60,0.2);color:#b8ff3c}
.zona-card{padding:10px 12px;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s}
.zona-card:hover{background:rgba(255,255,255,0.03)}
.zona-card.selected{background:rgba(184,255,60,0.06);border-left:3px solid var(--lime)}

/* ── Layout responsive ── */
.presc-layout{
  display:grid;
  grid-template-columns:1fr 300px;
  gap:16px;
  height:calc(72vh - 180px);
  min-height:400px;
}
.presc-mapa-wrap{ position:relative; }
.presc-panel{ display:flex;flex-direction:column;gap:12px;overflow-y:auto; }

@media(max-width:768px){
  .presc-layout{
    display:flex;
    flex-direction:column;
    height:auto;
    min-height:unset;
  }
  .presc-mapa-wrap{
    height:55vw;
    min-height:260px;
    max-height:380px;
  }
  .presc-panel{
    overflow-y:visible;
    max-height:none;
  }
  /* Toolbar más compacto en móvil */
  #tool-hint{ display:none!important; }
  .tool-btn{ font-size:14px;padding:4px 6px; }
  /* Cards más compactas */
  .card-body{ padding:10px!important; }
  /* Botones header en fila */
  .page-header>div:last-child{ flex-wrap:wrap; }
}
@media(max-width:480px){
  .presc-mapa-wrap{ height:65vw;min-height:220px; }
}
@media(max-width:640px){
  #mapa-vista{ height:260px!important; }
  #modal-vista .modal > div:nth-child(2){
    grid-template-columns:1fr!important;
  }
  #vista-resumen-wrap{ display:none; }
}
</style>

<script>
// ── Estado ────────────────────────────────────────────────
let mapaL = null;
let drawnItems = null;    // FeatureGroup con todas las zonas dibujadas
let drawControl = null;
let activeDraw  = null;   // instancia activa de Leaflet.Draw
let currentTool = 'pan';
let zonas = [];           // [{id, nombre, semilla, ferti_linea, ferti_costado, layer}]
let undoStack = [];
let zonaSeleccionada = null;

const PALETA = ['#3B82F6','#10B981','#F59E0B','#EF4444','#8B5CF6','#06B6D4','#84CC16','#F97316',
                '#EC4899','#14B8A6','#A78BFA','#FB923C','#34D399','#60A5FA','#FCD34D'];

const UNIT_LBL = { sem_m:'sem/m', sem_ha:'sem/ha', sem_10m:'sem/10m', kg_ha:'kg/ha', l_ha:'l/ha', g_m:'g/m' };

// ── Init mapa ─────────────────────────────────────────────
function initMapa() {
  if (mapaL) return;
  mapaL = L.map('mapa-presc', { zoomControl:true }).setView([-34.6,-60.0], 13);

  L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
    { attribution:'Esri', maxZoom:21 }).addTo(mapaL);
  L.tileLayer('https://services.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}',
    { maxZoom:21, opacity:0.55 }).addTo(mapaL);

  drawnItems = new L.FeatureGroup().addTo(mapaL);

  // Cuando se completa un dibujo
  mapaL.on(L.Draw.Event.CREATED, e => {
    // Si no hay prescripción cargada actualmente, es trabajo nuevo — no pisar ninguna
    undoStack.push(JSON.parse(JSON.stringify(zonasSnapshot())));
    const layer = e.layer;
    const idx   = zonas.length;
    const zona  = {
      id:            Date.now() + idx,
      nombre:        `Zona ${idx+1}`,
      semilla:       0,
      ferti_linea:   0,
      ferti_costado: 0,
      layer,
    };
    zonas.push(zona);
    drawnItems.addLayer(layer);
    estilizarLayer(layer, zona, idx);
    layer.on('click', () => abrirEditarZona(idx));
    renderListaZonas();
    repintarMapa();
    setTool('pan');
    // Abrir editor inmediatamente
    abrirEditarZona(idx);
  });
}

// ── Herramientas ──────────────────────────────────────────
const HINTS = {
  pan:    'Herramienta: Mover mapa',
  polygon:'Clic para agregar puntos · Doble clic para cerrar la zona',
  rect:   'Clic y arrastre para dibujar el rectángulo',
  edit:   'Clic en una zona para moverla o editar sus vértices',
  delete: 'Clic en una zona para borrarla',
};

function setTool(tool) {
  // Cancelar dibujo anterior
  if (activeDraw) { activeDraw.disable(); activeDraw = null; }

  currentTool = tool;
  document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(`tool-${tool}`)?.classList.add('active');
  document.getElementById('tool-hint').textContent = HINTS[tool] || '';

  if (tool === 'polygon') {
    activeDraw = new L.Draw.Polygon(mapaL, {
      shapeOptions:{ color:PALETA[zonas.length%PALETA.length], weight:2, fillOpacity:0.35 }
    });
    activeDraw.enable();
  } else if (tool === 'rect') {
    activeDraw = new L.Draw.Rectangle(mapaL, {
      shapeOptions:{ color:PALETA[zonas.length%PALETA.length], weight:2, fillOpacity:0.35 }
    });
    activeDraw.enable();
  } else if (tool === 'edit') {
    drawnItems.getLayers().forEach(l => l.editing?.enable());
  } else if (tool === 'delete') {
    mapaL.on('click.delete', e => {
      drawnItems.getLayers().forEach(l => {
        if (l.getBounds ? l.getBounds().contains(e.latlng) : false) borrarZonaByLayer(l);
      });
    });
  }

  if (tool !== 'edit') drawnItems.getLayers().forEach(l => l.editing?.disable());
  if (tool !== 'delete') mapaL.off('click.delete');
}

// ── Editar zona ───────────────────────────────────────────
function abrirEditarZona(idx) {
  zonaSeleccionada = idx;
  const z = zonas[idx];
  if (!z) return;

  document.getElementById('zona-idx').value     = idx;
  document.getElementById('zona-nombre').value  = z.nombre;
  document.getElementById('zona-semilla').value = z.semilla;
  document.getElementById('zona-ferti_linea').value  = z.ferti_linea;
  document.getElementById('zona-ferti_costado').value = z.ferti_costado;

  // Actualizar labels de unidad
  document.getElementById('lbl-unit-sem').textContent = UNIT_LBL[getUnit('semilla')];
  document.getElementById('lbl-unit-fl').textContent  = UNIT_LBL[getUnit('ferti_linea')];
  document.getElementById('lbl-unit-fc').textContent  = UNIT_LBL[getUnit('ferti_costado')];

  abrirPanelZona();
  setTimeout(() => document.getElementById('zona-nombre').focus(), 100);
}

function guardarZona() {
  const idx = parseInt(document.getElementById('zona-idx').value);
  if (isNaN(idx) || !zonas[idx]) return;
  zonas[idx].nombre        = document.getElementById('zona-nombre').value.trim() || `Zona ${idx+1}`;
  zonas[idx].semilla       = parseFloat(document.getElementById('zona-semilla').value)       || 0;
  zonas[idx].ferti_linea   = parseFloat(document.getElementById('zona-ferti_linea').value)   || 0;
  zonas[idx].ferti_costado = parseFloat(document.getElementById('zona-ferti_costado').value) || 0;
  cerrarPanelZona();
  renderListaZonas();
  repintarMapa();
  document.getElementById('btn-guardar').disabled  = false;
  document.getElementById('btn-exportar').disabled = false;
}

// ── Borrar zona ───────────────────────────────────────────
function borrarZona(idx) {
  if (!confirm(`¿Borrar "${zonas[idx]?.nombre}"?`)) return;
  undoStack.push(zonasSnapshot());
  drawnItems.removeLayer(zonas[idx].layer);
  zonas.splice(idx,1);
  renderListaZonas();
  repintarMapa();
}

function borrarZonaByLayer(layer) {
  const idx = zonas.findIndex(z => z.layer === layer);
  if (idx >= 0) {
    undoStack.push(zonasSnapshot());
    drawnItems.removeLayer(layer);
    zonas.splice(idx,1);
    renderListaZonas();
    repintarMapa();
  }
}

// ── Deshacer ──────────────────────────────────────────────
function deshacer() {
  if (!undoStack.length) return;
  // Restaurar último snapshot no implementado completamente en esta versión
  toast('Deshacer', 'Borrá la última zona manualmente con 🗑', 'amber');
}

function zonasSnapshot() {
  return zonas.map(z => ({ ...z, layer:null }));
}

// ── Estilos ───────────────────────────────────────────────
function estilizarLayer(layer, zona, idx, valor, min, max) {
  let fillColor = PALETA[idx % PALETA.length];
  if (valor !== undefined && max > min) {
    const t = (valor - min) / (max - min);
    fillColor = lerpColor('#3B82F6','#EF4444', t);
  }
  layer.setStyle({ color:fillColor, weight:2, opacity:0.9, fillColor, fillOpacity:0.5 });
}

function repintarMapa() {
  if (!zonas.length) return;
  const prod = document.getElementById('sel-vista')?.value || 'semilla';
  const vals = zonas.map(z => parseFloat(z[prod])||0);
  const min  = Math.min(...vals);
  const max  = Math.max(...vals);
  zonas.forEach((z,i) => estilizarLayer(z.layer, z, i, parseFloat(z[prod])||0, min, max));
  renderLeyenda(prod, min, max);
}

function lerpColor(a, b, t) {
  const r = s => [parseInt(s.slice(1,3),16), parseInt(s.slice(3,5),16), parseInt(s.slice(5,7),16)];
  const [ar,ag,ab] = r(a), [br,bg,bb] = r(b);
  const v = x => Math.round(x).toString(16).padStart(2,'0');
  return `#${v(ar+t*(br-ar))}${v(ag+t*(bg-ag))}${v(ab+t*(bb-ab))}`;
}

function renderLeyenda(prod, min, max) {
  const el = document.getElementById('leyenda');
  const lbl = {semilla:'Semilla',ferti_linea:'Ferti línea',ferti_costado:'Ferti costado'}[prod];
  const unit = UNIT_LBL[getUnit(prod)];
  if (min === max) { el.style.display='none'; return; }
  el.style.display = '';
  let html = `<div style="color:#fff;font-size:11px;font-weight:500;margin-bottom:6px">${lbl}</div>`;
  for (let i=4;i>=0;i--) {
    const v = min + (max-min)*(i/4);
    html += `<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px">
      <span style="width:16px;height:9px;background:${lerpColor('#3B82F6','#EF4444',i/4)};border-radius:2px;display:inline-block"></span>
      <span style="color:#ccc;font-size:10px">${v.toFixed(1)} ${unit}</span>
    </div>`;
  }
  el.innerHTML = html;
}

function getUnit(prod) {
  return document.getElementById(`unit-${prod}`)?.value || (prod==='semilla'?'sem_m':'kg_ha');
}

// ── Lista de zonas ────────────────────────────────────────
function renderListaZonas() {
  const div = document.getElementById('lista-zonas');
  document.getElementById('zonas-count').textContent = `${zonas.length} zona${zonas.length!==1?'s':''}`;

  if (!zonas.length) {
    div.innerHTML='<div style="padding:20px;text-align:center;color:var(--muted2);font-size:12px">Dibujá zonas en el mapa con ⬡ o ⬜</div>';
    return;
  }

  div.innerHTML = zonas.map((z,i) => `
    <div class="zona-card ${zonaSeleccionada===i?'selected':''}" onclick="zoomZona(${i})">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="width:10px;height:10px;border-radius:3px;background:${PALETA[i%PALETA.length]};flex-shrink:0"></span>
        <span style="font-size:12px;font-weight:500;color:#fff;flex:1">${z.nombre}</span>
        <button class="btn btn-sm btn-ghost" style="padding:2px 6px;font-size:11px" onclick="event.stopPropagation();abrirEditarZona(${i})">✏</button>
        <button class="btn btn-sm btn-ghost" style="padding:2px 6px;font-size:11px;color:var(--red)" onclick="event.stopPropagation();borrarZona(${i})">✕</button>
      </div>
      <div style="font-size:10px;color:var(--muted2);margin-top:4px;padding-left:18px;line-height:1.8">
        🌱 ${z.semilla} ${UNIT_LBL[getUnit('semilla')]}
        · 🧪 ${z.ferti_linea} ${UNIT_LBL[getUnit('ferti_linea')]}
        · 🌿 ${z.ferti_costado} ${UNIT_LBL[getUnit('ferti_costado')]}
      </div>
    </div>`).join('');
}

function zoomZona(idx) {
  zonaSeleccionada = idx;
  const layer = zonas[idx]?.layer;
  if (layer?.getBounds) mapaL.fitBounds(layer.getBounds(), { padding:[40,40], maxZoom:18 });
  renderListaZonas();
}

// ── Dosis uniforme ────────────────────────────────────────
function aplicarDosisGlobal() {
  if (!zonas.length) return;
  const prod = document.getElementById('sel-vista')?.value || 'semilla';
  const unit = UNIT_LBL[getUnit(prod)];
  const lbl  = {semilla:'Semilla',ferti_linea:'Ferti en línea',ferti_costado:'Ferti costado'}[prod];
  const val  = parseFloat(prompt(`Dosis uniforme de ${lbl} (${unit}) para todas las zonas:`)||'');
  if (isNaN(val) || val < 0) return;
  zonas.forEach(z => z[prod] = val);
  renderListaZonas();
  repintarMapa();
  toast(`✓ Dosis aplicada`, `${val} ${unit} en ${zonas.length} zonas`, 'lime');
}

// ── Guardar ───────────────────────────────────────────────
function abrirGuardar() {
  if (!zonas.length) return toast('Sin zonas', 'Dibujá al menos una zona', 'amber');
  // Si hay una prescripción cargada, pre-llenar con su nombre
  if (_prescId !== null) {
    const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
    const actual = lista.find(p => p.id === _prescId);
    document.getElementById('presc-nombre').value = actual?.nombre || '';
  } else {
    document.getElementById('presc-nombre').value = '';
  }
  openModal('modal-guardar');
  setTimeout(() => {
    const inp = document.getElementById('presc-nombre');
    inp.focus();
    inp.select();
  }, 100);
}

function confirmarGuardar() {
  const nombre = document.getElementById('presc-nombre').value.trim();
  if (!nombre) return;
  const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');

  const data = zonas.map(z => ({
    nombre:        z.nombre,
    semilla:       z.semilla,
    ferti_linea:   z.ferti_linea,
    ferti_costado: z.ferti_costado,
    geojson:       z.layer.toGeoJSON(),
  }));

  const units = {
    semilla:       getUnit('semilla'),
    ferti_linea:   getUnit('ferti_linea'),
    ferti_costado: getUnit('ferti_costado'),
  };

  const idx = _prescId !== null ? lista.findIndex(p => p.id === _prescId) : -1;

  if (idx >= 0) {
    // Actualizar existente
    lista[idx] = { ...lista[idx], nombre, fecha: new Date().toLocaleDateString('es-AR'),
                   zonas: zonas.length, units, data };
    toast('✓ Actualizada', nombre, 'lime');
  } else {
    // Nueva prescripción
    const newId = Date.now();
    lista.unshift({ id: newId, nombre, fecha: new Date().toLocaleDateString('es-AR'),
                    zonas: zonas.length, units, data });
    _prescId = newId;
    toast('✓ Guardada', nombre, 'lime');
  }

  localStorage.setItem('orbitx_presc', JSON.stringify(lista.slice(0,30)));
  actualizarBadge();
  closeModal('modal-guardar');
}

// ── Cargar guardada ───────────────────────────────────────
function abrirGuardadas() {
  renderGuardadas();
  openModal('modal-guardadas');
}

function renderGuardadas() {
  const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
  const div   = document.getElementById('lista-guardadas');
  if (!lista.length) {
    div.innerHTML='<div class="empty-state" style="padding:30px"><span class="icon">📋</span><p>Sin prescripciones guardadas</p></div>';
    return;
  }
  div.innerHTML = lista.map((p,i) => `
    <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border)">
      <div style="flex:1">
        <div class="td-main">${p.nombre}</div>
        <div class="td-dim">${p.fecha} · ${p.zonas} zonas</div>
      </div>
      <button class="btn btn-sm btn-lime-outline" onclick="cargarGuardada(${i})">Cargar</button>
      <button class="btn btn-sm btn-ghost" onclick="exportarGuardada(${i})">↓</button>
      <button class="btn btn-sm btn-ghost" style="color:var(--red)" onclick="borrarGuardada(${i})">✕</button>
    </div>`).join('');
}

function cargarGuardada(i) {
  const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
  if (!lista[i]) return;
  const p = lista[i];

  // Limpiar zonas existentes
  drawnItems.clearLayers();
  zonas = [];

  // Restaurar unidades
  if (p.units) {
    ['semilla','ferti_linea','ferti_costado'].forEach(k => {
      const el = document.getElementById(`unit-${k}`);
      if (el && p.units[k]) el.value = p.units[k];
    });
  }

  // Restaurar zonas
  p.data.forEach((d,idx) => {
    const layer = L.geoJSON(d.geojson).getLayers()[0];
    if (!layer) return;
    drawnItems.addLayer(layer);
    const zona = { id:Date.now()+idx, nombre:d.nombre, semilla:d.semilla,
                   ferti_linea:d.ferti_linea, ferti_costado:d.ferti_costado, layer };
    zonas.push(zona);
    layer.on('click', () => abrirEditarZona(zonas.indexOf(zona)));
  });

  _prescId = p.id; // Trackear cuál está cargada
  if (zonas.length) mapaL.fitBounds(drawnItems.getBounds(), { padding:[20,20] });
  renderListaZonas();
  repintarMapa();
  document.getElementById('btn-guardar').disabled  = false;
  document.getElementById('btn-exportar').disabled = false;
  closeModal('modal-guardadas');
  actualizarBadge();
  toast('✓ Cargada', p.nombre, 'lime');
}

function borrarGuardada(i) {
  const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
  if (!confirm(`¿Borrar "${lista[i]?.nombre}"?`)) return;
  lista.splice(i,1);
  localStorage.setItem('orbitx_presc', JSON.stringify(lista));
  renderGuardadas();
}

function exportarGuardada(i) {
  const lista = JSON.parse(localStorage.getItem('orbitx_presc')||'[]');
  if (!lista[i]) return;
  const p = lista[i];
  // Reconstruir zonas temporalmente para exportar
  const zonasTemp = p.data;
  const units     = p.units || {};
  _exportar(zonasTemp, units, p.nombre);
}

// ── Exportar ──────────────────────────────────────────────
function abrirExportar() {
  if (!zonas.length) return toast('Sin zonas', 'Dibujá al menos una zona', 'amber');
  openModal('modal-exportar');
}

function _exportar(zs, units, nombre) {
  window._exportZonas = zs;
  window._exportUnits = units || { semilla:getUnit('semilla'), ferti_linea:getUnit('ferti_linea'), ferti_costado:getUnit('ferti_costado') };
  window._exportNombre = nombre || 'prescripcion';
  openModal('modal-exportar');
}

function getExportZonas() {
  if (window._exportZonas) { const z=window._exportZonas; window._exportZonas=null; return z; }
  return zonas.map(z => ({ ...z, geojson: z.layer?.toGeoJSON() }));
}
function getExportUnits() {
  if (window._exportUnits) { const u=window._exportUnits; window._exportUnits=null; return u; }
  return { semilla:getUnit('semilla'), ferti_linea:getUnit('ferti_linea'), ferti_costado:getUnit('ferti_costado') };
}

function exportarJSON() {
  const zs = getExportZonas(), units = getExportUnits();
  const payload = {
    tipo:'prescripcion_dosis_variable', version:'1.0',
    generado: new Date().toISOString(),
    unidades: units,
    zonas: zs.map(z => ({
      nombre: z.nombre, semilla: z.semilla,
      ferti_linea: z.ferti_linea, ferti_costado: z.ferti_costado,
      geometry: z.geojson?.geometry || z.geojson,
    })),
  };
  descargar(JSON.stringify(payload,null,2), `${window._exportNombre||'prescripcion'}.json`, 'application/json');
  closeModal('modal-exportar');
}

function exportarCSV() {
  const zs = getExportZonas(), units = getExportUnits();
  const rows = [
    ['Zona', `Semilla (${UNIT_LBL[units.semilla||'sem_m']})`, `Ferti linea (${UNIT_LBL[units.ferti_linea||'kg_ha']})`, `Ferti costado (${UNIT_LBL[units.ferti_costado||'kg_ha']})`],
    ...zs.map(z => [z.nombre, z.semilla||0, z.ferti_linea||0, z.ferti_costado||0])
  ];
  const csv = rows.map(r=>r.map(c=>`"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  descargar(csv, `${window._exportNombre||'prescripcion'}.csv`, 'text/csv;charset=utf-8');
  closeModal('modal-exportar');
}

function exportarGeoJSON() {
  const zs = getExportZonas(), units = getExportUnits();
  const gj = {
    type: 'FeatureCollection',
    features: zs.map(z => ({
      type: 'Feature',
      geometry: z.geojson?.geometry || z.geojson,
      properties: {
        Name:   z.nombre,
        FertL:  Math.round(z.ferti_linea  || 0),
        FertC:  Math.round(z.ferti_costado|| 0),
        Sem:    parseFloat((z.semilla || 0).toFixed(3)),
      }
    }))
  };
  descargar(JSON.stringify(gj,null,2), `${window._exportNombre||'prescripcion'}.geojson`, 'application/json');
  closeModal('modal-exportar');
}

// ── Exportar SHP compatible con QuantiX ──────────────────
// Genera .shp + .dbf + .shx con el mismo formato de L7y8
function exportarSHP() {
  const zs    = getExportZonas();
  const nom   = window._exportNombre || 'prescripcion';

  try {
    const shpBuf = buildSHP(zs);
    const dbfBuf = buildDBF(zs);
    const shxBuf = buildSHX(zs);

    descargar(shpBuf, nom + '.shp', 'application/octet-stream');
    setTimeout(() => descargar(dbfBuf, nom + '.dbf', 'application/octet-stream'), 200);
    setTimeout(() => descargar(shxBuf, nom + '.shx', 'application/octet-stream'), 400);
    closeModal('modal-exportar');
    toast('✓ Shapefile generado', '3 archivos: .shp .dbf .shx', 'lime');
  } catch(e) {
    toast('✗ Error generando SHP', e.message, 'red');
  }
}

// ── SHP builder (PolygonZ type 15) ───────────────────────
function buildSHP(zonas) {
  const records = zonas.map(z => geomToRings(z.geojson?.geometry || z.geojson));

  // Calcular tamaño
  let contentBytes = 0;
  records.forEach(rings => {
    const nParts  = rings.length;
    const nPoints = rings.reduce((s,r) => s+r.length, 0);
    // 4(type)+32(bbox)+4(nparts)+4(npoints)+nparts*4+npoints*16 + Z ranges + Z values
    contentBytes += 4 + 32 + 4 + 4 + nParts*4 + nPoints*16 + 16 + nPoints*8 + 16 + nPoints*8;
  });
  const fileBytes = 100 + records.length * 8 + contentBytes;

  const buf  = new ArrayBuffer(fileBytes);
  const view = new DataView(buf);
  let off = 0;

  // ── File header ──
  setInt32BE(view, 0,  9994);       // file code
  setInt32BE(view, 24, fileBytes/2);// file length in 16-bit words
  view.setInt32(28, 1000, true);    // version
  view.setInt32(32, 15,   true);    // shape type PolygonZ

  // BBox global
  let minX=Infinity,minY=Infinity,maxX=-Infinity,maxY=-Infinity;
  records.forEach(rings => rings.forEach(ring => ring.forEach(([x,y]) => {
    if(x<minX)minX=x; if(x>maxX)maxX=x;
    if(y<minY)minY=y; if(y>maxY)maxY=y;
  })));
  view.setFloat64(36, minX, true); view.setFloat64(44, minY, true);
  view.setFloat64(52, maxX, true); view.setFloat64(60, maxY, true);
  // Z & M ranges (zeros)
  for(let i=68;i<100;i+=8) view.setFloat64(i,0,true);

  off = 100;

  records.forEach((rings, ri) => {
    const nParts  = rings.length;
    const nPoints = rings.reduce((s,r)=>s+r.length,0);
    const recContentBytes = 4+32+4+4+nParts*4+nPoints*16+16+nPoints*8+16+nPoints*8;
    const recContentWords = recContentBytes / 2;

    // Record header
    setInt32BE(view, off,   ri+1);
    setInt32BE(view, off+4, recContentWords);
    off += 8;

    // Shape type
    view.setInt32(off, 15, true); off += 4;

    // BBox
    let rx0=Infinity,ry0=Infinity,rx1=-Infinity,ry1=-Infinity;
    rings.forEach(ring=>ring.forEach(([x,y])=>{if(x<rx0)rx0=x;if(x>rx1)rx1=x;if(y<ry0)ry0=y;if(y>ry1)ry1=y;}));
    view.setFloat64(off,rx0,true);off+=8;
    view.setFloat64(off,ry0,true);off+=8;
    view.setFloat64(off,rx1,true);off+=8;
    view.setFloat64(off,ry1,true);off+=8;

    // Num parts & points
    view.setInt32(off,nParts,true);off+=4;
    view.setInt32(off,nPoints,true);off+=4;

    // Parts array
    let partStart=0;
    rings.forEach(ring=>{view.setInt32(off,partStart,true);off+=4;partStart+=ring.length;});

    // XY points
    rings.forEach(ring=>ring.forEach(([x,y])=>{
      view.setFloat64(off,x,true);off+=8;
      view.setFloat64(off,y,true);off+=8;
    }));

    // Z range (0,0) + Z values (all 0)
    view.setFloat64(off,0,true);off+=8;
    view.setFloat64(off,0,true);off+=8;
    for(let i=0;i<nPoints;i++){view.setFloat64(off,0,true);off+=8;}

    // M range (0,0) + M values (all 0)
    view.setFloat64(off,0,true);off+=8;
    view.setFloat64(off,0,true);off+=8;
    for(let i=0;i<nPoints;i++){view.setFloat64(off,0,true);off+=8;}
  });

  return buf;
}

// ── SHX builder ──────────────────────────────────────────
function buildSHX(zonas) {
  const records = zonas.map(z => geomToRings(z.geojson?.geometry || z.geojson));
  const fileBytes = 100 + records.length * 8;
  const buf  = new ArrayBuffer(fileBytes);
  const view = new DataView(buf);

  setInt32BE(view, 0,  9994);
  setInt32BE(view, 24, fileBytes/2);
  view.setInt32(28,1000,true);
  view.setInt32(32,15,true);
  for(let i=36;i<100;i+=4) view.setInt32(i,0,true);

  let offset = 50; // en words (100 bytes / 2)
  records.forEach((rings, ri) => {
    const nParts  = rings.length;
    const nPoints = rings.reduce((s,r)=>s+r.length,0);
    const recBytes = 4+32+4+4+nParts*4+nPoints*16+16+nPoints*8+16+nPoints*8;
    setInt32BE(view, 100+ri*8,   offset);
    setInt32BE(view, 100+ri*8+4, recBytes/2);
    offset += 4 + recBytes/2; // 4 words = 8 bytes record header
  });

  return buf;
}

// ── DBF builder (dBASE III) ───────────────────────────────
function buildDBF(zonas) {
  // Fields: Name(C,254), Fert L(N,10,0), Fert C(N,10,0), Sem(N,11,3)
  const fields = [
    { name:'Name',   type:'C', len:254, dec:0 },
    { name:'Fert L', type:'N', len:10,  dec:0 },
    { name:'Fert C', type:'N', len:10,  dec:0 },
    { name:'Sem',    type:'N', len:11,  dec:3 },
  ];
  const recordSize = 1 + fields.reduce((s,f)=>s+f.len,0);
  const headerSize = 32 + fields.length*32 + 1;
  const fileSize   = headerSize + zonas.length * recordSize;

  const buf  = new ArrayBuffer(fileSize);
  const view = new DataView(buf);
  const u8   = new Uint8Array(buf);

  // Header
  u8[0] = 3;  // version dBASE III
  const now = new Date();
  u8[1]=now.getFullYear()-1900; u8[2]=now.getMonth()+1; u8[3]=now.getDate();
  view.setUint32(4, zonas.length, true);
  view.setUint16(8,  headerSize,  true);
  view.setUint16(10, recordSize,  true);

  // Field descriptors
  fields.forEach((f,i) => {
    const fOff = 32 + i*32;
    writeStr(u8, fOff, f.name, 11);
    u8[fOff+11] = f.type.charCodeAt(0);
    u8[fOff+16] = f.len;
    u8[fOff+17] = f.dec;
  });
  u8[32 + fields.length*32] = 0x0D; // header terminator

  // Records
  zonas.forEach((z,ri) => {
    let rOff = headerSize + ri * recordSize;
    u8[rOff] = 0x20; rOff++; // not deleted
    const vals = [
      z.nombre || '',
      String(Math.round(z.ferti_linea  || 0)),
      String(Math.round(z.ferti_costado|| 0)),
      (z.semilla || 0).toFixed(3),
    ];
    fields.forEach((f,fi) => {
      const s = vals[fi].slice(0, f.len);
      const padded = f.type==='C' ? s.padEnd(f.len,' ') : s.padStart(f.len,' ');
      writeStr(u8, rOff, padded, f.len);
      rOff += f.len;
    });
  });
  u8[fileSize-1] = 0x1A; // EOF

  return buf;
}

// ── Helpers ───────────────────────────────────────────────
function setInt32BE(view, off, val) {
  view.setInt32(off, val, false); // big-endian
}

function writeStr(u8, off, str, len) {
  for(let i=0;i<len;i++) u8[off+i] = i<str.length ? str.charCodeAt(i) : 0x20;
}

function geomToRings(geom) {
  if (!geom) return [[]];
  if (geom.type === 'Polygon') {
    // GeoJSON coords son [lon,lat] — SHP también usa lon,lat → ok
    return geom.coordinates.map(ring => ring.map(([x,y])=>[x,y]));
  }
  if (geom.type === 'MultiPolygon') {
    // Aplanar todos los rings en una lista de partes
    const rings = [];
    geom.coordinates.forEach(poly => poly.forEach(ring => rings.push(ring.map(([x,y])=>[x,y]))));
    return rings;
  }
  return [[]];
}

function descargar(contenido, nombre, tipo) {
  const blob = contenido instanceof ArrayBuffer
    ? new Blob([contenido], {type:tipo})
    : new Blob([contenido], {type:tipo});
  const a = document.createElement('a');
  a.href  = URL.createObjectURL(blob);
  a.download = nombre;
  a.click();
  URL.revokeObjectURL(a.href);
}

