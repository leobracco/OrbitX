<%# pages/agraria.ejs — agrarIA: chat libre + análisis de lotes %>

<div class="page-header">
  <div>
    <h2>🌿 agrarIA</h2>
    <p>Análisis agronómico con inteligencia artificial · Powered by Claude</p>
  </div>
  <button class="btn btn-ghost" onclick="resumenDia()" id="btn-resumen">
    📋 Resumen del día
  </button>
</div>

<div class="g2" style="align-items:start">

  <!-- ── Chat libre ─────────────────────────────────────── -->
  <div class="card" style="display:flex;flex-direction:column;height:600px">
    <div class="card-head">
      <span class="card-title">💬 Chat agronómico</span>
      <button class="btn btn-sm btn-ghost" onclick="limpiarChat()">✕ Limpiar</button>
    </div>

    <!-- Mensajes -->
    <div id="chat-mensajes"
      style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px">
      <div class="chat-msg-ia">
        <div class="chat-bubble-ia">
          Hola. Soy agrarIA. Podés escribirme, adjuntarme fotos del campo, documentos PDF o notas de voz. ¿En qué te ayudo hoy?
        </div>
      </div>
    </div>

    <!-- Previews de archivos adjuntos -->
    <div id="adjuntos-preview"
      style="display:none;padding:8px 16px;border-top:1px solid var(--border);
             display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    </div>

    <!-- Input -->
    <div style="padding:10px 14px;border-top:1px solid var(--border);
                display:flex;gap:8px;align-items:flex-end">

      <!-- Botón adjuntar -->
      <div style="position:relative;flex-shrink:0">
        <button id="btn-adjuntar"
          onclick="document.getElementById('file-input').click()"
          title="Adjuntar imagen, PDF, GeoJSON, Shapefile, CSV, KML o audio"
          style="width:36px;height:36px;background:var(--surface2);border:1px solid var(--border);
                 border-radius:8px;color:var(--muted2);cursor:pointer;font-size:16px;
                 display:flex;align-items:center;justify-content:center;transition:all .15s;
                 flex-shrink:0"
          onmouseover="this.style.borderColor='rgba(184,255,60,0.4)';this.style.color='var(--lime)'"
          onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted2)'">
          📎
        </button>
        <input type="file" id="file-input" multiple accept="image/*,.pdf,audio/*"
          style="display:none" onchange="onFilesSelected(this.files)"
          accept="image/*,.pdf,audio/*,.geojson,.json,.csv,.kml,.kmz,.shp,.dbf,.shx,.prj,.txt,.zip"/>
      </div>

      <!-- Textarea del mensaje -->
      <textarea id="chat-input"
        placeholder="Escribí tu consulta…"
        rows="1"
        style="flex:1;background:var(--surface2);border:1px solid var(--border);
               color:var(--text);padding:9px 12px;border-radius:8px;
               font-family:var(--font-b);font-size:13px;outline:none;
               resize:none;line-height:1.5;max-height:120px;overflow-y:auto;
               transition:border-color .15s"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();enviarChat();}"
        oninput="autoResize(this)"
        onfocus="this.style.borderColor='rgba(184,255,60,0.4)'"
        onblur="this.style.borderColor='var(--border)'"></textarea>

      <!-- Botón enviar -->
      <button class="btn btn-primary" id="btn-chat" onclick="enviarChat()"
        style="padding:9px 14px;flex-shrink:0;height:36px">↑</button>
    </div>
  </div>

  <!-- ── Análisis rápidos ───────────────────────────────── -->
  <div style="display:flex;flex-direction:column;gap:14px">

    <!-- Analizar lote AOG -->
    <div class="card">
      <div class="card-head"><span class="card-title">🗺 Analizar lote AOG</span></div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:10px">
        <div class="field">
          <label>Lote</label>
          <select id="sel-lote-aog" style="width:100%">
            <option value="">Cargando lotes...</option>
          </select>
        </div>
        <button class="btn btn-primary" onclick="analizarLoteAOG()">Analizar</button>
        <div id="resultado-aog"
          style="display:none;background:var(--surface2);border:1px solid var(--border);
                 border-radius:8px;padding:12px;font-size:13px;color:var(--text);line-height:1.7">
        </div>
      </div>
    </div>

    <!-- Comparar lotes -->
    <div class="card">
      <div class="card-head"><span class="card-title">⚖ Comparar lotes</span></div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:10px">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
          <div class="field">
            <label>Lote A</label>
            <select id="sel-lote-a" style="width:100%"><option value="">–</option></select>
          </div>
          <div class="field">
            <label>Lote B</label>
            <select id="sel-lote-b" style="width:100%"><option value="">–</option></select>
          </div>
        </div>
        <button class="btn btn-primary" onclick="compararLotes()">Comparar</button>
        <div id="resultado-comparar"
          style="display:none;background:var(--surface2);border:1px solid var(--border);
                 border-radius:8px;padding:12px;font-size:13px;color:var(--text);line-height:1.7">
        </div>
      </div>
    </div>

    <!-- Resumen del día -->
    <div class="card" id="card-resumen" style="display:none">
      <div class="card-head"><span class="card-title">📋 Resumen del día</span></div>
      <div class="card-body">
        <div id="resultado-resumen"
          style="font-size:13px;color:var(--text);line-height:1.7"></div>
        <div id="resumen-stats"
          style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px"></div>
      </div>
    </div>

  </div>
</div>

<style>
.chat-msg-ia   { display:flex; justify-content:flex-start; }
.chat-msg-user { display:flex; justify-content:flex-end; }
.chat-bubble-ia {
  background:var(--surface2); border:1px solid var(--border);
  border-radius:12px 12px 12px 2px;
  padding:10px 14px; max-width:85%;
  font-size:13px; color:var(--text); line-height:1.6;
}
.chat-bubble-user {
  background:var(--lime-dim); border:1px solid rgba(184,255,60,0.2);
  border-radius:12px 12px 2px 12px;
  padding:10px 14px; max-width:85%;
  font-size:13px; color:var(--text); line-height:1.6;
}
.chat-typing { display:flex; gap:4px; align-items:center; padding:4px 0; }
.chat-typing span {
  width:6px; height:6px; border-radius:50%;
  background:var(--muted2); animation:typingDot 1.2s infinite;
}
.chat-typing span:nth-child(2) { animation-delay:0.2s; }
.chat-typing span:nth-child(3) { animation-delay:0.4s; }
@keyframes typingDot {
  0%,60%,100% { opacity:0.3; transform:translateY(0); }
  30%          { opacity:1;   transform:translateY(-4px); }
}
/* Chip de adjunto */
.adjunto-chip {
  display:flex; align-items:center; gap:6px;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:6px; padding:4px 8px;
  font-size:11px; color:var(--text); max-width:160px;
}
.adjunto-chip span { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; }
.adjunto-chip button {
  background:none; border:none; color:var(--muted2);
  cursor:pointer; font-size:13px; padding:0; line-height:1; flex-shrink:0;
}
/* Thumbnail en burbuja */
.chat-img-thumb {
  max-width:220px; max-height:160px;
  border-radius:8px; margin-top:6px;
  object-fit:cover; display:block;
}
.chat-file-pill {
  display:inline-flex; align-items:center; gap:6px;
  background:rgba(255,255,255,0.07); border-radius:6px;
  padding:4px 10px; font-size:11px; margin-top:5px;
}
</style>

<script>
let _historialChat = [];
let _lotesAOG      = [];
let _adjuntos      = []; // [{file, tipo, base64, mediaType, nombre}]

// ── Auto-resize textarea ──────────────────────────────────
function autoResize(el) {
  el.style.height = "auto";
  el.style.height = Math.min(el.scrollHeight, 120) + "px";
}

// ── Cargar lotes ──────────────────────────────────────────
async function cargarLotesIA() {
  try {
    const lotes = await Auth.get('/api/aog/lotes');
    _lotesAOG   = lotes;
    const opts  = '<option value="">Seleccioná un lote...</option>' +
      lotes.map(l => `<option value="${l.nombre}">${l.nombre}</option>`).join('');
    document.getElementById('sel-lote-aog').innerHTML = opts;
    document.getElementById('sel-lote-a').innerHTML   = opts;
    document.getElementById('sel-lote-b').innerHTML   = opts;
  } catch(e) {
    ['sel-lote-aog','sel-lote-a','sel-lote-b'].forEach(id => {
      document.getElementById(id).innerHTML = '<option value="">Error cargando lotes</option>';
    });
  }
}

// ── Manejo de archivos adjuntos ───────────────────────────
async function onFilesSelected(files) {
  for (const file of files) {
    if (_adjuntos.length >= 5) { toast('Máximo 5 adjuntos por mensaje', '', 'amber'); break; }

    const tipo = file.type;
    const ext  = file.name.split('.').pop().toLowerCase();
    let categoria, icono;

    if (tipo.startsWith('image/')) {
      categoria = 'imagen'; icono = '🖼';
    } else if (tipo === 'application/pdf') {
      categoria = 'pdf'; icono = '📄';
    } else if (tipo.startsWith('audio/')) {
      categoria = 'audio'; icono = '🎵';
    } else if (['geojson','json'].includes(ext)) {
      categoria = 'geojson'; icono = '🗺';
    } else if (ext === 'shp') {
      categoria = 'shp'; icono = '📐';
    } else if (['dbf','shx','prj'].includes(ext)) {
      categoria = 'shp_aux'; icono = '📎';
    } else if (ext === 'csv') {
      categoria = 'csv'; icono = '📊';
    } else if (['kml','kmz'].includes(ext)) {
      categoria = 'kml'; icono = '📍';
    } else if (ext === 'txt') {
      categoria = 'txt'; icono = '📝';
    } else if (ext === 'zip') {
      categoria = 'zip'; icono = '🗜';
    } else {
      // Intentar como texto genérico
      categoria = 'datos'; icono = '📁';
    }

    // Límite de tamaño: 10MB
    if (file.size > 10 * 1024 * 1024) {
      toast(`${file.name} es muy grande`, 'Máximo 10 MB', 'amber');
      continue;
    }

    const ext2 = file.name.split('.').pop().toLowerCase();
    let base64 = null, texto = null;
    if (TEXT_EXTS.has(ext2) && file.size < 5*1024*1024) {
      texto = await fileToText(file);
    } else {
      base64 = await fileToBase64(file);
    }
    _adjuntos.push({ file, tipo, categoria, icono, base64, texto, mediaType: tipo, nombre: file.name });
  }

  document.getElementById('file-input').value = '';
  renderAdjuntosPreview();
}

const TEXT_EXTS = new Set(['geojson','json','csv','kml','txt','prj']);

function fileToBase64(file) {
  return new Promise((res, rej) => {
    const r = new FileReader();
    r.onload  = () => res(r.result.split(',')[1]);
    r.onerror = () => rej(new Error('Error leyendo archivo'));
    r.readAsDataURL(file);
  });
}

function fileToText(file) {
  return new Promise((res, rej) => {
    const r = new FileReader();
    r.onload  = () => res(r.result);
    r.onerror = () => rej(new Error('Error leyendo archivo'));
    r.readAsText(file, 'utf-8');
  });
}

function renderAdjuntosPreview() {
  const cont = document.getElementById('adjuntos-preview');
  if (!_adjuntos.length) { cont.style.display = 'none'; return; }
  cont.style.display = 'flex';
  cont.innerHTML = _adjuntos.map((a, i) => `
    <div class="adjunto-chip">
      <span style="flex-shrink:0">${a.icono}</span>
      <span title="${a.nombre}">${a.nombre}</span>
      <button onclick="quitarAdjunto(${i})" title="Quitar">✕</button>
    </div>`).join('') +
    `<span style="font-size:10px;color:var(--muted2)">${_adjuntos.length}/5</span>`;
}

function quitarAdjunto(i) {
  _adjuntos.splice(i, 1);
  renderAdjuntosPreview();
}

// ── Chat ──────────────────────────────────────────────────
function agregarMensaje(contenido, esUsuario, adjuntos = []) {
  const cont = document.getElementById('chat-mensajes');
  const div  = document.createElement('div');
  div.className = esUsuario ? 'chat-msg-user' : 'chat-msg-ia';

  let extra = '';
  if (adjuntos.length) {
    extra = adjuntos.map(a => {
      if (a.categoria === 'imagen') {
        return `<img src="data:${a.mediaType};base64,${a.base64}"
                  class="chat-img-thumb" alt="${a.nombre}"/>`;
      }
      return `<div class="chat-file-pill">${a.icono} ${a.nombre}</div>`;
    }).join('');
  }

  div.innerHTML = `<div class="${esUsuario ? 'chat-bubble-user' : 'chat-bubble-ia'}">
    ${contenido ? `<div>${contenido}</div>` : ''}
    ${extra}
  </div>`;
  cont.appendChild(div);
  cont.scrollTop = cont.scrollHeight;
  return div;
}

function mostrarTyping() {
  const cont = document.getElementById('chat-mensajes');
  const div  = document.createElement('div');
  div.className = 'chat-msg-ia';
  div.id = 'typing-indicator';
  div.innerHTML = `<div class="chat-bubble-ia">
    <div class="chat-typing"><span></span><span></span><span></span></div>
  </div>`;
  cont.appendChild(div);
  cont.scrollTop = cont.scrollHeight;
}

async function enviarChat() {
  const input   = document.getElementById('chat-input');
  const mensaje = input.value.trim();

  // Necesita al menos texto O adjunto
  if (!mensaje && !_adjuntos.length) return;

  input.value = '';
  input.style.height = 'auto';
  const btn = document.getElementById('btn-chat');
  btn.disabled = true;

  // Capturar adjuntos antes de limpiar
  const adjuntosEnvio = [..._adjuntos];
  _adjuntos = [];
  renderAdjuntosPreview();

  // Mostrar burbuja del usuario
  agregarMensaje(mensaje, true, adjuntosEnvio);
  mostrarTyping();

  try {
    // Armar payload — adjuntos como base64
    const adjuntosPayload = adjuntosEnvio.map(a => ({
      categoria:  a.categoria,
      mediaType:  a.mediaType,
      base64:     a.base64  || null,
      texto:      a.texto   || null,
      nombre:     a.nombre,
    }));

    const r = await Auth.post('/api/agraria/chat', {
      mensaje,
      historial: _historialChat,
      adjuntos:  adjuntosPayload,
    });

    document.getElementById('typing-indicator')?.remove();
    agregarMensaje(r.respuesta, false);

    // Guardar en historial (sin base64 para no inflar)
    const resumenAdjuntos = adjuntosEnvio.length
      ? ` [Adjuntos: ${adjuntosEnvio.map(a => a.nombre).join(', ')}]`
      : '';
    _historialChat.push({ rol: 'user',      texto: mensaje + resumenAdjuntos });
    _historialChat.push({ rol: 'assistant', texto: r.respuesta });
    if (_historialChat.length > 20) _historialChat = _historialChat.slice(-20);

  } catch(e) {
    document.getElementById('typing-indicator')?.remove();
    agregarMensaje(`Error: ${e.message}`, false);
  } finally {
    btn.disabled = false;
    input.focus();
  }
}

function limpiarChat() {
  _historialChat = [];
  _adjuntos      = [];
  renderAdjuntosPreview();
  const cont = document.getElementById('chat-mensajes');
  cont.innerHTML = `<div class="chat-msg-ia">
    <div class="chat-bubble-ia">Chat reiniciado. ¿En qué te puedo ayudar?</div>
  </div>`;
}

// ── Drag & drop en el área de chat ───────────────────────
(function() {
  const card = document.querySelector('.card');
  if (!card) return;
  ['dragover','dragenter'].forEach(ev =>
    document.getElementById('chat-mensajes')?.addEventListener(ev, e => {
      e.preventDefault();
      e.currentTarget.style.outline = '2px dashed rgba(184,255,60,0.4)';
    })
  );
  document.getElementById('chat-mensajes')?.addEventListener('dragleave', e => {
    e.currentTarget.style.outline = '';
  });
  document.getElementById('chat-mensajes')?.addEventListener('drop', e => {
    e.preventDefault();
    e.currentTarget.style.outline = '';
    if (e.dataTransfer.files.length) onFilesSelected(e.dataTransfer.files);
  });
})();

// ── Análisis rápidos (igual que antes) ───────────────────
async function analizarLoteAOG() {
  const nombre = document.getElementById('sel-lote-aog').value;
  if (!nombre) { toast('Seleccioná un lote', '', 'amber'); return; }
  const res = document.getElementById('resultado-aog');
  res.style.display = 'block'; res.textContent = 'Analizando...';
  try {
    const r = await Auth.post('/api/agraria/analizar-lote', { lote_nombre: nombre });
    res.textContent = r.analisis;
    agregarMensaje(`Análisis del lote "${nombre}": ${r.analisis}`, false);
    _historialChat.push({ rol:'assistant', texto: `Análisis "${nombre}": ${r.analisis}` });
  } catch(e) { res.textContent = `Error: ${e.message}`; }
}

async function compararLotes() {
  const a = document.getElementById('sel-lote-a').value;
  const b = document.getElementById('sel-lote-b').value;
  if (!a || !b)  { toast('Seleccioná dos lotes', '', 'amber'); return; }
  if (a === b)   { toast('Seleccioná lotes diferentes', '', 'amber'); return; }
  const res = document.getElementById('resultado-comparar');
  res.style.display = 'block'; res.textContent = 'Comparando...';
  try {
    const r = await Auth.post('/api/agraria/comparar-lotes', { lote_a: a, lote_b: b });
    res.textContent = r.analisis;
    agregarMensaje(`Comparación "${a}" vs "${b}": ${r.analisis}`, false);
    _historialChat.push({ rol:'assistant', texto: r.analisis });
  } catch(e) { res.textContent = `Error: ${e.message}`; }
}

async function resumenDia() {
  const btn = document.getElementById('btn-resumen');
  btn.disabled = true; btn.textContent = '...';
  try {
    const r = await Auth.post('/api/agraria/resumen-dia', {});
    document.getElementById('card-resumen').style.display = 'block';
    document.getElementById('resultado-resumen').textContent = r.resumen;
    document.getElementById('resumen-stats').innerHTML = `
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center">
        <div style="font-family:var(--font-m);font-size:20px;color:var(--lime)">${r.lotes}</div>
        <div style="font-size:10px;color:var(--muted2);margin-top:3px">Lotes</div>
      </div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center">
        <div style="font-family:var(--font-m);font-size:20px;color:${r.alertas>0?'var(--red)':'var(--lime)'}">${r.alertas}</div>
        <div style="font-size:10px;color:var(--muted2);margin-top:3px">Alertas</div>
      </div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center">
        <div style="font-family:var(--font-m);font-size:14px;color:var(--teal)">${r.fecha}</div>
        <div style="font-size:10px;color:var(--muted2);margin-top:3px">Fecha</div>
      </div>`;
    document.getElementById('card-resumen').scrollIntoView({ behavior:'smooth' });
  } catch(e) {
    toast('Error generando resumen', e.message, 'red');
  } finally {
    btn.disabled = false; btn.textContent = '📋 Resumen del día';
  }
}

document.addEventListener('DOMContentLoaded', cargarLotesIA);
</script>
