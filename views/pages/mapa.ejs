<%# pages/mapa.ejs — Mapa de lotes · buscador + lazy load + panel de capas %>

<div class="page-header">
  <div>
    <h2>Mapa de lotes</h2>
    <p>Boundaries · cobertura · capas externas</p>
  </div>
  <div style="display:flex;gap:8px;align-items:center">
    <span id="mapa-estado" style="font-size:11px;color:var(--muted2)">–</span>
    <button id="btn-ndvi" class="btn btn-ghost" onclick="OrbitNDVI.toggle()"
      style="display:flex;align-items:center;gap:6px">
      🛰 NDVI
    </button>
    <button class="btn btn-ghost" onclick="limpiarMapa()">✕ Limpiar</button>
  </div>
</div>

<!-- Buscador -->
<div class="card" style="margin-bottom:14px">
  <div class="card-body" style="padding:12px 16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">

    <div style="position:relative;flex:1;min-width:200px">
      <input type="text" id="lote-search"
        placeholder="Buscar lote… (mínimo 3 caracteres)"
        autocomplete="off"
        style="width:100%;background:var(--surface2);border:1px solid var(--border);
               color:var(--text);padding:9px 12px 9px 34px;border-radius:8px;
               font-family:var(--font-b);font-size:13px;outline:none;
               box-sizing:border-box;transition:border-color .15s"
        oninput="onBusqueda(this.value)"
        onfocus="this.style.borderColor='rgba(184,255,60,0.4)'"
        onblur="this.style.borderColor='var(--border)'"/>
      <span style="position:absolute;left:11px;top:50%;transform:translateY(-50%);
                   font-size:13px;opacity:0.35;pointer-events:none">🔍</span>

      <div id="search-dropdown"
        style="display:none;position:fixed;z-index:99999;
               background:rgba(10,14,26,0.96);border:1px solid rgba(255,255,255,0.1);
               border-radius:10px;box-shadow:0 12px 40px rgba(0,0,0,0.7);
               backdrop-filter:blur(12px);max-height:280px;overflow-y:auto">
      </div>
    </div>

    <% if (locals.isSA) { %>
    <select id="filtro-estab"
      style="background:var(--surface2);border:1px solid var(--border);color:var(--text);
             padding:9px 12px;border-radius:8px;font-family:var(--font-b);font-size:13px;
             outline:none;flex-shrink:0"
      onchange="recargarLista()">
      <option value="">Todos los establecimientos</option>
      <% establecimientos.forEach(e => { %>
      <option value="<%= e.slug %>" <%= locals.miSlug===e.slug?'selected':'' %>><%= e.nombre %></option>
      <% }) %>
    </select>
    <% } %>

    <div id="pill-activo"
      style="display:none;background:var(--lime-dim);border:1px solid rgba(184,255,60,0.3);
             border-radius:8px;padding:7px 12px;font-size:12px;color:var(--lime);
             align-items:center;gap:8px;white-space:nowrap;flex-shrink:0">
      <span id="pill-nombre">–</span>
      <button onclick="limpiarMapa()"
        style="background:none;border:none;color:var(--lime);cursor:pointer;font-size:14px;padding:0;line-height:1">✕</button>
    </div>
  </div>
</div>

<!-- Layout: mapa + panel capas -->
<div style="display:grid;grid-template-columns:1fr auto;gap:14px;align-items:start">

  <!-- Mapa -->
  <div style="position:relative;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border)">
    <div id="mapa" style="height:580px;width:100%;background:#050810"></div>

    <!-- Leyenda -->
    <div id="mapa-leyenda"
      style="position:absolute;bottom:12px;left:12px;background:rgba(0,0,0,0.78);
             border-radius:8px;padding:10px 14px;z-index:1000;font-size:11px;
             color:#fff;line-height:2.4;pointer-events:none;min-width:140px">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="display:inline-block;width:16px;height:2px;background:#b8ff3c;border-radius:2px"></span>Boundary
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <span style="display:inline-block;width:14px;height:10px;background:rgba(60,158,255,0.35);
                     border:1px solid #3c9eff;border-radius:2px"></span>Cobertura
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <span style="display:inline-block;width:8px;height:8px;background:#f59e0b;border-radius:50%"></span>Origen GPS
      </div>
      <!-- Capas externas se agregan dinámicamente aquí -->
      <div id="leyenda-capas"></div>
    </div>

    <!-- Overlay vacío -->
    <div id="mapa-empty"
      style="position:absolute;inset:0;display:flex;flex-direction:column;
             align-items:center;justify-content:center;pointer-events:none;z-index:500">
      <div style="font-size:40px;opacity:0.15">🗺</div>
      <div style="font-size:12px;color:var(--muted2);margin-top:10px;opacity:0.5">
        Buscá un lote para verlo
      </div>
    </div>

    <!-- Loading -->
    <div id="mapa-loading"
      style="display:none;position:absolute;inset:0;background:rgba(0,0,0,0.55);
             align-items:center;justify-content:center;z-index:2000">
      <div style="background:var(--surface);border:1px solid var(--border);
           border-radius:10px;padding:14px 22px;font-size:13px;color:var(--text);
           display:flex;align-items:center;gap:10px">
        <span class="spinner"></span><span id="loading-texto">Cargando…</span>
      </div>
    </div>
  </div>

  <!-- Panel de capas (se muestra cuando hay lote seleccionado) -->
  <div id="panel-capas"
    style="display:none;width:240px;background:var(--surface);border:1px solid var(--border);
           border-radius:var(--radius);overflow:hidden;flex-shrink:0">

    <div style="padding:12px 14px;border-bottom:1px solid var(--border);
                display:flex;align-items:center;justify-content:space-between">
      <span style="font-size:12px;font-weight:500;color:#fff">Capas</span>
      <span id="capas-count" style="font-size:10px;color:var(--muted2)">–</span>
    </div>

    <div id="capas-lista" style="padding:8px 0;max-height:520px;overflow-y:auto"></div>

    <div style="padding:10px 14px;border-top:1px solid var(--border)">
      <button class="btn btn-ghost" style="width:100%;font-size:11px"
        onclick="window.location='/lotes'">
        ✏ Gestionar capas →
      </button>
    </div>
  </div>

</div>

<!-- Panel NDVI — se monta por OrbitNDVI.init() -->
<div id="ndvi-controls"></div>

<!-- Leaflet -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
.leaflet-container { background: #050810 !important; }
#search-dropdown > div { transition: background .1s; }

.capa-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  cursor: pointer;
  transition: background .1s;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.capa-item:hover { background: var(--surface2); }
.capa-item:last-child { border-bottom: none; }
.capa-toggle {
  width: 28px; height: 16px; border-radius: 8px;
  border: 1.5px solid rgba(255,255,255,0.2);
  flex-shrink: 0; cursor: pointer;
  transition: all .2s; position: relative;
}
.capa-toggle.on  { border-color: rgba(184,255,60,0.6); }
.capa-toggle::after {
  content: ''; position: absolute;
  width: 10px; height: 10px; border-radius: 50%;
  top: 2px; left: 2px; transition: all .2s;
}
.capa-toggle.off::after { background: rgba(255,255,255,0.2); }
.capa-toggle.on::after  { background: var(--lime); transform: translateX(12px); }
</style>

<script>
// ── Estado ─────────────────────────────────────────────────
let _mapa       = null;
let _layers     = [];        // capas base del lote (boundary, sections, origen)
let _capaLayers = {};        // { capaId: [leafletLayer, ...] }
let _lista      = [];
let _searchTO   = null;
let _loteActual = null;
let _primerBoundsCargado = false;  // evita que el 2do SHP pise el fitBounds

// Paleta para capas externas
const CAPA_COLORES = [
  "#ff6b35","#a855f7","#06b6d4","#f59e0b",
  "#ec4899","#10b981","#ef4444","#8b5cf6",
];
let _colorIdx = 0;
function nextColor() { return CAPA_COLORES[_colorIdx++ % CAPA_COLORES.length]; }

const CAPA_ICONO = {
  ndvi:'🛰', imagen_drone:'🚁', imagen_sat:'🛰', lluvia:'🌧', clima:'🌤',
  quantix:'⚙', vistax_manual:'🌱', analisis_suelo:'🧪', prescripcion:'📋',
  shapefile:'📐', pdf:'📄', csv:'📊', nota:'📝', imagen:'🖼', otro:'📁',
  geojson:'🗺', kml:'📍',
};

// ── Init mapa ──────────────────────────────────────────────
function initMapa() {
  if (_mapa) return;
  _mapa = L.map("mapa", { zoomControl: true, preferCanvas: true })
            .setView([-34.6, -60.0], 10);

  const _satLayer = L.tileLayer(
    "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
    { attribution: "Esri", maxNativeZoom: 17, maxZoom: 22 }
  ).addTo(_mapa);

  const _labelLayer = L.tileLayer(
    "https://services.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}",
    { maxNativeZoom: 17, maxZoom: 22, opacity: 0.7 }
  ).addTo(_mapa);

  _mapa.on("zoomend", () => {
    _labelLayer.setOpacity(_mapa.getZoom() > 17 ? 0 : 0.7);
  });
  _mapa.on("click", cerrarDropdown);
}

// ── Lista liviana ──────────────────────────────────────────
async function recargarLista() {
  try {
    const estab = document.getElementById("filtro-estab")?.value || "";
    const url   = "/api/aog/lotes-mapa" + (estab ? "?estab=" + estab : "");
    _lista      = await Auth.get(url);
    document.getElementById("mapa-estado").textContent =
      _lista.length + " lote" + (_lista.length !== 1 ? "s" : "");
  } catch {
    document.getElementById("mapa-estado").textContent = "Error al cargar";
  }
}

// ── Buscador ───────────────────────────────────────────────
function posicionarDropdown() {
  const input = document.getElementById("lote-search");
  const dd    = document.getElementById("search-dropdown");
  const rect  = input.getBoundingClientRect();
  dd.style.top   = (rect.bottom + 4) + "px";
  dd.style.left  = rect.left + "px";
  dd.style.width = rect.width + "px";
}

function onBusqueda(val) {
  clearTimeout(_searchTO);
  const dd = document.getElementById("search-dropdown");
  if (val.trim().length < 3) { dd.style.display = "none"; return; }

  _searchTO = setTimeout(() => {
    const q = val.trim().toLowerCase();
    const matches = _lista.filter(l =>
      (l.nombre || "").toLowerCase().includes(q) ||
      (l.estab_slug || "").toLowerCase().includes(q)
    ).slice(0, 10);

    if (!matches.length) {
      dd.innerHTML = `<div style="padding:14px 16px;font-size:12px;color:rgba(255,255,255,0.4);text-align:center">
        Sin resultados para "<em style='color:rgba(255,255,255,0.6)'>${val}</em>"</div>`;
      dd.style.display = "block";
      posicionarDropdown();
      return;
    }

    dd.innerHTML = matches.map(l => {
      const nombre = l.nombre || "?";
      const badges = [
        l.tiene_boundary ? `<span style="font-size:9px;color:var(--lime);opacity:.8">⬡ boundary</span>` : "",
        l.tiene_sections ? `<span style="font-size:9px;color:#3c9eff;opacity:.8">▦ cobertura</span>` : "",
        l.tiene_origen   ? `<span style="font-size:9px;color:#f59e0b;opacity:.8">📍 GPS</span>` : "",
      ].filter(Boolean).join(" &middot; ");
      const estabLabel = l.estab_slug && l.estab_slug !== "unassigned" ? l.estab_slug : "";
      return `<div
        onclick="seleccionarLote('${encodeURIComponent(nombre)}','${l.estab_slug||''}')"
        onmouseover="this.style.background='rgba(184,255,60,0.06)'"
        onmouseout="this.style.background=''"
        style="padding:11px 16px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,0.05);transition:background .1s">
        <div style="font-size:13px;font-weight:500;color:#fff">${nombre}</div>
        <div style="margin-top:3px;display:flex;gap:6px;align-items:center;flex-wrap:wrap">
          ${estabLabel ? `<span style="font-size:10px;color:rgba(255,255,255,0.35)">${estabLabel}</span>` : ""}
          ${badges ? `<span style="font-size:10px">${badges}</span>` : ""}
        </div>
      </div>`;
    }).join("");

    posicionarDropdown();
    dd.style.display = "block";
  }, 180);
}

function cerrarDropdown() {
  document.getElementById("search-dropdown").style.display = "none";
}

// ── Seleccionar lote ───────────────────────────────────────
async function seleccionarLote(nombreEnc, estabSlug) {
  cerrarDropdown();
  _loteActual = decodeURIComponent(nombreEnc);
  document.getElementById("lote-search").value = _loteActual;

  initMapa();
  mostrarLoading("Cargando lote…");
  document.getElementById("mapa-empty").style.display = "none";

  // Limpiar todo
  _layers.forEach(l => _mapa.removeLayer(l));
  _layers = [];
  Object.values(_capaLayers).forEach(ls => ls.forEach(l => _mapa.removeLayer(l)));
  _capaLayers = {};
  _colorIdx   = 0;
  _primerBoundsCargado = false;
  document.getElementById("leyenda-capas").innerHTML = "";
  document.getElementById("panel-capas").style.display = "none";

  try {
    // 1. Cargar AOG base
    const qs   = `?lote=${nombreEnc}` + (estabSlug ? `&estab=${estabSlug}` : "");
    const data = await Auth.get("/api/aog/mapa" + qs);
    const lote = Array.isArray(data) ? data[0] : data;

    const bounds = [];

    if (lote) {
      const nombre = lote.nombre || _loteActual;

      if (lote.boundary?.length > 2) {
        const poly = L.polygon(lote.boundary, {
          color: "#b8ff3c", weight: 1.5, opacity: 0.9,
          fillColor: "#b8ff3c", fillOpacity: 0.07,
        }).addTo(_mapa);
        poly.bindTooltip(`<b style="color:#b8ff3c">${nombre}</b>`, { sticky: true });
        _layers.push(poly);
        lote.boundary.forEach(p => bounds.push(p));
      }

      if (lote.sections?.length) {
        lote.sections.forEach(rect => {
          _layers.push(L.polygon(rect, {
            color: "#3c9eff", weight: 0.5, opacity: 0.7,
            fillColor: "#3c9eff", fillOpacity: 0.3,
          }).addTo(_mapa));
        });
      }

      if (lote.origen) {
        const m = L.circleMarker([lote.origen.lat, lote.origen.lon], {
          radius: 5, color: "#f59e0b", fillColor: "#f59e0b", fillOpacity: 1, weight: 1.5,
        }).addTo(_mapa);
        m.bindTooltip(`${nombre} — origen GPS`);
        _layers.push(m);
        bounds.push([lote.origen.lat, lote.origen.lon]);
      }

      if (bounds.length) _mapa.fitBounds(bounds, { padding: [40, 40], maxZoom: 18 });
    }

    // Pill activo
    document.getElementById("pill-nombre").textContent   = _loteActual;
    document.getElementById("pill-activo").style.display = "flex";

    // Estado
    const info = [
      lote?.boundary ? "⬡ Boundary" : null,
      lote?.sections ? `▦ ${lote.sections.length} pasadas` : null,
      lote?.origen   ? "📍 GPS" : null,
    ].filter(Boolean).join(" · ");
    document.getElementById("mapa-estado").textContent = _loteActual + (info ? "  " + info : "");

    // 2. Cargar capas externas del lote
    ocultarLoading();
    cargarCapasLote(nombreEnc, estabSlug);

  } catch(e) {
    toast("Error cargando lote", e.message, "red");
    document.getElementById("mapa-empty").style.display = "flex";
    ocultarLoading();
  }
}

// ── Cargar capas externas (async, no bloquea) ─────────────
async function cargarCapasLote(nombreEnc, estabSlug) {
  try {
    const ctx = await Auth.get(`/api/lotes-maestro/${nombreEnc}/contexto`);
    const externas = ctx.capas?.externas || {};
    const todasCapas = Object.entries(externas).flatMap(([subtipo, capas]) =>
      capas.map(c => ({ ...c, subtipo }))
    );

    if (!todasCapas.length) return;

    // Debug: confirmar que los datos llegaron
    console.log("[VistaX/capas] Total capas:", todasCapas.length);
    todasCapas.forEach((c,i) => console.log(`  [${i}] ${c.nombre} | texto:${!!c.contenido_texto} | b64:${!!c.base64}`));

    // Mostrar panel
    document.getElementById("panel-capas").style.display = "block";
    document.getElementById("capas-count").textContent   = todasCapas.length + " capa" + (todasCapas.length !== 1 ? "s" : "");

    renderPanelCapas(todasCapas, nombreEnc);

    // Separar SHP de otros formatos
    // Detección por mediaType (cuando el nombre de capa no tiene extensión)
    // o por extensión del nombre
    const shpGrupos = {};
    const noSHP     = [];
    for (const capa of todasCapas) {
      const ext = (capa.nombre || "").split(".").pop().toLowerCase();
      const mt  = (capa.mediaType || "").toLowerCase();

      // Detectar SHP por mediaType o extensión
      const esShpBin = mt.includes("shp") || mt.includes("x-shapefile") || ext === "shp";
      const esShx    = mt.includes("shx") || ext === "shx";
      const esDbf    = mt.includes("dbf") || ext === "dbf";
      const esPrj    = mt.includes("prj") || ext === "prj";

      if (esShpBin || esShx || esDbf || esPrj) {
        // Agrupar por _id del primer SHP encontrado, o por nombre base si tiene extensión
        let base;
        if (ext === "shp") {
          base = capa.nombre.replace(/\.shp$/i, "");
        } else if (esShpBin) {
          // mediaType es shp pero el nombre no tiene .shp — usar ts como base
          base = "shp_" + capa.ts;
        } else {
          // dbf, shx, prj — buscar el SHP más cercano en tiempo
          // Buscaremos el SHP cuyo ts sea el más parecido
          base = "shp_" + capa.ts; // fallback — se refinará abajo
        }
        if (!shpGrupos[base]) shpGrupos[base] = { nombreDisplay: capa.nombre };
        if (esShpBin)     shpGrupos[base].shp = capa;
        else if (esShx)   shpGrupos[base].shx = capa;
        else if (esDbf)   shpGrupos[base].dbf = capa;
        else if (esPrj)   shpGrupos[base].prj = capa;
      } else {
        noSHP.push(capa);
      }
    }

    // Reagrupar SHP por proximidad temporal (SHX/DBF del mismo upload)
    // Si hay un SHP con ts muy cercano a un SHX/DBF huérfano, unirlos
    const shpArr = Object.entries(shpGrupos);
    for (const [base, grp] of shpArr) {
      if (!grp.shp) continue; // solo procesar grupos con SHP
      const shpTs = grp.shp.ts;
      for (const [base2, grp2] of shpArr) {
        if (base2 === base || grp2.shp) continue; // skip si ya tiene SHP o es el mismo
        // Si la capa auxiliar está dentro de 60s del SHP, combinar
        const auxTs = (grp2.shx || grp2.dbf || grp2.prj)?.ts || 0;
        if (Math.abs(shpTs - auxTs) < 60000) {
          if (grp2.shx && !grp.shx) grp.shx = grp2.shx;
          if (grp2.dbf && !grp.dbf) grp.dbf = grp2.dbf;
          if (grp2.prj && !grp.prj) grp.prj = grp2.prj;
          delete shpGrupos[base2];
        }
      }
    }

    // Cargar grupos SHP via endpoint de conversión UTM→WGS84
    for (const [base, grp] of Object.entries(shpGrupos)) {
      if (grp.shp && grp.shp.base64) {
        await cargarSHPEnMapa(base, grp);
      }
    }

    // Cargar resto (GeoJSON, CSV, KML)
    for (const capa of noSHP) {
      if (capa.contenido_texto || capa.base64) {
        await cargarCapaEnMapa(capa, nombreEnc);
      }
    }

  } catch(e) {
    console.error("[cargarCapasLote] ERROR:", e.message, e);
    toast("Error cargando capas", e.message, "red");
  }
}

// ── Renderizar panel de capas ──────────────────────────────
function renderPanelCapas(capas, nombreEnc) {
  const lista = document.getElementById("capas-lista");

  // Agrupar SHP para mostrar como una sola entrada
  const shpGruposVisto = new Set();
  const items = [];
  let colorOff = 0;

  // Primero construir el mapa de grupos SHP igual que en cargarCapasLote
  // para saber qué capaIds van a ser SHP
  const _shpGrupoIds = new Set();
  const _shpItemsMap = {}; // capaId → {nombreDisplay, ts}
  for (const c of capas) {
    const _ext = (c.nombre || "").split(".").pop().toLowerCase();
    const _mt  = (c.mediaType || "").toLowerCase();
    const esShpBin = _mt.includes("shp") || _mt.includes("x-shapefile") || _ext === "shp";
    if (esShpBin) {
      const _base = _ext === "shp"
        ? c.nombre.replace(/\.shp$/i, "")
        : "shp_" + c.ts;
      const _capaId = `capa_shp_${_base.replace(/[^a-z0-9]/gi,"_")}`;
      _shpGrupoIds.add(_capaId);
      if (!_shpItemsMap[_capaId]) {
        _shpItemsMap[_capaId] = { nombreDisplay: c.nombre || _base, ts: c.ts };
      }
    }
  }

  for (const c of capas) {
    const ext  = (c.nombre || "").split(".").pop().toLowerCase();
    const mt   = (c.mediaType || "").toLowerCase();
    const base = c.nombre.replace(/\.[^.]+$/, "");
    const esShpBin = mt.includes("shp") || mt.includes("x-shapefile") || ext === "shp";
    const esAux    = mt.includes("shx") || mt.includes("dbf") || mt.includes("prj") ||
                     ["dbf","shx","prj"].includes(ext);

    if (esShpBin) {
      // Es un SHP — construir capaId igual que en cargarSHPEnMapa
      const shpBase  = ext === "shp" ? base : "shp_" + c.ts;
      const shpCapaId = `capa_shp_${shpBase.replace(/[^a-z0-9]/gi,"_")}`;
      const label    = c.nombre || shpBase;
      items.push({ tipo:"shp", base: shpBase, nombreDisplay: label,
                   color: CAPA_COLORES[colorOff++ % CAPA_COLORES.length],
                   capaId: shpCapaId });
    } else if (esAux) {
      // SHX/DBF/PRJ — ignorar visualmente (ya van implícitos con el SHP)
    } else {
      const icono    = CAPA_ICONO[c.subtipo] || "📁";
      const color    = CAPA_COLORES[colorOff++ % CAPA_COLORES.length];
      const capaId   = `capa_${items.length}`;
      const tieneGeo = esCapaGeografica(c);
      items.push({ tipo:"capa", capa:c, icono, color, capaId, tieneGeo });
    }
  }

  lista.innerHTML = items.map(it => {
    if (it.tipo === "shp") {
      const label = it.nombreDisplay || it.base;
      return `
        <div class="capa-item" onclick="toggleCapaSHP('${it.capaId}','${nombreEnc}')">
          <div style="width:10px;height:10px;border-radius:3px;background:${it.color};flex-shrink:0"></div>
          <div style="flex:1;min-width:0">
            <div style="font-size:12px;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
              title="${label}">📐 ${label}</div>
            <div style="font-size:10px;color:var(--muted2)">shapefile · gradiente automático</div>
          </div>
          <div class="capa-toggle on" id="toggle-${it.capaId}" title="Mostrar/ocultar"></div>
        </div>`;
    }
    const c = it.capa;
    return `
      <div class="capa-item" onclick="toggleCapa('${it.capaId}','${nombreEnc}',${capas.indexOf(c)})">
        <div style="width:10px;height:10px;border-radius:3px;background:${it.color};flex-shrink:0"></div>
        <div style="flex:1;min-width:0">
          <div style="font-size:12px;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
            title="${c.nombre}">${it.icono} ${c.nombre}</div>
          <div style="font-size:10px;color:var(--muted2)">${c.subtipo}${c.fuente?' · '+c.fuente:''}</div>
        </div>
        ${it.tieneGeo
          ? `<div class="capa-toggle on" id="toggle-${it.capaId}" title="Mostrar/ocultar en mapa"></div>`
          : `<span style="font-size:10px;color:var(--muted2)" title="Sin datos geográficos">—</span>`}
      </div>`;
  }).join("");
}

function esCapaGeografica(c) {
  const ext = (c.nombre||"").split(".").pop().toLowerCase();
  return ["geojson","json","csv","kml","shp","shapefile"].includes(ext) ||
         ["ndvi","shapefile","geojson","kml","csv","imagen_drone","imagen_sat"].includes(c.subtipo) ||
         !!c.contenido_texto || !!c.base64;
}

// ── Toggle capa en el mapa ────────────────────────────────
async function toggleCapa(capaId, nombreEnc, idx) {
  const toggle = document.getElementById(`toggle-${capaId}`);
  if (!toggle) return;

  const estaOn = toggle.classList.contains("on");

  if (estaOn) {
    // Ocultar
    (_capaLayers[capaId] || []).forEach(l => _mapa.removeLayer(l));
    delete _capaLayers[capaId];
    toggle.classList.remove("on");
    toggle.classList.add("off");
  } else {
    // Mostrar — recargar capa desde contexto (ya incluye contenido_texto y base64)
    toggle.classList.add("on");
    toggle.classList.remove("off");
    mostrarLoading("Cargando capa…");
    try {
      const ctx      = await Auth.get(`/api/lotes-maestro/${nombreEnc}/contexto`);
      const externas = ctx.capas?.externas || {};
      const todasCapas = Object.entries(externas).flatMap(([sub, cs]) =>
        cs.map(c => ({ ...c, subtipo: sub }))
      );
      // Buscar por capaId que coincida con índice o nombre
      const capa = todasCapas[idx];
      if (!capa) { toast("Capa no encontrada", "", "amber"); return; }

      const ext = (capa.nombre || "").split(".").pop().toLowerCase();
      if (["shp","dbf","shx","prj"].includes(ext)) {
        // No soportado en toggle individual por ahora
        toast("Recargá la página para ver el shapefile", "", "amber");
      } else {
        await cargarCapaEnMapa(capa, nombreEnc, capaId, idx);
      }
    } catch(e) {
      toast("Error cargando capa", e.message, "red");
    } finally {
      ocultarLoading();
    }
  }
}

// ── Toggle específico para capas SHP ─────────────────────
async function toggleCapaSHP(capaId, nombreEnc) {
  const toggle = document.getElementById(`toggle-${capaId}`);
  if (!toggle) return;

  const estaOn = toggle.classList.contains("on");

  if (estaOn) {
    // Ocultar capas del SHP
    (_capaLayers[capaId] || []).forEach(l => _mapa.removeLayer(l));
    delete _capaLayers[capaId];
    toggle.classList.remove("on");
    toggle.classList.add("off");
    // Remover leyenda
    document.getElementById(`leyenda-${capaId}`)?.remove();
  } else {
    // Mostrar — re-ejecutar carga del SHP desde el contexto
    toggle.classList.add("on");
    toggle.classList.remove("off");
    mostrarLoading("Cargando shapefile…");
    try {
      const ctx      = await Auth.get(`/api/lotes-maestro/${nombreEnc}/contexto`);
      const externas = ctx.capas?.externas || {};
      const todasCapas = Object.entries(externas).flatMap(([sub, cs]) =>
        cs.map(c => ({ ...c, subtipo: sub }))
      );

      // Reconstruir shpGrupos igual que en cargarCapasLote
      const shpGrupos = {};
      for (const capa of todasCapas) {
        const _ext = (capa.nombre || "").split(".").pop().toLowerCase();
        const _mt  = (capa.mediaType || "").toLowerCase();
        const esShpBin = _mt.includes("shp") || _mt.includes("x-shapefile") || _ext === "shp";
        const esShx    = _mt.includes("shx") || _ext === "shx";
        const esDbf    = _mt.includes("dbf") || _ext === "dbf";
        const esPrj    = _mt.includes("prj") || _ext === "prj";
        if (esShpBin || esShx || esDbf || esPrj) {
          const _base = _ext === "shp" ? capa.nombre.replace(/\.shp$/i,"") : "shp_" + capa.ts;
          if (!shpGrupos[_base]) shpGrupos[_base] = { nombreDisplay: capa.nombre };
          if (esShpBin)  shpGrupos[_base].shp = capa;
          else if (esShx) shpGrupos[_base].shx = capa;
          else if (esDbf) shpGrupos[_base].dbf = capa;
          else if (esPrj) shpGrupos[_base].prj = capa;
        }
      }
      // Reagrupar por proximidad temporal
      const shpArr = Object.entries(shpGrupos);
      for (const [base, grp] of shpArr) {
        if (!grp.shp) continue;
        for (const [base2, grp2] of shpArr) {
          if (base2 === base || grp2.shp) continue;
          const auxTs = (grp2.shx || grp2.dbf || grp2.prj)?.ts || 0;
          if (Math.abs(grp.shp.ts - auxTs) < 60000) {
            if (grp2.shx && !grp.shx) grp.shx = grp2.shx;
            if (grp2.dbf && !grp.dbf) grp.dbf = grp2.dbf;
            if (grp2.prj && !grp.prj) grp.prj = grp2.prj;
            delete shpGrupos[base2];
          }
        }
      }
      // Encontrar el grupo que corresponde a este capaId
      for (const [base, grp] of Object.entries(shpGrupos)) {
        const thisCapaId = `capa_shp_${base.replace(/[^a-z0-9]/gi,"_")}`;
        if (thisCapaId === capaId && grp.shp?.base64) {
          await cargarSHPEnMapa(base, grp);
          break;
        }
      }
    } catch(e) {
      toast("Error al recargar shapefile", e.message, "red");
      toggle.classList.remove("on");
      toggle.classList.add("off");
    } finally {
      ocultarLoading();
    }
  }
}

// ── SHP: convertir UTM→WGS84 vía backend y dibujar ──────
async function cargarSHPEnMapa(base, grp) {
  const color       = CAPA_COLORES[_colorIdx % CAPA_COLORES.length];
  const capaId      = `capa_shp_${base.replace(/[^a-z0-9]/gi,"_")}`;
  const labelMostrar = grp.nombreDisplay || grp.shp?.nombre || base;
  _colorIdx++;

  try {
    mostrarLoading(`Convirtiendo ${base}.shp…`);

    // Leer PRJ como texto si está disponible
    let prjText = null;
    if (grp.prj) {
      prjText = grp.prj.contenido_texto || (grp.prj.base64
        ? atob(grp.prj.base64)
        : null);
    }

    const body = {
      shp: grp.shp.base64,
      shx: grp.shx?.base64 || null,
      dbf: grp.dbf?.base64 || null,
      prj: prjText,
    };

    const geojson = await Auth.post("/api/lotes-maestro/shp-to-geojson", body);
    ocultarLoading();

    if (!geojson.features?.length) {
      toast(`${base}.shp`, "Sin features para mostrar", "amber");
      return;
    }

    // Detectar si es nube de puntos con valor numérico → mapa de calor por color
    // Los valores del DBF pueden venir como strings — parsear a número
    const firstProps = geojson.features[0]?.properties || {};
    let valKey = null;
    for (const k of Object.keys(firstProps)) {
      const v = parseFloat(firstProps[k]);
      if (!isNaN(v)) { valKey = k; break; }
    }

    // Detectar tipo de geometría dominante
    const geomTipo = geojson.features[0]?.geometry?.type || "Point";
    const esPoligono = geomTipo.includes("Polygon");
    const esLinea    = geomTipo.includes("LineString") || geomTipo.includes("Polyline");

    function gradColor(t) {
      const r = Math.round(t < 0.5 ? t*2*50 : 50 + (t-0.5)*2*205);
      const g = Math.round(t < 0.5 ? 100 + t*2*155 : 255 - (t-0.5)*2*200);
      const b = Math.round(t < 0.5 ? 200 - t*2*200 : 0);
      return `rgb(${r},${g},${b})`;
    }

    let layer;
    if (valKey && geojson.features.length > 1) {
      const vals   = geojson.features
        .map(f => parseFloat(f.properties[valKey]))
        .filter(v => !isNaN(v));
      const minVal = Math.min(...vals);
      const maxVal = Math.max(...vals);
      const range  = maxVal - minVal || 1;

      console.log(`[SHP gradiente] tipo=${geomTipo} campo="${valKey}" min=${minVal.toFixed(4)} max=${maxVal.toFixed(4)} n=${vals.length}`);

      layer = L.geoJSON(geojson, {
        // Para polígonos: fill por gradiente de color
        style: esPoligono ? (feature) => {
          const raw = parseFloat(feature.properties[valKey]);
          const t   = isNaN(raw) ? 0 : Math.max(0, Math.min(1, (raw - minVal) / range));
          const clr = gradColor(t);
          return { color: clr, weight: 0.5, opacity: 0.9, fillColor: clr, fillOpacity: 0.75 };
        } : undefined,
        // Para puntos: circleMarker con gradiente
        pointToLayer: !esPoligono && !esLinea ? (feature, latlng) => {
          const raw = parseFloat(feature.properties[valKey]);
          const t   = isNaN(raw) ? 0 : Math.max(0, Math.min(1, (raw - minVal) / range));
          const clr = gradColor(t);
          return L.circleMarker(latlng, {
            radius: 4, color: clr, fillColor: clr,
            fillOpacity: 0.85, weight: 0,
          });
        } : undefined,
        onEachFeature: (feature, layer) => {
          const raw = parseFloat(feature.properties[valKey]);
          const val = isNaN(raw) ? feature.properties[valKey] : raw;
          const t   = isNaN(raw) ? 0 : Math.max(0, Math.min(1, (raw - minVal) / range));
          const clr = gradColor(t);
          layer.bindPopup(
            `<div style="font-size:12px;min-width:100px">
              <b style="color:${clr}">${valKey}:</b> ${typeof val==="number" ? val.toFixed(4) : val}
              ${Object.entries(feature.properties).filter(([k])=>k!==valKey).slice(0,3)
                .map(([k,v])=>`<br><b>${k}:</b> ${v}`).join("")}
            </div>`
          );
        },
      }).addTo(_mapa);

      // Agregar leyenda de gradiente
      const leyenda = document.getElementById("leyenda-capas");
      leyenda.innerHTML += `
        <div id="leyenda-${capaId}" style="margin-top:6px">
          <div style="font-size:10px;color:rgba(255,255,255,0.5);margin-bottom:3px">${labelMostrar} (${valKey})</div>
          <div style="display:flex;align-items:center;gap:4px">
            <span style="font-size:9px;color:rgba(255,255,255,0.4)">${minVal.toFixed(2)}</span>
            <div style="width:60px;height:6px;border-radius:3px;
                        background:linear-gradient(to right,rgb(0,100,200),rgb(50,255,50),rgb(255,55,0))"></div>
            <span style="font-size:9px;color:rgba(255,255,255,0.4)">${maxVal.toFixed(2)}</span>
          </div>
        </div>`;

    } else {
      // Sin campo numérico → color fijo del panel
      // Para polígonos: fill semitransparente; para puntos: circleMarker
      layer = L.geoJSON(geojson, {
        style: esPoligono ? () => ({ color, weight:1.5, opacity:0.85, fillColor:color, fillOpacity:0.35 }) : undefined,
        pointToLayer: !esPoligono ? (feature, latlng) => L.circleMarker(latlng, {
          radius: 4, color, fillColor: color, fillOpacity: 0.85, weight: 1,
        }) : undefined,
        onEachFeature: (feature, l) => {
          if (feature.properties) {
            const props = Object.entries(feature.properties).slice(0,5)
              .map(([k,v]) => `<b>${k}:</b> ${typeof v==="number" ? v.toFixed(4) : v}`)
              .join("<br>");
            if (props) l.bindPopup(`<div style="font-size:12px">${props}</div>`);
          }
        },
      }).addTo(_mapa);

      const leyenda = document.getElementById("leyenda-capas");
      leyenda.innerHTML += `
        <div style="display:flex;align-items:center;gap:8px" id="leyenda-${capaId}">
          <span style="display:inline-block;width:14px;height:3px;background:${color};border-radius:2px"></span>
          <span style="color:rgba(255,255,255,0.7)">${labelMostrar}</span>
        </div>`;
    }

    _capaLayers[capaId] = [layer];

    // Ajustar bounds SOLO si no hay capas base del lote (boundary) y es el primer SHP
    if (!_layers.length || !_primerBoundsCargado) {
      try {
        const b = layer.getBounds();
        // Verificar que los bounds son WGS84 válidos antes de hacer fitBounds
        const ne = b.getNorthEast();
        if (ne.lat >= -90 && ne.lat <= 90 && ne.lng >= -180 && ne.lng <= 180) {
          _mapa.fitBounds(b, { padding: [30, 30], maxZoom: 18 });
          _primerBoundsCargado = true;
        }
      } catch {}
    }

    toast(`✓ ${labelMostrar}`, `${geojson.features.length} features cargados`, "lime");

  } catch(e) {
    ocultarLoading();
    console.error("[cargarSHP]", base, e.message);
    toast(`Error en ${base}.shp`, e.message, "red");
  }
}

// ── Parsear y dibujar una capa en el mapa ─────────────────
async function cargarCapaEnMapa(capa, nombreEnc, capaId, colorOffset) {
  console.log("[cargarCapaEnMapa]", capa.nombre, "| texto:", !!capa.contenido_texto, "| b64:", !!capa.base64);
  const color = CAPA_COLORES[(colorOffset !== undefined ? colorOffset : _colorIdx) % CAPA_COLORES.length];
  if (colorOffset === undefined) _colorIdx++;
  if (!capaId) {
    const idx = Object.keys(_capaLayers).length;
    capaId = `capa_${idx}`;
  }

  // Priorizar contenido_texto; si no hay, intentar decodificar base64 para formatos de texto
  let contenido = capa.contenido_texto || null;
  if (!contenido && capa.base64) {
    const _mt  = (capa.mediaType || "").toLowerCase();
    const _ext = (capa.nombre || "").split(".").pop().toLowerCase();
    if (["geojson","json","csv","kml","txt"].includes(_ext) ||
        _mt.includes("json") || _mt.includes("csv") || _mt.includes("kml") || _mt.includes("text")) {
      try { contenido = atob(capa.base64); } catch(e) { console.warn("[cargarCapaEnMapa] atob falló:", e.message); }
    }
  }
  if (!contenido) {
    console.warn("[cargarCapaEnMapa] Sin contenido para dibujar:", capa.nombre, "mediaType:", capa.mediaType, "b64:", !!capa.base64);
    return;
  }

  const ext = (capa.nombre || "").split(".").pop().toLowerCase();
  let leafletLayers = [];

  try {
    // ── GeoJSON / JSON ────────────────────────────────────
    if (ext === "geojson" || ext === "json" || capa.subtipo === "geojson") {
      const gj = JSON.parse(contenido);
      const layer = L.geoJSON(gj, {
        style: () => ({
          color,
          weight: 1.5,
          opacity: 0.85,
          fillColor: color,
          fillOpacity: 0.25,
        }),
        pointToLayer: (feature, latlng) => L.circleMarker(latlng, {
          radius: 4, color, fillColor: color, fillOpacity: 0.8, weight: 1,
        }),
        onEachFeature: (feature, layer) => {
          if (feature.properties) {
            const props = Object.entries(feature.properties)
              .filter(([,v]) => v !== null && v !== undefined)
              .slice(0, 5)
              .map(([k, v]) => `<b>${k}:</b> ${typeof v === "number" ? v.toFixed(4) : v}`)
              .join("<br>");
            if (props) layer.bindPopup(`<div style="font-size:12px;min-width:120px">${props}</div>`);
          }
        },
      }).addTo(_mapa);
      leafletLayers.push(layer);

      // Ajustar bounds si no hay lote base
      if (!_layers.length) {
        try { _mapa.fitBounds(layer.getBounds(), { padding: [30, 30], maxZoom: 18 }); } catch {}
      }
    }

    // ── KML ────────────────────────────────────────────────
    else if (ext === "kml") {
      const coordsMatch = contenido.match(/<coordinates>([\s\S]*?)<\/coordinates>/gi) || [];
      coordsMatch.forEach(block => {
        const pts = block.replace(/<\/?coordinates>/gi, "").trim()
          .split(/\s+/).map(c => {
            const [lon, lat] = c.split(",").map(parseFloat);
            return (!isNaN(lat) && !isNaN(lon)) ? [lat, lon] : null;
          }).filter(Boolean);
        if (pts.length > 1) {
          leafletLayers.push(L.polyline(pts, { color, weight: 2, opacity: 0.85 }).addTo(_mapa));
        } else if (pts.length === 1) {
          leafletLayers.push(L.circleMarker(pts[0], { radius: 5, color, fillColor: color, fillOpacity: 0.85, weight: 1 }).addTo(_mapa));
        }
      });
    }

    // ── CSV con lat/lon ───────────────────────────────────
    else if (ext === "csv") {
      const lines   = contenido.split(/\r?\n/).filter(l => l.trim());
      const sep     = lines[0].includes("\t") ? "\t" : ",";
      const headers = lines[0].split(sep).map(h => h.replace(/^"|"$/g, "").trim().toLowerCase());
      const latCol  = headers.findIndex(h => ["lat","latitude","latitud"].includes(h));
      const lonCol  = headers.findIndex(h => ["lon","lng","long","longitude","longitud"].includes(h));

      if (latCol >= 0 && lonCol >= 0) {
        const pts = [];
        lines.slice(1).forEach(line => {
          const cols = line.split(sep).map(v => v.replace(/^"|"$/g, "").trim());
          const lat  = parseFloat(cols[latCol]);
          const lon  = parseFloat(cols[lonCol]);
          if (!isNaN(lat) && !isNaN(lon)) {
            const props = headers.map((h, i) => `<b>${h}:</b> ${cols[i] || "–"}`).join("<br>");
            const m = L.circleMarker([lat, lon], {
              radius: 3, color, fillColor: color, fillOpacity: 0.75, weight: 0.5,
            }).addTo(_mapa);
            m.bindPopup(`<div style="font-size:12px">${props}</div>`);
            leafletLayers.push(m);
            pts.push([lat, lon]);
          }
        });
        if (pts.length && !_layers.length) {
          try { _mapa.fitBounds(pts, { padding: [30, 30], maxZoom: 18 }); } catch {}
        }
      } else {
        toast(`CSV "${capa.nombre}" sin columnas lat/lon`, "No se puede dibujar en el mapa", "amber");
        return;
      }
    }

  } catch(e) {
    console.error("[mapa/capa]", capa.nombre, e.message);
    toast(`Error al dibujar "${capa.nombre}"`, e.message, "red");
    return;
  }

  if (!leafletLayers.length) return;

  _capaLayers[capaId] = leafletLayers;

  // Agregar a leyenda
  const leyenda = document.getElementById("leyenda-capas");
  const nombre  = capa.nombre.length > 22 ? capa.nombre.slice(0, 20) + "…" : capa.nombre;
  leyenda.innerHTML += `
    <div style="display:flex;align-items:center;gap:8px" id="leyenda-${capaId}">
      <span style="display:inline-block;width:14px;height:3px;background:${color};border-radius:2px"></span>
      <span style="color:rgba(255,255,255,0.7)">${nombre}</span>
    </div>`;
}

// ── Limpiar ────────────────────────────────────────────────
function limpiarMapa() {
  _layers.forEach(l => _mapa?.removeLayer(l));
  _layers = [];
  Object.values(_capaLayers).forEach(ls => ls.forEach(l => _mapa?.removeLayer(l)));
  _capaLayers = {};
  _colorIdx   = 0;
  _loteActual = null;
  _primerBoundsCargado = false;
  document.getElementById("lote-search").value          = "";
  document.getElementById("pill-activo").style.display   = "none";
  document.getElementById("mapa-empty").style.display    = "flex";
  document.getElementById("panel-capas").style.display   = "none";
  document.getElementById("leyenda-capas").innerHTML     = "";
  document.getElementById("mapa-estado").textContent     = _lista.length + " lote" + (_lista.length !== 1 ? "s" : "");
}

// ── Loading helpers ────────────────────────────────────────
function mostrarLoading(txt) {
  document.getElementById("loading-texto").textContent   = txt || "Cargando…";
  document.getElementById("mapa-loading").style.display  = "flex";
}
function ocultarLoading() {
  document.getElementById("mapa-loading").style.display  = "none";
}

// ── Cerrar dropdown ────────────────────────────────────────
document.addEventListener("click", e => {
  if (!e.target.closest("#lote-search") && !e.target.closest("#search-dropdown"))
    cerrarDropdown();
});

document.addEventListener("DOMContentLoaded", () => {
  initMapa();
  recargarLista();
  if (typeof OrbitNDVI !== 'undefined') OrbitNDVI.init('ndvi-controls');
});
</script>
