<%# pages/aog.ejs — Piloto Agro Parallel · Sincronización + historial + restauración %>

<div class="page-header">
  <div>
    <h2>Piloto Agro Parallel</h2>
    <p>Archivos sincronizados · Historial de versiones · Restauración</p>
  </div>
  <a href="/aog" class="btn">↻ Actualizar</a>
</div>

<!-- KPIs -->
<div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:20px">
  <div class="kpi lime">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Lotes sincronizados</div>
    <div class="kpi-val"><%= stats.lotes_count || 0 %></div>
    <div class="kpi-delta">desde Piloto AP</div>
  </div>
  <div class="kpi blue">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Archivos totales</div>
    <div class="kpi-val"><%= stats.total_archivos || 0 %></div>
    <div class="kpi-delta">Fields + configs</div>
  </div>
  <div class="kpi <%= stats.tiene_vehicle ? 'lime' : 'red' %>">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Vehicle.xml</div>
    <div class="kpi-val" style="font-size:18px"><%= stats.tiene_vehicle ? '✓' : '✗' %></div>
    <div class="kpi-delta"><%= stats.tiene_vehicle ? 'Sincronizado' : 'No encontrado' %></div>
  </div>
  <div class="kpi teal">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Último sync</div>
    <div class="kpi-val" style="font-size:14px;line-height:2.2">
      <%= stats.ultimo_sync ? new Date(stats.ultimo_sync).toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}) : '–' %>
    </div>
    <div class="kpi-delta"><%= stats.ultimo_sync ? fmtDate(stats.ultimo_sync) : 'Sin datos' %></div>
  </div>
</div>

<div class="g2">

  <!-- Lotes -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">🌾 Lotes de Piloto AP</span>
      <span style="font-size:11px;color:var(--muted2)"><%= lotes.length %> lote<%= lotes.length!==1?'s':'' %></span>
    </div>
    <% if (!lotes || !lotes.length) { %>
      <div class="empty-state" style="padding:30px">
        <span class="icon">📂</span>
        <p>Sin lotes sincronizados.<br>Verificá que el agente esté corriendo<br>en el tractor.</p>
      </div>
    <% } else { %>
    <div style="max-height:460px;overflow-y:auto">
      <% lotes.forEach(l => { %>
      <div style="display:flex;align-items:center;gap:12px;padding:11px 16px;border-bottom:1px solid rgba(255,255,255,0.04);cursor:pointer"
        onclick="verLote('<%= encodeURIComponent(l.nombre) %>')">
        <div style="width:34px;height:34px;border-radius:8px;background:var(--lime-dim);border:1px solid rgba(184,255,60,0.2);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">🌾</div>
        <div style="flex:1;min-width:0">
          <div class="td-main"><%= l.nombre %></div>
          <div style="display:flex;gap:6px;margin-top:3px;flex-wrap:wrap">
            <% if (l.tiene_boundary) { %><span class="badge badge-lime" style="font-size:9px">Boundary</span><% } %>
            <% if (l.tiene_field)    { %><span class="badge badge-blue" style="font-size:9px">GPS</span><% } %>
            <span class="badge badge-gray" style="font-size:9px"><%= l.archivos.length %> archivos</span>
          </div>
        </div>
        <div class="td-dim" style="font-size:10px;text-align:right;white-space:nowrap"><%= fmtDate(l.ts_ultimo) %></div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <!-- Configs y vehículo -->
  <div style="display:flex;flex-direction:column;gap:14px">

    <!-- Vehicle.xml con historial -->
    <div class="card">
      <div class="card-head">
        <span class="card-title">🚜 Configuración del vehículo</span>
        <% if (stats.tiene_vehicle) { %>
        <button class="btn btn-sm btn-ghost" onclick="verHistorial('vehicle.xml')">Historial →</button>
        <% } %>
      </div>
      <div class="card-body">
        <% if (!stats.tiene_vehicle) { %>
          <div style="font-size:12px;color:var(--muted2)">
            <code style="font-family:var(--font-m);font-size:11px;color:var(--amber)">vehicle.xml</code>
            no sincronizado.<br>Guardá el vehículo en el Piloto.
          </div>
        <% } else { %>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="flex:1;font-size:12px;color:var(--muted2);line-height:1.8">
              <span style="color:var(--lime)">✓</span> vehicle.xml activo<br>
              <% if (stats.tipos && stats.tipos['tool_config']) { %>
              <span style="color:var(--lime)">✓</span> tool.xml activo
              <% } %>
            </div>
            <button class="btn btn-sm btn-ghost" onclick="verVehicle()">Ver XML</button>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Tipos de archivos -->
    <div class="card">
      <div class="card-head"><span class="card-title">📊 Archivos por tipo</span></div>
      <div class="card-body" style="padding:12px 16px">
        <% const TIPOS = {
          field_origin:      ['📍','Field.txt (origen GPS)'],
          boundary:          ['⬡','Boundary.txt'],
          boundary_kml:      ['🗺','KML boundaries'],
          headland:          ['↩','HeadLand.txt'],
          sections_coverage: ['▦','Sections.txt'],
          ab_line:           ['⟺','Líneas AB'],
          vehicle_config:    ['🚜','vehicle.xml'],
          tool_config:       ['⚙','tool.xml'],
          config_xml:        ['📄','Configs XML'],
          field_file:        ['📁','Otros'],
        }; %>
        <% if (stats.tipos && Object.keys(stats.tipos).length) { %>
          <% Object.entries(stats.tipos).forEach(([t,n]) => {
            const [icon, label] = TIPOS[t] || ['📄', t];
          %>
          <div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
            <span style="font-size:13px;width:20px;text-align:center"><%= icon %></span>
            <span style="font-size:12px;color:var(--muted2);flex:1"><%= label %></span>
            <span style="font-family:var(--font-m);font-size:12px;color:var(--lime)"><%= n %></span>
          </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:12px;color:var(--muted2)">Sin datos</div>
        <% } %>
      </div>
    </div>

    <!-- Info agente -->
    <div class="card">
      <div class="card-head"><span class="card-title">⚙ Agente tractor</span></div>
      <div class="card-body">
        <div style="font-size:11px;color:var(--muted2);line-height:2">
          Ruta del Piloto configurada:<br>
          <code style="font-family:var(--font-m);font-size:11px;color:var(--lime)"><%= aogPath %></code>
        </div>
        <div style="margin-top:10px;padding:10px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;font-size:11px;color:var(--muted2);line-height:1.8">
          El agente (<code style="color:var(--amber)">orbitx-tractor-agent</code>) corre
          en el tractor junto al Piloto y sube cada archivo automáticamente.
          Si el servidor no tiene conexión, los archivos se encolan y suben solos al reconectar.
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ MODAL: detalle de lote ═══ -->
<div class="modal-backdrop" id="modal-lote-aog">
  <div class="modal" style="width:560px;max-height:88vh;display:flex;flex-direction:column">
    <div class="modal-title" id="modal-aog-nombre">–</div>
    <div class="modal-sub">Archivos del lote en Piloto AP</div>
    <div id="modal-aog-content" style="margin-top:16px;overflow-y:auto;flex:1"></div>
    <button class="btn btn-ghost" style="width:100%;margin-top:14px;flex-shrink:0" onclick="closeModal('modal-lote-aog')">Cerrar</button>
  </div>
</div>

<!-- ═══ MODAL: vehicle XML ═══ -->
<div class="modal-backdrop" id="modal-vehicle">
  <div class="modal" style="width:620px;max-height:88vh;display:flex;flex-direction:column">
    <div class="modal-title">vehicle.xml</div>
    <div class="modal-sub" id="modal-v-sub">Configuración activa del vehículo</div>
    <pre id="modal-vehicle-content"
      style="margin-top:14px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px;font-family:var(--font-m);font-size:11px;color:var(--text);overflow:auto;flex:1;white-space:pre-wrap;word-break:break-all;min-height:100px">
    </pre>
    <button class="btn btn-ghost" style="width:100%;margin-top:14px;flex-shrink:0" onclick="closeModal('modal-vehicle')">Cerrar</button>
  </div>
</div>

<!-- ═══ MODAL: historial de versiones ═══ -->
<div class="modal-backdrop" id="modal-historial">
  <div class="modal" style="width:640px;max-height:88vh;display:flex;flex-direction:column">
    <div class="modal-title">Historial de versiones</div>
    <div class="modal-sub" id="modal-h-archivo" style="font-family:var(--font-m);color:var(--lime)">–</div>
    <div id="modal-historial-list" style="margin-top:14px;overflow-y:auto;flex:1;display:flex;flex-direction:column;gap:8px"></div>
    <button class="btn btn-ghost" style="width:100%;margin-top:14px;flex-shrink:0" onclick="closeModal('modal-historial')">Cerrar</button>
  </div>
</div>

<!-- ═══ MODAL: comparar versión ═══ -->
<div class="modal-backdrop" id="modal-version">
  <div class="modal" style="width:680px;max-height:88vh;display:flex;flex-direction:column">
    <div class="modal-title" id="modal-ver-titulo">Versión del –</div>
    <div class="modal-sub" id="modal-ver-sub">–</div>
    <pre id="modal-ver-content"
      style="margin-top:14px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px;font-family:var(--font-m);font-size:11px;color:var(--text);overflow:auto;flex:1;white-space:pre-wrap;word-break:break-all;min-height:120px">
    </pre>
    <div style="display:flex;gap:8px;margin-top:14px;flex-shrink:0">
      <button class="btn btn-ghost" style="flex:1" onclick="closeModal('modal-version')">Cancelar</button>
      <button id="btn-restaurar" class="btn btn-primary" style="flex:1" onclick="restaurar()">
        ↩ Usar esta versión en el tractor
      </button>
    </div>
  </div>
</div>

<script>
let _historialActual = null; // { ruta_rel, histId }

// ─── Ver detalle de un lote ────────────────────────────────
async function verLote(nombreEnc) {
  const nombre = decodeURIComponent(nombreEnc);
  document.getElementById('modal-aog-nombre').textContent = nombre;
  document.getElementById('modal-aog-content').innerHTML  = '<div class="loading"><span class="spinner"></span></div>';
  openModal('modal-lote-aog');
  try {
    const d   = await Auth.get('/api/aog/lotes/' + nombreEnc);
    const archivos = [d.boundary, d.headland, d.sections, d.kml, ...(d.ab_lines||[]), ...(d.otros||[])].filter(Boolean);
    let html = '';

    if (d.origen) {
      html += `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:10px">
        <div style="font-size:10px;color:var(--muted2);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px">Origen GPS · Field.txt</div>
        <button class="btn btn-sm btn-ghost" onclick="verHistorialRuta('${encodeURIComponent(d.origen.ruta_rel)}', '${d.origen.nombre}')">Ver historial →</button>
      </div>`;
    }

    if (archivos.length) {
      html += `<div style="font-size:10px;color:var(--muted2);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Archivos</div>`;
      archivos.forEach(a => {
        const kb = (a.tamaño/1024).toFixed(1);
        html += `
          <div style="display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
            <span style="font-family:var(--font-m);font-size:12px;color:var(--lime);flex:1">${a.nombre}</span>
            <span style="font-size:10px;color:var(--muted2)">${kb} KB</span>
            <button class="btn btn-sm btn-ghost" onclick="verHistorialRuta('${encodeURIComponent(a.ruta_rel)}','${a.nombre}')">Historial</button>
            <button class="btn btn-sm btn-ghost" onclick="descargar('${encodeURIComponent(a.ruta_rel)}','${a.nombre}')">↓</button>
          </div>`;
      });
    }
    document.getElementById('modal-aog-content').innerHTML = html || '<div class="td-dim">Sin archivos disponibles</div>';
  } catch(e) {
    document.getElementById('modal-aog-content').innerHTML = `<div class="alert error show">${e.message}</div>`;
  }
}

// ─── Ver vehicle.xml ──────────────────────────────────────
async function verVehicle() {
  document.getElementById('modal-vehicle-content').textContent = 'Cargando...';
  document.getElementById('modal-v-sub').textContent = 'Configuración activa del vehículo';
  openModal('modal-vehicle');
  try {
    const d = await Auth.get('/api/aog/vehicle');
    document.getElementById('modal-v-sub').textContent = `Sincronizado: ${new Date(d.ts).toLocaleString('es-AR')} · ${d.device_id||'–'}`;
    document.getElementById('modal-vehicle-content').textContent = d.contenido || 'Sin contenido';
  } catch(e) {
    document.getElementById('modal-vehicle-content').textContent = 'Error: ' + e.message;
  }
}

// ─── Ver historial de un archivo ─────────────────────────
async function verHistorial(nombre) {
  // Para vehicle.xml buscar la ruta relativa
  await verHistorialRuta(encodeURIComponent('vehicle.xml'), nombre);
}

async function verHistorialRuta(rutaEnc, nombre) {
  document.getElementById('modal-h-archivo').textContent = nombre;
  document.getElementById('modal-historial-list').innerHTML = '<div class="loading"><span class="spinner"></span></div>';
  openModal('modal-historial');
  try {
    const lista = await Auth.get('/api/aog/historial?ruta=' + rutaEnc);
    if (!lista.length) {
      document.getElementById('modal-historial-list').innerHTML =
        '<div class="empty-state" style="padding:30px"><p>Sin versiones históricas para este archivo</p></div>';
      return;
    }
    document.getElementById('modal-historial-list').innerHTML = lista.map((v, i) => `
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:14px;display:flex;align-items:center;gap:12px">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--surface);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-family:var(--font-m);font-size:11px;color:var(--muted2);flex-shrink:0">${i===0?'<span style="color:var(--lime)">+1</span>':'v'+(lista.length-i)}</div>
        <div style="flex:1">
          <div style="font-size:13px;font-weight:500;color:#fff">${new Date(v.ts).toLocaleString('es-AR')}</div>
          <div style="font-size:11px;color:var(--muted2);margin-top:2px">
            ${v.device_id||'–'} · ${v.tamaño ? (v.tamaño/1024).toFixed(1)+' KB' : '–'}
          </div>
        </div>
        <div style="display:flex;gap:6px">
          <button class="btn btn-sm btn-ghost" onclick="verContenidoVersion('${v._id}', '${new Date(v.ts).toLocaleString('es-AR')}', '${nombre}')">Ver</button>
        </div>
      </div>`).join('');
  } catch(e) {
    document.getElementById('modal-historial-list').innerHTML = `<div class="alert error show">${e.message}</div>`;
  }
}

// ─── Ver contenido de una versión ────────────────────────
async function verContenidoVersion(histId, fechaStr, nombre) {
  _historialActual = { histId, nombre };
  document.getElementById('modal-ver-titulo').textContent = 'Versión del ' + fechaStr;
  document.getElementById('modal-ver-sub').textContent    = nombre;
  document.getElementById('modal-ver-content').textContent = 'Cargando...';
  document.getElementById('btn-restaurar').disabled = false;
  document.getElementById('btn-restaurar').textContent = '↩ Usar esta versión en el tractor';
  openModal('modal-version');
  try {
    const d = await Auth.get('/api/aog/historial/' + histId + '/contenido');
    document.getElementById('modal-ver-content').textContent = d.contenido || '(vacío)';
  } catch(e) {
    document.getElementById('modal-ver-content').textContent = 'Error: ' + e.message;
  }
}

// ─── Restaurar versión ────────────────────────────────────
async function restaurar() {
  if (!_historialActual) return;
  const { histId, nombre } = _historialActual;
  if (!confirm(`¿Restaurar "${nombre}" a esta versión?\n\nEl agente del tractor descargará el archivo automáticamente en el próximo ciclo de sync.`)) return;

  const btn = document.getElementById('btn-restaurar');
  btn.disabled = true;
  btn.textContent = 'Restaurando...';

  try {
    const d = await Auth.post('/api/aog/historial/' + histId + '/restaurar', {});
    toast('✓ Versión restaurada', d.mensaje || '', 'lime');
    closeModal('modal-version');
    closeModal('modal-historial');
  } catch(e) {
    toast('✗ Error al restaurar', e.message, 'red');
    btn.disabled = false;
    btn.textContent = '↩ Usar esta versión en el tractor';
  }
}

// ─── Descargar archivo ────────────────────────────────────
async function descargar(rutaEnc, nombre) {
  try {
    const d    = await Auth.get('/api/aog/archivo?ruta=' + rutaEnc);
    const blob = new Blob([d.contenido], { type:'text/plain;charset=utf-8' });
    const a    = document.createElement('a');
    a.href     = URL.createObjectURL(blob);
    a.download = nombre;
    a.click();
    URL.revokeObjectURL(a.href);
  } catch(e) { toast('✗ Error', e.message, 'red'); }
}
</script>
