<%# pages/vistax.ejs — Panel VistaX: lotes de siembra + mapa de densidad %>

<div class="page-header">
  <div>
    <h2>VistaX — Siembra</h2>
    <p>Lotes sincronizados · Densidad por surco · Semillas georeferenciadas</p>
  </div>
  <div style="display:flex;gap:8px;align-items:center">
    <div id="vx-estado" style="font-size:11px;color:var(--muted2)">Cargando...</div>
    <a href="/vistax" class="btn">↻ Actualizar</a>
  </div>
</div>

<!-- KPIs -->
<div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:20px">
  <div class="kpi lime">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Lotes sincronizados</div>
    <div class="kpi-val" id="kpi-lotes">–</div>
    <div class="kpi-delta">desde VistaX</div>
  </div>
  <div class="kpi blue">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Con mapa de densidad</div>
    <div class="kpi-val" id="kpi-con-densidad">–</div>
    <div class="kpi-delta">GeoJSON disponible</div>
  </div>
  <div class="kpi teal">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Con semillas georreferenciadas</div>
    <div class="kpi-val" id="kpi-con-semillas">–</div>
    <div class="kpi-delta">seed_recorder</div>
  </div>
  <div class="kpi <%= typeof stats !== 'undefined' && stats.tiene_perfiles ? 'lime' : 'red' %>">
    <div class="kpi-shine"></div>
    <div class="kpi-label">Perfil de máquina</div>
    <div class="kpi-val" style="font-size:18px">
      <%= typeof stats !== 'undefined' && stats.tiene_perfiles ? '✓' : '✗' %>
    </div>
    <div class="kpi-delta">configuración sincronizada</div>
  </div>
</div>

<div class="g2">

  <!-- Lista de lotes -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">Lotes de siembra</span>
      <span style="font-size:11px;color:var(--muted2)" id="total-lotes">–</span>
    </div>
    <div id="lista-lotes" style="max-height:520px;overflow-y:auto">
      <div class="loading"><span class="spinner"></span></div>
    </div>
  </div>

  <!-- Mapa -->
  <div style="display:flex;flex-direction:column;gap:14px">

    <div class="card" style="flex:1">
      <div class="card-head">
        <span class="card-title" id="mapa-titulo">Seleccioná un lote</span>
        <div style="display:flex;gap:6px">
          <button class="btn btn-sm btn-ghost" id="btn-toggle-semillas" onclick="toggleCapaSemillas()" style="display:none">
            Semillas
          </button>
          <button class="btn btn-sm btn-ghost" id="btn-export" onclick="exportarGeoJSON()" style="display:none">
            ↓ GeoJSON
          </button>
        </div>
      </div>

      <div style="position:relative;border-radius:0 0 var(--radius) var(--radius);overflow:hidden">
        <div id="vx-mapa" style="height:420px;background:var(--surface2)"></div>

        <!-- Leyenda -->
        <div id="vx-leyenda" style="display:none;position:absolute;bottom:10px;left:10px;background:rgba(0,0,0,0.75);border-radius:8px;padding:10px 14px;z-index:1000;font-size:11px;color:#fff;line-height:2">
          <div style="display:flex;align-items:center;gap:8px"><span style="display:inline-block;width:50px;height:6px;background:linear-gradient(to right,#ff1744,#ffb300,#ffea00,#00e676);border-radius:3px"></span></div>
          <div style="display:flex;justify-content:space-between;font-size:10px;color:#aaa;margin-top:2px">
            <span>Tapado</span><span id="leyenda-mid">–</span><span>Óptimo+</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats del lote seleccionado -->
    <div class="card" id="card-stats-lote" style="display:none">
      <div class="card-head"><span class="card-title" id="stats-lote-nombre">–</span></div>
      <div class="card-body">
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center">
            <div style="font-family:var(--font-m);font-size:18px;color:var(--lime)" id="stat-semillas">–</div>
            <div style="font-size:10px;color:var(--muted2);margin-top:2px">Semillas totales</div>
          </div>
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center">
            <div style="font-family:var(--font-m);font-size:18px;color:var(--blue)" id="stat-duracion">–</div>
            <div style="font-size:10px;color:var(--muted2);margin-top:2px">Duración (min)</div>
          </div>
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center">
            <div style="font-family:var(--font-m);font-size:18px;color:var(--teal)" id="stat-cultivo">–</div>
            <div style="font-size:10px;color:var(--muted2);margin-top:2px">Cultivo</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Leaflet -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<script>
let mapa         = null;
let capaDensidad = null;
let capaSemillas = null;
let loteActual   = null;
let mostrarSemillas = false;
let exportData   = null;

// ── Init mapa ────────────────────────────────────────────
function initMapa() {
  if (mapa) return;
  mapa = L.map("vx-mapa", { zoomControl:true, preferCanvas:true })
           .setView([-34.6, -60.0], 10);

  L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}", {
    attribution: "Esri World Imagery", maxZoom: 20,
  }).addTo(mapa);

  L.tileLayer("https://services.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}", {
    maxZoom: 20, opacity: 0.6,
  }).addTo(mapa);
}

// ── Color por SPM ────────────────────────────────────────
function spmAColor(spm, objetivo) {
  if (!spm || spm <= 0) return "#ff1744";
  const pct = Math.min(spm / (objetivo * 1.2), 1);
  const lerp = (c1, c2, t) => {
    const p = s => [parseInt(s.slice(1,3),16),parseInt(s.slice(3,5),16),parseInt(s.slice(5,7),16)];
    const [r1,g1,b1]=p(c1),[r2,g2,b2]=p(c2);
    return '#'+[Math.round(r1+(r2-r1)*t),Math.round(g1+(g2-g1)*t),Math.round(b1+(b2-b1)*t)].map(v=>v.toString(16).padStart(2,'0')).join('');
  };
  if (pct < 0.5) return lerp('#ffb300','#ffea00', pct/0.5);
  return              lerp('#ffea00','#00e676', (pct-0.5)/0.5);
}

// ── Cargar lotes ─────────────────────────────────────────
async function cargarLotes() {
  try {
    const lotes = await Auth.get('/api/vistax/lotes');
    const stats = await Auth.get('/api/vistax/stats').catch(() => ({}));

    document.getElementById('kpi-lotes').textContent          = lotes.length;
    document.getElementById('kpi-con-densidad').textContent   = lotes.filter(l=>l.tiene_densidad).length;
    document.getElementById('kpi-con-semillas').textContent   = lotes.filter(l=>l.tiene_semillas).length;
    document.getElementById('total-lotes').textContent        = `${lotes.length} lote${lotes.length!==1?'s':''}`;
    document.getElementById('vx-estado').textContent          = stats.ultimo_sync
      ? 'Último sync: ' + new Date(stats.ultimo_sync).toLocaleString('es-AR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})
      : 'Sin datos aún';

    const lista = document.getElementById('lista-lotes');

    if (!lotes.length) {
      lista.innerHTML = `
        <div class="empty-state" style="padding:40px">
          <span class="icon">🌾</span>
          <p>Sin lotes sincronizados aún.<br>
          Verificá que el agente OrbitX esté corriendo<br>
          con VISTAX_PATH configurado en el .env.</p>
        </div>`;
      return;
    }

    lista.innerHTML = lotes.map(l => {
      const fecha = l.startTs ? new Date(l.startTs).toLocaleDateString('es-AR') : '–';
      const hora  = l.startTs ? new Date(l.startTs).toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}) : '';
      const activo = !l.endTs;
      return `
        <div onclick="verLote('${l.lote_id}', '${(l.nombre||'').replace(/'/g,"\\'")}', ${l.tiene_semillas})"
          style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.04);cursor:pointer;transition:background .1s"
          onmouseover="this.style.background='var(--surface2)'" onmouseout="this.style.background=''">
          <div style="width:34px;height:34px;border-radius:8px;background:var(--lime-dim);border:1px solid rgba(184,255,60,0.2);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">🌾</div>
          <div style="flex:1;min-width:0">
            <div class="td-main">${l.nombre || l.lote_id}</div>
            <div style="display:flex;gap:5px;margin-top:3px;flex-wrap:wrap">
              ${l.cultivo && l.cultivo!=='–' ? `<span class="badge badge-teal" style="font-size:9px">${l.cultivo}</span>` : ''}
              ${l.tiene_densidad ? '<span class="badge badge-lime" style="font-size:9px">Densidad</span>' : ''}
              ${l.tiene_semillas ? '<span class="badge badge-blue" style="font-size:9px">Semillas GPS</span>' : ''}
              ${activo ? '<span class="badge badge-red" style="font-size:9px">● Grabando</span>' : ''}
              ${l.totalSemillas > 0 ? `<span class="badge badge-gray" style="font-size:9px">${l.totalSemillas.toLocaleString('es-AR')} sem.</span>` : ''}
            </div>
          </div>
          <div class="td-dim" style="font-size:10px;text-align:right;white-space:nowrap">
            ${fecha}<br>${hora}
          </div>
        </div>`;
    }).join('');

  } catch(e) {
    document.getElementById('lista-lotes').innerHTML = `<div class="alert error show">${e.message}</div>`;
    document.getElementById('vx-estado').textContent = 'Error al cargar';
  }
}

// ── Ver lote en el mapa ───────────────────────────────────
async function verLote(loteId, nombre, tieneSemillas) {
  initMapa();
  loteActual = loteId;
  mostrarSemillas = false;

  document.getElementById('mapa-titulo').textContent = nombre || loteId;
  document.getElementById('card-stats-lote').style.display = 'block';
  document.getElementById('btn-export').style.display = 'inline-flex';
  document.getElementById('btn-toggle-semillas').style.display = tieneSemillas ? 'inline-flex' : 'none';
  document.getElementById('vx-leyenda').style.display = 'block';

  // Limpiar capas anteriores
  if (capaDensidad) { mapa.removeLayer(capaDensidad); capaDensidad = null; }
  if (capaSemillas) { mapa.removeLayer(capaSemillas); capaSemillas = null; }

  // Cargar detalle del lote
  try {
    const detalle = await Auth.get(`/api/vistax/lote/${loteId}`);
    if (detalle.meta) {
      document.getElementById('stat-semillas').textContent  = (detalle.meta.totalSemillas||0).toLocaleString('es-AR');
      document.getElementById('stat-duracion').textContent  = detalle.meta.duracionMin || '–';
      document.getElementById('stat-cultivo').textContent   = detalle.meta.cultivo || '–';
      document.getElementById('stats-lote-nombre').textContent = detalle.meta.nombre || loteId;
    }
  } catch {}

  // Cargar GeoJSON de densidad
  try {
    const geojson  = await Auth.get(`/api/vistax/geojson/${loteId}`);
    exportData     = geojson;

    // Calcular objetivo desde las propiedades
    const spms  = geojson.features.map(f => f.properties.spmPromedio || 0).filter(v => v > 0);
    const objetivo = spms.length ? (spms.reduce((a,b)=>a+b,0)/spms.length) * 1.1 : 16;
    const spmMax   = spms.length ? Math.max(...spms) : 16;

    document.getElementById('leyenda-mid').textContent = (spmMax/2).toFixed(1);

    capaDensidad = L.geoJSON(geojson, {
      pointToLayer: (feature, latlng) => {
        const spm   = feature.properties.spmPromedio || 0;
        const color = spmAColor(spm, objetivo);
        return L.circleMarker(latlng, {
          radius:      3,
          fillColor:   color,
          fillOpacity: 0.85,
          color:       "transparent",
          weight:      0,
        });
      },
      onEachFeature: (feature, layer) => {
        const p = feature.properties;
        layer.bindTooltip(`
          <div style="font-size:11px;color:#ccc">
            <b style="color:${spmAColor(p.spmPromedio||0,objetivo)}">${(p.spmPromedio||0).toFixed(1)} sem/m</b><br>
            ${p.alerta ? '<span style="color:#ff1744">⚠ Alerta</span>' : ''}
            <span style="color:#555">${new Date(p.ts).toLocaleTimeString('es-AR')}</span>
          </div>`, { opacity:1 });
      },
    }).addTo(mapa);

    // Ajustar vista
    try { mapa.fitBounds(capaDensidad.getBounds(), { padding:[40,40], maxZoom:18 }); } catch {}

  } catch(e) {
    toast('Sin mapa de densidad para este lote', '', 'amber');
  }
}

// ── Toggle capa de semillas ───────────────────────────────
async function toggleCapaSemillas() {
  if (!loteActual) return;
  mostrarSemillas = !mostrarSemillas;
  const btn = document.getElementById('btn-toggle-semillas');

  if (mostrarSemillas) {
    btn.textContent = 'Densidad';
    if (capaDensidad) { mapa.removeLayer(capaDensidad); }
    if (!capaSemillas) {
      try {
        const geojson = await Auth.get(`/api/vistax/semillas/${loteActual}`);
        capaSemillas  = L.geoJSON(geojson, {
          pointToLayer: (feature, latlng) => L.circleMarker(latlng, {
            radius:      2,
            fillColor:   "#00e676",
            fillOpacity: 0.7,
            color:       "transparent",
            weight:      0,
          }),
          onEachFeature: (feature, layer) => {
            const p = feature.properties;
            layer.bindTooltip(
              `<div style="font-size:11px;color:#ccc">Surco <b>${p.bajada}</b> · ${p.count} sem.</div>`,
              { opacity:1 }
            );
          },
        }).addTo(mapa);
      } catch(e) {
        toast('Sin datos de semillas GPS', e.message, 'amber');
        mostrarSemillas = false; btn.textContent = 'Semillas'; return;
      }
    } else {
      capaSemillas.addTo(mapa);
    }
  } else {
    btn.textContent = 'Semillas';
    if (capaSemillas) mapa.removeLayer(capaSemillas);
    if (capaDensidad) capaDensidad.addTo(mapa);
  }
}

// ── Exportar GeoJSON ──────────────────────────────────────
function exportarGeoJSON() {
  if (!exportData) return;
  const blob = new Blob([JSON.stringify(exportData, null, 2)], { type:'application/json' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = `${loteActual || 'lote'}_densidad.geojson`;
  a.click();
  URL.revokeObjectURL(a.href);
}

// ── Auto-cargar al abrir ──────────────────────────────────
document.addEventListener('DOMContentLoaded', cargarLotes);
</script>
