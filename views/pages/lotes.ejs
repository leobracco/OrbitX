document.addEventListener('DOMContentLoaded', cargarLotes);

// ═══════════════════════════════════════════════════════════
// CREAR LOTE — modal con dibujo de boundary en mapa Leaflet
// ═══════════════════════════════════════════════════════════
let _clMapa = null, _clMarkers = [], _clPoly = null, _clPuntos = [];

async function abrirCrearLote() {
  // Reset
  _clPuntos = [];
  document.getElementById("cl-nombre").value    = "";
  document.getElementById("cl-cultivo").value   = "";
  document.getElementById("cl-temporada").value = "";
  document.getElementById("cl-tags").value      = "";
  document.getElementById("cl-notas").value     = "";
  document.getElementById("cl-ha").textContent  = "0 ha";
  document.getElementById("cl-alert").className = "alert";

  openModal("modal-crear");

  // Cargar dispositivos disponibles para el selector.
  cargarDevicesCrearLote();

  // Inicializar mapa después que el modal sea visible (Leaflet necesita el size).
  setTimeout(() => initMapaCrearLote(), 50);
}

async function cargarDevicesCrearLote() {
  const sel = document.getElementById("cl-device");
  sel.innerHTML = '<option value="">— Solo guardar en cloud —</option>';
  try {
    const devs = await Auth.get("/api/devices");
    (Array.isArray(devs) ? devs : []).forEach(d => {
      const op = document.createElement("option");
      op.value = d.device_id;
      op.textContent = `${d.nombre || d.device_id}${d.online ? " · online" : ""}`;
      sel.appendChild(op);
    });
  } catch {}
}

function initMapaCrearLote() {
  if (_clMapa) {
    _clMapa.invalidateSize();
    clLimpiar();
    return;
  }
  _clMapa = L.map("cl-mapa", { zoomControl: true }).setView([-34.6, -60.0], 6);
  L.tileLayer(
    "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
    { attribution: "Esri", maxNativeZoom: 17, maxZoom: 22 }
  ).addTo(_clMapa);

  // Buscador de ubicación (geocoder simple via Nominatim).
  const buscador = L.control({ position: "topright" });
  buscador.onAdd = () => {
    const div = L.DomUtil.create("div");
    div.innerHTML = `<input id="cl-buscar" placeholder="🔍 Buscar dirección…"
      style="background:rgba(0,0,0,0.8);border:1px solid #555;color:#fff;padding:7px 10px;border-radius:6px;font-size:12px;width:220px;outline:none"/>`;
    L.DomEvent.disableClickPropagation(div);
    return div;
  };
  buscador.addTo(_clMapa);

  setTimeout(() => {
    const inp = document.getElementById("cl-buscar");
    if (!inp) return;
    inp.addEventListener("keydown", async e => {
      if (e.key !== "Enter") return;
      const q = inp.value.trim();
      if (!q) return;
      try {
        const r = await fetch(`https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(q)}`);
        const j = await r.json();
        if (j[0]) {
          _clMapa.setView([parseFloat(j[0].lat), parseFloat(j[0].lon)], 16);
        }
      } catch {}
    });
  }, 100);

  _clMapa.on("click", clOnClick);
  _clMapa.on("dblclick", clBorrarUltimo);
}

function clOnClick(e) {
  const punto = [e.latlng.lat, e.latlng.lng];

  // Si el click está cerca del primer punto Y ya hay 3+, cerrar el polígono.
  if (_clPuntos.length >= 3) {
    const p0 = _clMapa.latLngToContainerPoint(_clPuntos[0]);
    const pc = _clMapa.latLngToContainerPoint(e.latlng);
    if (Math.hypot(pc.x - p0.x, pc.y - p0.y) < 14) {
      clRedibujar(true);
      return;
    }
  }

  _clPuntos.push(punto);
  clRedibujar();
}

function clBorrarUltimo() {
  if (!_clPuntos.length) return;
  _clPuntos.pop();
  clRedibujar();
}

function clRedibujar(cerrado) {
  _clMarkers.forEach(m => _clMapa.removeLayer(m));
  _clMarkers = [];
  if (_clPoly) { _clMapa.removeLayer(_clPoly); _clPoly = null; }

  _clPuntos.forEach((p, i) => {
    const m = L.circleMarker(p, {
      radius: i === 0 ? 7 : 5,
      color: i === 0 ? "#A4BA3E" : "#fff",
      weight: 2, fillColor: i === 0 ? "#A4BA3E" : "#fff", fillOpacity: 1,
    }).addTo(_clMapa);
    _clMarkers.push(m);
  });

  if (_clPuntos.length >= 2) {
    if (cerrado || _clPuntos.length >= 3) {
      _clPoly = L.polygon(_clPuntos, {
        color: "#A4BA3E", weight: 2, fillColor: "#A4BA3E", fillOpacity: 0.20,
      }).addTo(_clMapa);
    } else {
      _clPoly = L.polyline(_clPuntos, { color: "#A4BA3E", weight: 2, dashArray: "4 6" }).addTo(_clMapa);
    }
  }

  // Calcular hectáreas (shoelace en proyección equirectangular local).
  let ha = 0;
  if (_clPuntos.length >= 3) {
    const meanLat = _clPuntos.reduce((s, p) => s + p[0], 0) / _clPuntos.length * Math.PI / 180;
    const mLon = 111320 * Math.cos(meanLat);
    const mLat = 110540;
    let acc = 0;
    for (let i = 0; i < _clPuntos.length; i++) {
      const [lat1, lon1] = _clPuntos[i];
      const [lat2, lon2] = _clPuntos[(i + 1) % _clPuntos.length];
      acc += (lon1 * mLon * lat2 * mLat - lon2 * mLon * lat1 * mLat);
    }
    ha = Math.abs(acc / 2) / 10000;
  }
  document.getElementById("cl-ha").textContent = `${ha.toFixed(2)} ha · ${_clPuntos.length} puntos`;
}

function clLimpiar() {
  _clPuntos = [];
  clRedibujar();
}

async function clGuardar() {
  const alert = document.getElementById("cl-alert");
  alert.className = "alert";

  const nombre    = document.getElementById("cl-nombre").value.trim();
  const cultivo   = document.getElementById("cl-cultivo").value.trim();
  const temporada = document.getElementById("cl-temporada").value.trim();
  const tags      = document.getElementById("cl-tags").value.split(",").map(s => s.trim()).filter(Boolean);
  const notas     = document.getElementById("cl-notas").value.trim();
  const device_id = document.getElementById("cl-device").value;

  if (!nombre) { alert.className = "alert error show"; alert.textContent = "Pasá el nombre del lote"; return; }
  if (_clPuntos.length < 3) { alert.className = "alert error show"; alert.textContent = "Dibujá al menos 3 puntos"; return; }

  try {
    const r = await Auth.post("/api/lotes-maestro/crear", {
      nombre,
      boundary: _clPuntos,
      cultivo: cultivo || null,
      temporada: temporada || null,
      tags,
      notas,
      device_id: device_id || null,
    });

    closeModal("modal-crear");
    if (typeof toast === "function") {
      toast("✓ Lote creado",
            `${r.ha_calculadas} ha${r.encolados ? ` · enviado a ${r.device_id}` : ""}`,
            "lime");
    }
    cargarLotes(true);
  } catch (e) {
    alert.className = "alert error show";
    alert.textContent = e.message || "No pudimos guardar el lote";
  }
}
</script>
