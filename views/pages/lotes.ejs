// ── Tabs ──────────────────────────────────────────────────
function switchTab(tab, force) {
  if (tab === _tabActual && !force) return;
  _tabActual = tab;
  ['aog','vistax','capas','info'].forEach(t => {
    document.getElementById(`tab-${t}`)?.classList.toggle('tab-active', t === tab);
    const cont = document.getElementById(`tab-content-${t}`);
    if (cont) cont.style.display = t === tab ? 'block' : 'none';
  });
}

// ── Editar metadata ───────────────────────────────────────
function abrirEditarLote() {
  const ctx = _contextoActual || {};
  document.getElementById('mel-nombre').textContent = _loteActual;
  document.getElementById('mel-cultivo').value      = ctx.cultivo      || '';
  document.getElementById('mel-temporada').value    = ctx.temporada    || '';
  document.getElementById('mel-ha').value           = ctx.ha_estimadas || '';
  document.getElementById('mel-tags').value         = (ctx.tags||[]).join(', ');
  document.getElementById('mel-notas').value        = ctx.notas        || '';
  openModal('modal-editar-lote');
}

async function guardarMetadata() {
  try {
    const tags = document.getElementById('mel-tags').value.split(',').map(t=>t.trim()).filter(Boolean);
    await Auth.put(`/api/lotes-maestro/${encodeURIComponent(_loteActual)}`, {
      cultivo:      document.getElementById('mel-cultivo').value.trim()  || null,
      temporada:    document.getElementById('mel-temporada').value.trim() || null,
      ha_estimadas: parseFloat(document.getElementById('mel-ha').value)   || null,
      tags,
      notas:        document.getElementById('mel-notas').value.trim(),
    });
    toast('✓ Guardado', _loteActual, 'lime');
    closeModal('modal-editar-lote');
    await abrirLote(encodeURIComponent(_loteActual));
    cargarLotes();
  } catch(e) { toast('Error', e.message, 'red'); }
}

// ── Agregar capa ──────────────────────────────────────────
function abrirAgregarCapa() {
  document.getElementById('mc-lote-nombre').textContent = _loteActual;
  document.getElementById('mc-nombre').value  = '';
  document.getElementById('mc-resumen').value = '';
  document.getElementById('mc-file-label').textContent = 'Sin archivo';
  document.getElementById('mc-alert').classList.remove('show');
  _capaFile = null;
  openModal('modal-capa');
}

function abrirAgregarCapaDirecto(nombreEnc) {
  _loteActual = decodeURIComponent(nombreEnc);
  abrirAgregarCapa();
}

function onCapaFile(file) {
  if (!file) return;
  _capaFile = file;
  document.getElementById('mc-file-label').textContent = `${file.name} (${(file.size/1024).toFixed(0)} KB)`;
}

async function guardarCapa() {
  const subtipo = document.getElementById('mc-subtipo').value;
  const nombre  = document.getElementById('mc-nombre').value.trim();
  if (!nombre) {
    const el = document.getElementById('mc-alert');
    el.textContent = 'Ingresá un nombre/descripción'; el.className = 'alert error show';
    return;
  }

  const btn = document.getElementById('btn-guardar-capa');
  btn.disabled = true; btn.textContent = 'Guardando…';

  try {
    const body = {
      subtipo,
      nombre,
      fuente:  document.getElementById('mc-fuente').value,
      resumen: document.getElementById('mc-resumen').value.trim() || null,
    };

    // Adjuntar archivo si hay
    if (_capaFile) {
      const TEXT_EXTS = new Set(['geojson','json','csv','kml','txt','prj']);
      const ext = _capaFile.name.split('.').pop().toLowerCase();
      if (TEXT_EXTS.has(ext) && _capaFile.size < 5*1024*1024) {
        body.contenido_texto = await new Promise((res,rej) => {
          const r = new FileReader();
          r.onload = () => res(r.result);
          r.onerror = rej;
          r.readAsText(_capaFile, 'utf-8');
        });
      } else {
        body.base64 = await new Promise((res,rej) => {
          const r = new FileReader();
          r.onload = () => res(r.result.split(',')[1]);
          r.onerror = rej;
          r.readAsDataURL(_capaFile);
        });
        body.mediaType = _capaFile.type;
      }
    }

    await Auth.post(`/api/lotes-maestro/${encodeURIComponent(_loteActual)}/capa`, body);
    toast('✓ Capa agregada', nombre, 'lime');
    closeModal('modal-capa');
    if (_contextoActual) await abrirLote(encodeURIComponent(_loteActual));
    cargarLotes();
  } catch(e) {
    const el = document.getElementById('mc-alert');
    el.textContent = e.message; el.className = 'alert error show';
  } finally {
    btn.disabled = false; btn.textContent = 'Guardar capa';
  }
}

