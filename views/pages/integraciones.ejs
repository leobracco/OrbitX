<%# pages/integraciones.ejs %>
<%# Solo visible para owner / admin_org %>

<div class="page-header">
  <div>
    <h2>Integraciones</h2>
    <p>Conectá servicios externos a tu establecimiento</p>
  </div>
</div>

<div style="max-width:560px">

  <!-- ══ Copernicus Data Space ══════════════════════════ -->
  <div class="card" style="margin-bottom:16px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
      <div style="width:36px;height:36px;background:var(--surface2);border-radius:8px;
                  display:flex;align-items:center;justify-content:center;font-size:18px">🛰</div>
      <div>
        <div style="font-weight:500;font-size:14px">Copernicus Data Space</div>
        <div style="font-size:12px;color:var(--text-dim)">NDVI · Sentinel-2 · Gratis hasta 10.000 PU/mes</div>
      </div>
      <div style="margin-left:auto">
        <span id="cop-badge" class="badge badge-gray">No configurado</span>
      </div>
    </div>

    <div id="cop-info" style="display:none;margin-bottom:12px;font-size:12px;color:var(--text-dim)"></div>

    <div id="cop-form" style="display:flex;flex-direction:column;gap:10px">
      <div class="field">
        <label>Client ID</label>
        <input type="text" id="cop-client-id"
          placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
          style="font-family:monospace;font-size:12px"/>
      </div>
      <div class="field">
        <label>Client Secret</label>
        <input type="password" id="cop-client-secret" placeholder="••••••••••••••••"/>
      </div>
      <div class="field">
        <label>Instance ID (WMS de Sentinel Hub Dashboard)</label>
        <input type="text" id="cop-instance-id"
          placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
          style="font-family:monospace;font-size:12px"/>
      </div>

      <div style="font-size:11px;color:var(--text-dim);line-height:1.6;
                  background:var(--surface2);padding:10px;border-radius:8px">
        <strong style="color:var(--text)">¿Cómo obtener estas credenciales?</strong><br>
        1. Registrate gratis en
        <a href="https://dataspace.copernicus.eu" target="_blank">dataspace.copernicus.eu</a><br>
        2. En Sentinel Hub Dashboard → Configuration Utility → New configuration (tipo WMS)<br>
        3. Copiá el <em>Instance ID</em> de esa configuración<br>
        4. En Account → OAuth clients → New client → copiá Client ID y Secret
      </div>

      <div style="display:flex;gap:8px">
        <button class="btn btn-primary" onclick="guardarCopernicus()">Guardar</button>
        <button class="btn btn-ghost" id="cop-btn-eliminar"
          style="display:none;color:var(--red)" onclick="eliminarCopernicus()">Eliminar</button>
      </div>
    </div>
  </div>

  <!-- Más integraciones futuras acá -->

</div>

<script>
(async () => {
  try {
    const r = await Auth.get('/api/integraciones/copernicus');
    const badge = document.getElementById('cop-badge');
    const info  = document.getElementById('cop-info');
    const btnEl = document.getElementById('cop-btn-eliminar');

    if (r.configurado) {
      badge.textContent = 'Activo';
      badge.className   = 'badge badge-lime';
      btnEl.style.display = 'inline-flex';
      if (r.configurado_at) {
        info.style.display = 'block';
        info.textContent   = 'Configurado el ' +
          new Date(r.configurado_at).toLocaleString('es-AR',
            { day:'2-digit', month:'2-digit', year:'numeric',
              hour:'2-digit', minute:'2-digit' });
      }
    }
  } catch(e) { console.error(e); }
})();

async function guardarCopernicus() {
  const client_id     = document.getElementById('cop-client-id').value.trim();
  const client_secret = document.getElementById('cop-client-secret').value.trim();
  const instance_id   = document.getElementById('cop-instance-id').value.trim();

  if (!client_id || !client_secret || !instance_id) {
    return toast('Faltan datos', 'Completá los tres campos', 'amber');
  }

  try {
    await Auth.put('/api/integraciones/copernicus', { client_id, client_secret, instance_id });
    toast('✓ Integración guardada', 'NDVI disponible en el mapa de lotes', 'lime');
    document.getElementById('cop-badge').textContent = 'Activo';
    document.getElementById('cop-badge').className   = 'badge badge-lime';
    document.getElementById('cop-btn-eliminar').style.display = 'inline-flex';
    // Limpiar los campos sensibles de la UI
    document.getElementById('cop-client-secret').value = '';
  } catch(e) {
    toast('Error', e.message, 'red');
  }
}

async function eliminarCopernicus() {
  if (!confirm('¿Eliminar las credenciales de Copernicus? El NDVI dejará de funcionar.')) return;
  try {
    await Auth.del('/api/integraciones/copernicus');
    toast('Credenciales eliminadas', '', 'amber');
    document.getElementById('cop-badge').textContent = 'No configurado';
    document.getElementById('cop-badge').className   = 'badge badge-gray';
    document.getElementById('cop-btn-eliminar').style.display = 'none';
  } catch(e) {
    toast('Error', e.message, 'red');
  }
}
</script>
