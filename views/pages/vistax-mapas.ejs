<%# pages/vistax-mapas.ejs — Viewer de shapefiles VistaX (sesiones de siembra) %>

<link rel="stylesheet" href="/lib/leaflet/leaflet.min.css">
<script src="/lib/leaflet/leaflet.min.js"></script>

<div class="page-header">
  <div>
    <h2>VistaX — Mapas de sesión</h2>
    <p>Shapefiles sincronizados de AOG · Puntos por surco coloreados por SPM</p>
  </div>
  <div style="display:flex; gap:8px; align-items:center">
    <select id="vxm-sesion" class="input" style="min-width:340px">
      <option value="">Cargando sesiones...</option>
    </select>
    <a href="/vistax-mapas" class="btn">↻ Actualizar</a>
  </div>
</div>

<div id="vxm-info" style="font-size:12px; color:var(--muted2); margin-bottom:10px">
  Cargando...
</div>

<div id="vxm-mapa" style="height:calc(100vh - 240px); min-height:480px; border-radius:10px; overflow:hidden; background:#0a0a0a"></div>

<div style="font-size:11px; color:var(--muted2); margin-top:8px">
  <strong>Leyenda SPM</strong>:
  <span style="color:#ff1744">● tapado</span> ·
  <span style="color:#ff9100">● bajo (&lt;4)</span> ·
  <span style="color:#ffea00">● medio (4–7)</span> ·
  <span style="color:#76ff03">● bueno (7–10)</span> ·
  <span style="color:#00e676">● excelente (≥10)</span>
</div>

<script src="/js/vistax-mapas.js"></script>
