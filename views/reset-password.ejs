<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { title: 'Cambiar contraseña' }) %>
</head>
<body>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;position:relative;z-index:1">
  <div style="width:100%;max-width:420px;background:rgba(26,31,37,0.95);border:1px solid var(--ap-border);border-radius:14px;padding:32px;backdrop-filter:blur(20px)">

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
      <img src="/img/brand/favicon.png" alt="Agro Parallel" width="36" height="36" style="border-radius:7px"/>
      <div style="line-height:1.1">
        <div style="font-size:18px;font-weight:700;color:#fff">Orbit<span style="color:var(--ap-green)">X</span></div>
        <div style="font-size:11px;color:var(--ap-muted)">por Agro Parallel</div>
      </div>
    </div>

    <h2 style="font-size:18px;color:#fff;margin-bottom:6px;font-weight:700">Cambiar contraseña</h2>
    <p style="font-size:13px;color:var(--ap-muted);margin-bottom:18px;line-height:1.6">Elegí una nueva contraseña para tu cuenta.</p>

    <div id="alert" class="alert" style="margin-bottom:14px"></div>

    <div class="form-grid" style="grid-template-columns:1fr">
      <div class="field"><label>Contraseña nueva</label>
        <input type="password" id="pass1" placeholder="Mínimo 8 caracteres"/>
      </div>
      <div class="field"><label>Repetí la contraseña</label>
        <input type="password" id="pass2"/>
      </div>
    </div>

    <button class="btn btn-primary" style="width:100%;margin-top:14px;justify-content:center" onclick="cambiar()">Guardar contraseña</button>
  </div>
</div>

<script>
async function cambiar() {
  const p1 = document.getElementById("pass1").value;
  const p2 = document.getElementById("pass2").value;
  if (p1.length < 8)  return showErr("Mínimo 8 caracteres");
  if (p1 !== p2)      return showErr("Las contraseñas no coinciden");

  try {
    const r = await fetch(`/api/auth/reset-password/<%= token %>`, {
      method:  "POST",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify({ password: p1 }),
    });
    const j = await r.json();
    if (!r.ok) return showErr(j.error || "No pudimos cambiar la contraseña");
    showOk("✓ Contraseña actualizada — ya podés ingresar");
    setTimeout(() => window.location.href = "/login", 1500);
  } catch (e) { showErr("Error: " + e.message); }
}
function showErr(msg) {
  const a = document.getElementById("alert");
  a.textContent = msg; a.className = "alert error show";
}
function showOk(msg) {
  const a = document.getElementById("alert");
  a.textContent = msg; a.className = "alert success show";
}
</script>

</body>
</html>
