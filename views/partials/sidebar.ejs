<%
// sidebar.ejs - Agro Parallel OrbitX
const activeNav = locals.activeNav || req?.path || "";
function navItem(href, icon, label, active) {
  const isActive = (active === href) || (href !== "/" && active?.startsWith(href));
  return `<a href="${href}" class="nav-item${isActive ? " active" : ""}">
    <span class="nav-icon">${icon}</span>
    <span class="nav-label">${label}</span>
  </a>`;
}
%>

<nav class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <span class="logo-mark">O</span>
    <span class="logo-text">OrbitX</span>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Principal</div>
    <%- navItem('/dashboard',  '◈', 'Dashboard',      activeNav) %>
    <%- navItem('/alertas',    '⚠', 'Alertas',         activeNav) %>
    <%- navItem('/dispositivos','⬡','Dispositivos',    activeNav) %>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Gestión</div>
    <%- navItem('/establecimientos', '🏛', 'Establecimientos', activeNav) %>
    <%- navItem('/lotes',   '🌾', 'Lotes',      activeNav) %>
    <%- navItem('/mapa',    '🗺', 'Mapa',        activeNav) %>
    <%- navItem('/vehiculos','🚜','Vehículos',   activeNav) %>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Siembra</div>
    <%- navItem('/vistax',          '🌱', 'VistaX',        activeNav) %>
    <%- navItem('/configuraciones', '⚙',  'Configuraciones',activeNav) %>
    <%- navItem('/prescripciones',  '📋', 'Prescripciones', activeNav) %>
    <%- navItem('/agraria',         '✦',  'agrarIA',        activeNav) %>
  </div>

  <% if (locals.isAdmin || locals.isSA) { %>
  <div class="nav-section">
    <div class="nav-section-label">Administración</div>
    <%- navItem('/registros', '📬', 'Registros',     activeNav) %>
    <%- navItem('/usuarios',  '👤', 'Usuarios',       activeNav) %>
    <%- navItem('/roles',     '🔑', 'Roles',           activeNav) %>
    <%- navItem('/grupos',    '👥', 'Grupos',           activeNav) %>
    <% if (locals.isSA) { %>
    <%- navItem('/config',    '🔧', 'Config sistema',  activeNav) %>
    <%- navItem('/couchdb',   '🗃', 'CouchDB',          activeNav) %>
    <% } %>
  </div>
  <% } %>

  <div class="sidebar-footer">
    <div class="user-pill">
      <span class="user-avatar"><%= (locals.user?.nombre||locals.user?.email||"U")[0].toUpperCase() %></span>
      <div class="user-info">
        <div class="user-name"><%= locals.user?.nombre || locals.user?.email || "Usuario" %></div>
        <div class="user-role"><%= locals.user?.rol_global || "usuario" %></div>
      </div>
    </div>
    <a href="/logout" class="btn-logout" title="Cerrar sesión">↪</a>
  </div>
</nav>
